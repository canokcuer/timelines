{% comment %}
  Daily Ritual Clock — Circadian Rhythm Timeline section.
  Fully self-contained: all base CSS, JS, and CTA markup inlined.
{% endcomment %}

{%- comment -%} ── Slot data ─────────────────────────────────────────── {%- endcomment -%}
{%- assign slots = section.blocks | where: 'type', 'time_slot' -%}

<section
  id="cs-ritual-{{ section.id }}"
  class="cs-timeline cs-ritual"
  aria-label="{{ section.settings.section_title | default: 'Günlük Ritüel' }}"
  data-section-id="{{ section.id }}"
  data-section-type="cs-timeline-ritual"
>
  <div class="cs-timeline__container">
    {%- comment -%} ── Header ───────────────────────────────────────── {%- endcomment -%}
    <header class="cs-timeline__header cs-timeline__reveal">
      {%- if section.settings.kicker != blank -%}
        <span class="cs-timeline__kicker cs-ritual__kicker">
          {{ section.settings.kicker }}
        </span>
      {%- endif -%}

      <h2 class="cs-timeline__title cs-ritual__title">
        {{ section.settings.section_title }}
      </h2>

      {%- if section.settings.subtitle != blank -%}
        <p class="cs-timeline__subtitle cs-ritual__subtitle" style="color: var(--cs-text-dark-muted);">
          {{ section.settings.subtitle }}
        </p>
      {%- endif -%}
    </header>

    {%- if slots.size > 0 -%}
      {%- comment -%} ── Desktop: Circular clock ────────────────────── {%- endcomment -%}
      <cs-ritual-clock
        class="cs-ritual__clock-wrap cs-timeline--hide-mobile cs-timeline__reveal cs-timeline__reveal--scale"
        data-slot-count="{{ slots.size }}"
        role="region"
        aria-label="Sirkadiyen ritim saati"
      >
        <div class="cs-ritual__clock-layout">
          {%- comment -%} SVG Clock ─────────────────────────────────── {%- endcomment -%}
          <div class="cs-ritual__clock-ring" aria-hidden="true">
            <svg
              class="cs-ritual__svg"
              viewBox="0 0 560 560"
              xmlns="http://www.w3.org/2000/svg"
            >
              {%- comment -%} Background circle ──────────────────────── {%- endcomment -%}
              <circle cx="280" cy="280" r="255" fill="none" stroke="var(--cs-text-dark-subtle)" stroke-width="1" opacity="0.2" />

              {%- comment -%} Hour tick marks ──────────────────────────── {%- endcomment -%}
              {%- for h in (0..23) -%}
                {%- assign angle_deg = h | times: 15 | minus: 90 -%}
                {%- comment -%} Pre-calculated cos/sin approximation via Liquid math {%- endcomment -%}
                <line
                  x1="280" y1="280" x2="280" y2="280"
                  class="cs-ritual__tick"
                  data-hour="{{ h }}"
                  transform="rotate({{ angle_deg }} 280 280)"
                />
              {%- endfor -%}

              {%- comment -%} Colored arcs per slot ────────────────────── {%- endcomment -%}
              {%- for block in slots -%}
                <path
                  class="cs-ritual__arc"
                  data-slot-index="{{ forloop.index0 }}"
                  fill="none"
                  stroke="{{ block.settings.accent_color }}"
                  stroke-width="28"
                  stroke-linecap="round"
                  opacity="0.25"
                  d=""
                />
              {%- endfor -%}

              {%- comment -%} Cortisol / melatonin rhythm curve ─────────── {%- endcomment -%}
              <path
                class="cs-ritual__rhythm-curve"
                fill="none"
                stroke="var(--cs-text-dark)"
                stroke-width="1.5"
                opacity="0.08"
                d="M280,60 C350,80 420,170 430,280 C440,390 380,480 280,500 C180,480 120,390 130,280 C140,170 210,80 280,60"
              />
            </svg>
          </div>

          {%- comment -%} Central display ───────────────────────────── {%- endcomment -%}
          <div class="cs-ritual__center" aria-live="polite">
            <span class="cs-ritual__center-time">{{ slots[0].settings.time_label }}</span>
            <span class="cs-ritual__center-state">{{ slots[0].settings.body_state }}</span>
          </div>

          {%- comment -%} Orbiting product cards ────────────────────── {%- endcomment -%}
          <div
            class="cs-ritual__orbit"
            role="tablist"
            aria-label="Ürün zaman dilimleri"
          >
            {%- for block in slots -%}
              <button
                class="cs-ritual__card{% if forloop.first %} cs-ritual__card--active{% endif %}"
                data-slot-index="{{ forloop.index0 }}"
                role="tab"
                id="cs-ritual-tab-{{ section.id }}-{{ forloop.index0 }}"
                aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                aria-controls="cs-ritual-panel-{{ section.id }}-{{ forloop.index0 }}"
                tabindex="{% if forloop.first %}0{% else %}-1{% endif %}"
                style="--card-accent: {{ block.settings.accent_color }};"
                {{ block.shopify_attributes }}
              >
                <span class="cs-ritual__card-time">{{ block.settings.time_label }}</span>
                <span class="cs-ritual__card-name">{{ block.settings.product_name }}</span>
              </button>
            {%- endfor -%}
          </div>
        </div>

        {%- comment -%} Detail panels ──────────────────────────────── {%- endcomment -%}
        {%- for block in slots -%}
          <div
            class="cs-ritual__panel{% if forloop.first %} cs-ritual__panel--active{% endif %}"
            data-slot-index="{{ forloop.index0 }}"
            role="tabpanel"
            id="cs-ritual-panel-{{ section.id }}-{{ forloop.index0 }}"
            aria-labelledby="cs-ritual-tab-{{ section.id }}-{{ forloop.index0 }}"
            {% unless forloop.first %}hidden{% endunless %}
          >
            <div class="cs-ritual__panel-inner">
              <span class="cs-ritual__panel-badge" style="background: {{ block.settings.accent_color }}20; color: {{ block.settings.accent_color }}; border: 1px solid {{ block.settings.accent_color }}40;">
                {{ block.settings.time_label }}
              </span>
              <h3 class="cs-ritual__panel-product">{{ block.settings.product_name }}</h3>
              <p class="cs-ritual__panel-state">{{ block.settings.body_state }}</p>

              {%- if block.settings.benefits != blank -%}
                {%- assign benefit_list = block.settings.benefits | split: '|' -%}
                <ul class="cs-ritual__panel-benefits" role="list">
                  {%- for b in benefit_list -%}
                    <li class="cs-ritual__panel-benefit">{{ b | strip }}</li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}

              {%- if block.settings.product_handle != blank -%}
                <a href="{{ block.settings.product_handle }}" class="cs-timeline__cta cs-timeline__cta--gold cs-ritual__panel-cta">
                  Ürünü Keşfet
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" focusable="false">
                    <path d="M3.333 8h9.334M8.667 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </a>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </cs-ritual-clock>

      {%- comment -%} ── Mobile: Vertical timeline ──────────────────── {%- endcomment -%}
      <div class="cs-ritual__mobile cs-timeline--hide-desktop">
        {%- for block in slots -%}
          <div
            class="cs-ritual__mobile-slot cs-timeline__reveal"
            style="--slot-accent: {{ block.settings.accent_color }}; transition-delay: {{ forloop.index0 | times: 100 }}ms;"
            {{ block.shopify_attributes }}
          >
            <div class="cs-ritual__mobile-rail" aria-hidden="true">
              <span class="cs-ritual__mobile-dot" style="border-color: {{ block.settings.accent_color }}; background: {{ block.settings.accent_color }};"></span>
              {%- unless forloop.last -%}
                <span class="cs-ritual__mobile-line"></span>
              {%- endunless -%}
            </div>

            <div class="cs-ritual__mobile-content">
              <span class="cs-ritual__mobile-time">{{ block.settings.time_label }}</span>
              <h3 class="cs-ritual__mobile-name">{{ block.settings.product_name }}</h3>
              <p class="cs-ritual__mobile-state">{{ block.settings.body_state }}</p>

              {%- if block.settings.benefits != blank -%}
                {%- assign benefit_list = block.settings.benefits | split: '|' -%}
                <ul class="cs-ritual__mobile-benefits" role="list">
                  {%- for b in benefit_list -%}
                    <li>{{ b | strip }}</li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}

              {%- if block.settings.product_handle != blank -%}
                <a href="{{ block.settings.product_handle }}" class="cs-timeline__cta cs-timeline__cta--gold cs-ritual__mobile-cta">
                  Ürünü Keşfet
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" focusable="false">
                    <path d="M3.333 8h9.334M8.667 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </a>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

<style>
/* ============================================================================
   CS Timeline Base — Design Tokens & Shared Utilities
   Cyrasoul Timeline Sections
   ============================================================================ */

/* --------------------------------------------------------------------------
   Design Tokens
   -------------------------------------------------------------------------- */

:root {
  /* Brand Colors */
  --cs-gold: #FFDF00;
  --cs-gold-soft: rgba(255, 223, 0, 0.15);
  --cs-gold-medium: rgba(255, 223, 0, 0.4);
  --cs-teal: #108474;
  --cs-teal-soft: rgba(16, 132, 116, 0.15);
  --cs-teal-medium: rgba(16, 132, 116, 0.4);
  --cs-indigo: #3B3073;
  --cs-indigo-soft: rgba(59, 48, 115, 0.15);

  /* Background Surfaces */
  --cs-bg-dark: #171717;
  --cs-bg-deep: #0a0a0a;
  --cs-bg-warm: #f9f6f2;
  --cs-bg-white: #ffffff;
  --cs-bg-card-dark: rgba(255, 255, 255, 0.04);
  --cs-bg-card-frost: rgba(255, 255, 255, 0.06);

  /* Text */
  --cs-text-white: #ffffff;
  --cs-text-white-muted: rgba(255, 255, 255, 0.7);
  --cs-text-white-subtle: rgba(255, 255, 255, 0.5);
  --cs-text-dark: #171717;
  --cs-text-dark-muted: rgba(23, 23, 23, 0.7);
  --cs-text-dark-subtle: rgba(23, 23, 23, 0.5);

  /* Borders */
  --cs-border-light: rgba(255, 255, 255, 0.08);
  --cs-border-gold: rgba(255, 223, 0, 0.3);
  --cs-border-teal: rgba(16, 132, 116, 0.3);

  /* Typography — Inter stack */
  --cs-font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  --cs-font-size-xs: clamp(0.6875rem, 0.625rem + 0.25vw, 0.75rem);    /* 11-12px */
  --cs-font-size-sm: clamp(0.75rem, 0.6875rem + 0.25vw, 0.875rem);    /* 12-14px */
  --cs-font-size-base: clamp(0.875rem, 0.8125rem + 0.25vw, 1rem);     /* 14-16px */
  --cs-font-size-md: clamp(1rem, 0.9375rem + 0.25vw, 1.125rem);       /* 16-18px */
  --cs-font-size-lg: clamp(1.125rem, 1rem + 0.5vw, 1.375rem);         /* 18-22px */
  --cs-font-size-xl: clamp(1.375rem, 1.125rem + 1vw, 1.75rem);        /* 22-28px */
  --cs-font-size-2xl: clamp(1.75rem, 1.375rem + 1.5vw, 2.5rem);       /* 28-40px */
  --cs-font-size-3xl: clamp(2rem, 1.5rem + 2vw, 3rem);                /* 32-48px */

  /* Spacing */
  --cs-space-xs: clamp(0.25rem, 0.125rem + 0.5vw, 0.5rem);
  --cs-space-sm: clamp(0.5rem, 0.375rem + 0.5vw, 0.75rem);
  --cs-space-md: clamp(0.75rem, 0.5rem + 1vw, 1.25rem);
  --cs-space-lg: clamp(1.25rem, 0.875rem + 1.5vw, 2rem);
  --cs-space-xl: clamp(2rem, 1.25rem + 3vw, 3.5rem);
  --cs-space-2xl: clamp(3rem, 2rem + 4vw, 5rem);
  --cs-space-3xl: clamp(4rem, 2.5rem + 6vw, 7.5rem);

  /* Radii */
  --cs-radius-sm: 4px;
  --cs-radius-md: 8px;
  --cs-radius-lg: 12px;
  --cs-radius-xl: 16px;
  --cs-radius-full: 9999px;

  /* Shadows */
  --cs-shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.12);
  --cs-shadow-md: 0 4px 12px rgba(0, 0, 0, 0.15);
  --cs-shadow-lg: 0 8px 30px rgba(0, 0, 0, 0.2);
  --cs-shadow-gold: 0 0 20px rgba(255, 223, 0, 0.15);
  --cs-shadow-teal: 0 0 20px rgba(16, 132, 116, 0.15);

  /* Transitions */
  --cs-ease-out: cubic-bezier(0.16, 1, 0.3, 1);
  --cs-ease-in-out: cubic-bezier(0.65, 0, 0.35, 1);
  --cs-duration-fast: 200ms;
  --cs-duration-base: 400ms;
  --cs-duration-slow: 600ms;
  --cs-duration-draw: 1200ms;

  /* Z-index scale */
  --cs-z-base: 1;
  --cs-z-above: 10;
  --cs-z-sticky: 100;
  --cs-z-overlay: 200;
  --cs-z-modal: 300;

  /* Layout */
  --cs-content-max: 1200px;
  --cs-content-narrow: 640px;
  --cs-mobile-dock-clearance: 95px;
}

/* --------------------------------------------------------------------------
   Base Reset & Layout
   -------------------------------------------------------------------------- */

.cs-timeline {
  font-family: var(--cs-font-family);
  line-height: 1.6;
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

.cs-timeline *,
.cs-timeline *::before,
.cs-timeline *::after {
  box-sizing: inherit;
}

.cs-timeline__container {
  width: 100%;
  max-width: var(--cs-content-max);
  margin-inline: auto;
  padding-inline: var(--cs-space-md);
}

.cs-timeline__container--narrow {
  max-width: var(--cs-content-narrow);
}

/* --------------------------------------------------------------------------
   Section Header (shared)
   -------------------------------------------------------------------------- */

.cs-timeline__header {
  text-align: center;
  margin-block-end: var(--cs-space-2xl);
}

.cs-timeline__kicker {
  display: inline-block;
  font-size: var(--cs-font-size-xs);
  font-weight: 600;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  margin-block-end: var(--cs-space-sm);
}

.cs-timeline__title {
  font-size: var(--cs-font-size-2xl);
  font-weight: 700;
  letter-spacing: -0.02em;
  line-height: 1.15;
  margin: 0 0 var(--cs-space-md);
}

.cs-timeline__subtitle {
  font-size: var(--cs-font-size-md);
  line-height: 1.5;
  max-width: 540px;
  margin-inline: auto;
}

/* --------------------------------------------------------------------------
   Shared Animation States
   -------------------------------------------------------------------------- */

.cs-timeline__reveal {
  opacity: 0;
  transform: translateY(24px);
  transition:
    opacity var(--cs-duration-slow) var(--cs-ease-out),
    transform var(--cs-duration-slow) var(--cs-ease-out);
}

.cs-timeline__reveal--visible {
  opacity: 1;
  transform: translateY(0);
}

.cs-timeline__reveal--left {
  opacity: 0;
  transform: translateX(-24px);
  transition:
    opacity var(--cs-duration-slow) var(--cs-ease-out),
    transform var(--cs-duration-slow) var(--cs-ease-out);
}

.cs-timeline__reveal--left.cs-timeline__reveal--visible {
  opacity: 1;
  transform: translateX(0);
}

.cs-timeline__reveal--right {
  opacity: 0;
  transform: translateX(24px);
  transition:
    opacity var(--cs-duration-slow) var(--cs-ease-out),
    transform var(--cs-duration-slow) var(--cs-ease-out);
}

.cs-timeline__reveal--right.cs-timeline__reveal--visible {
  opacity: 1;
  transform: translateX(0);
}

.cs-timeline__reveal--scale {
  opacity: 0;
  transform: scale(0.85);
  transition:
    opacity var(--cs-duration-slow) var(--cs-ease-out),
    transform var(--cs-duration-slow) var(--cs-ease-out);
}

.cs-timeline__reveal--scale.cs-timeline__reveal--visible {
  opacity: 1;
  transform: scale(1);
}

/* Stagger children */
.cs-timeline__reveal--visible .cs-timeline__stagger:nth-child(1) { transition-delay: 0ms; }
.cs-timeline__reveal--visible .cs-timeline__stagger:nth-child(2) { transition-delay: 80ms; }
.cs-timeline__reveal--visible .cs-timeline__stagger:nth-child(3) { transition-delay: 160ms; }
.cs-timeline__reveal--visible .cs-timeline__stagger:nth-child(4) { transition-delay: 240ms; }
.cs-timeline__reveal--visible .cs-timeline__stagger:nth-child(5) { transition-delay: 320ms; }
.cs-timeline__reveal--visible .cs-timeline__stagger:nth-child(6) { transition-delay: 400ms; }

.cs-timeline__stagger {
  opacity: 0;
  transform: translateY(12px);
  transition:
    opacity var(--cs-duration-base) var(--cs-ease-out),
    transform var(--cs-duration-base) var(--cs-ease-out);
}

.cs-timeline__reveal--visible .cs-timeline__stagger {
  opacity: 1;
  transform: translateY(0);
}

/* --------------------------------------------------------------------------
   Line Draw Animation
   -------------------------------------------------------------------------- */

.cs-timeline__line-draw {
  stroke-dasharray: var(--line-length, 1000);
  stroke-dashoffset: var(--line-length, 1000);
  transition: stroke-dashoffset var(--cs-duration-draw) var(--cs-ease-in-out);
}

.cs-timeline__line-draw--active {
  stroke-dashoffset: 0;
}

/* --------------------------------------------------------------------------
   Node (shared dot/circle on timeline)
   -------------------------------------------------------------------------- */

.cs-timeline__node {
  position: relative;
  width: 16px;
  height: 16px;
  border-radius: var(--cs-radius-full);
  border: 2px solid var(--cs-gold);
  background: transparent;
  transition: background var(--cs-duration-base) var(--cs-ease-out),
              box-shadow var(--cs-duration-base) var(--cs-ease-out);
  flex-shrink: 0;
}

.cs-timeline__node--active {
  background: var(--cs-gold);
  box-shadow: var(--cs-shadow-gold);
}

.cs-timeline__node--large {
  width: 24px;
  height: 24px;
}

/* --------------------------------------------------------------------------
   Frosted Glass Card
   -------------------------------------------------------------------------- */

.cs-timeline__card-frost {
  background: var(--cs-bg-card-frost);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid var(--cs-border-light);
  border-radius: var(--cs-radius-lg);
  padding: var(--cs-space-lg);
}

/* --------------------------------------------------------------------------
   Tag / Pill
   -------------------------------------------------------------------------- */

.cs-timeline__tag {
  display: inline-flex;
  align-items: center;
  gap: 0.25em;
  font-size: var(--cs-font-size-xs);
  font-weight: 600;
  padding: 0.25em 0.75em;
  border-radius: var(--cs-radius-full);
  white-space: nowrap;
}

.cs-timeline__tag--gold {
  background: var(--cs-gold-soft);
  color: var(--cs-gold);
  border: 1px solid var(--cs-border-gold);
}

.cs-timeline__tag--teal {
  background: var(--cs-teal-soft);
  color: var(--cs-teal);
  border: 1px solid var(--cs-border-teal);
}

/* --------------------------------------------------------------------------
   CTA Button (base)
   -------------------------------------------------------------------------- */

.cs-timeline__cta {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5em;
  font-family: var(--cs-font-family);
  font-size: var(--cs-font-size-sm);
  font-weight: 600;
  letter-spacing: 0.04em;
  text-decoration: none;
  padding: 0.875em 2em;
  border-radius: var(--cs-radius-full);
  border: none;
  cursor: pointer;
  min-height: 44px;
  min-width: 44px;
  transition:
    background var(--cs-duration-fast) var(--cs-ease-out),
    transform var(--cs-duration-fast) var(--cs-ease-out),
    box-shadow var(--cs-duration-fast) var(--cs-ease-out);
}

.cs-timeline__cta:hover {
  transform: translateY(-1px);
}

.cs-timeline__cta:active {
  transform: translateY(0);
}

.cs-timeline__cta--gold {
  background: var(--cs-gold);
  color: var(--cs-bg-dark);
}

.cs-timeline__cta--gold:hover {
  box-shadow: var(--cs-shadow-gold);
}

.cs-timeline__cta--ghost {
  background: transparent;
  border: 1px solid var(--cs-border-light);
  color: var(--cs-text-white);
}

.cs-timeline__cta--ghost:hover {
  background: rgba(255, 255, 255, 0.05);
}

/* --------------------------------------------------------------------------
   Progress Bar (shared)
   -------------------------------------------------------------------------- */

.cs-timeline__progress {
  position: relative;
  width: 100%;
  height: 2px;
  background: var(--cs-border-light);
  border-radius: var(--cs-radius-full);
  overflow: hidden;
}

.cs-timeline__progress-fill {
  position: absolute;
  inset-block: 0;
  inset-inline-start: 0;
  width: 0%;
  background: linear-gradient(90deg, var(--cs-gold), var(--cs-teal));
  border-radius: var(--cs-radius-full);
  transition: width var(--cs-duration-base) var(--cs-ease-out);
}

/* --------------------------------------------------------------------------
   Prefers Reduced Motion (base)
   -------------------------------------------------------------------------- */

@media (prefers-reduced-motion: reduce) {
  .cs-timeline__reveal,
  .cs-timeline__reveal--left,
  .cs-timeline__reveal--right,
  .cs-timeline__reveal--scale,
  .cs-timeline__stagger,
  .cs-timeline__line-draw,
  .cs-timeline__node,
  .cs-timeline__cta,
  .cs-timeline__progress-fill {
    transition-duration: 0.01ms !important;
    animation-duration: 0.01ms !important;
  }

  .cs-timeline__reveal,
  .cs-timeline__reveal--left,
  .cs-timeline__reveal--right,
  .cs-timeline__reveal--scale {
    opacity: 1;
    transform: none;
  }

  .cs-timeline__stagger {
    opacity: 1;
    transform: none;
  }

  .cs-timeline__line-draw {
    stroke-dashoffset: 0;
  }
}

/* --------------------------------------------------------------------------
   Responsive Utilities
   -------------------------------------------------------------------------- */

@media screen and (max-width: 749px) {
  .cs-timeline--hide-mobile {
    display: none !important;
  }

  .cs-timeline {
    padding-block-end: var(--cs-mobile-dock-clearance);
  }
}

@media screen and (min-width: 750px) {
  .cs-timeline--hide-desktop {
    display: none !important;
  }
}

/* Screen reader only */
.cs-timeline__sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border-width: 0;
}

/* ==========================================================================
   CS Ritual — Daily Ritual Clock
   ========================================================================== */

/* ── Section root ───────────────────────────────────────────────────────── */
.cs-ritual {
  background: var(--cs-bg-warm);
  color: var(--cs-text-dark);
  padding-block: var(--cs-space-3xl);
