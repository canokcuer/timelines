{%- if section.blocks.size > 0 -%}
  {%- assign total_slides = section.blocks.size -%}
  <section
    class="ingredient-showcase"
    data-section-id="{{ section.id }}"
    style="
      --bg-color: {{ section.settings.bg_color }};
      --text-color: {{ section.settings.text_color }};
      --accent-color: {{ section.settings.accent_color }};
      --tag-border-color: {{ section.settings.tag_border_color }};
      --heading-font: inherit;
      --body-font: inherit;
      --padding-top: {{ section.settings.padding_top }}px;
      --padding-bottom: {{ section.settings.padding_bottom }}px;
    "
  >
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="ingredient-showcase__header">
        {%- if section.settings.heading != blank -%}
          <h2 class="ingredient-showcase__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="ingredient-showcase__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if total_slides > 1 -%}
      <div class="ingredient-showcase__tabs">
        {%- for block in section.blocks -%}
          <button
            class="ingredient-showcase__tab{% if forloop.first %} ingredient-showcase__tab--active{% endif %}"
            data-tab="{{ forloop.index0 }}"
          >
            {{ block.settings.name }}
          </button>
        {%- endfor -%}
      </div>
    {%- endif -%}

    <div
      class="ingredient-showcase__carousel"
      role="region"
      aria-label="{{ section.settings.heading | default: 'İçerik vitrini' }}"
      aria-roledescription="carousel"
    >
      <div class="ingredient-showcase__track" data-track>
        {%- for block in section.blocks -%}
          <div
            class="ingredient-showcase__slide"
            role="group"
            aria-roledescription="slide"
            aria-label="{{ forloop.index }} / {{ total_slides }}"
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.name != blank -%}
              <span class="ingredient-showcase__name-chip">{{ block.settings.name }}</span>
            {%- endif -%}

            {%- if block.settings.image != blank -%}
              <div class="ingredient-showcase__image-wrap">
                {{
                  block.settings.image
                  | image_url: width: 600
                  | image_tag:
                    loading: 'lazy',
                    widths: '200, 300, 400, 600',
                    sizes: '(min-width: 768px) 300px, 55vw',
                    class: 'ingredient-showcase__image'
                }}
              </div>
            {%- else -%}
              <div class="ingredient-showcase__image-wrap">
                {{ 'product-1' | placeholder_svg_tag: 'ingredient-showcase__image ingredient-showcase__image--placeholder' }}
              </div>
            {%- endif -%}

            <div class="ingredient-showcase__content">
              {%- if block.settings.benefit_1 != blank
                or block.settings.benefit_2 != blank
                or block.settings.benefit_3 != blank
              -%}
                <div class="ingredient-showcase__benefits">
                  {%- if block.settings.benefit_1 != blank -%}
                    <span class="ingredient-showcase__tag">{{ block.settings.benefit_1 }}</span>
                  {%- endif -%}
                  {%- if block.settings.benefit_2 != blank -%}
                    <span class="ingredient-showcase__tag">{{ block.settings.benefit_2 }}</span>
                  {%- endif -%}
                  {%- if block.settings.benefit_3 != blank -%}
                    <span class="ingredient-showcase__tag">{{ block.settings.benefit_3 }}</span>
                  {%- endif -%}
                </div>
              {%- endif -%}

              {%- if block.settings.description != blank -%}
                <p class="ingredient-showcase__description">{{ block.settings.description }}</p>
              {%- endif -%}

              {%- if block.settings.hero_label != blank -%}
                {%- assign coa_hero_val = block.settings.hero_value | default: 99 -%}
                {%- assign coa_offset = 226 | minus: coa_hero_val | times: 226 | divided_by: 100 -%}
                {%- comment -%}offset = 226 - (226 * value / 100){%- endcomment -%}
                {%- assign coa_offset_correct = 226 | times: coa_hero_val | divided_by: 100 -%}
                {%- assign coa_offset_final = 226 | minus: coa_offset_correct -%}

                <button class="coa-panel__trigger" data-coa-toggle>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M9 12h6M9 16h6M13 3H7a2 2 0 00-2 2v14a2 2 0 002 2h10a2 2 0 002-2V9l-6-6z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M13 3v6h6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  Analiz Sertifikasını İncele
                  <span class="coa-panel__chevron">&#9662;</span>
                </button>

                <div class="coa-panel__body">
                  <div class="coa-panel__grid">
                    <!-- Column 1: Hero Metric -->
                    <div class="coa-panel__hero">
                      <svg class="coa-panel__ring" width="80" height="80" viewBox="0 0 80 80">
                        <circle cx="40" cy="40" r="36" fill="none" stroke="rgba(0,0,0,0.08)" stroke-width="4"/>
                        <circle class="coa-panel__ring-fg" cx="40" cy="40" r="36" fill="none" stroke="#108474" stroke-width="4" stroke-linecap="round" stroke-dasharray="226" stroke-dashoffset="226" data-target-offset="{{ coa_offset_final }}" transform="rotate(-90 40 40)"/>
                        <text x="40" y="38" text-anchor="middle" dominant-baseline="central" fill="#171717" font-size="24" font-weight="700">{{ coa_hero_val }}</text>
                        <text x="40" y="54" text-anchor="middle" dominant-baseline="central" fill="#171717" font-size="12" font-weight="400">{{ block.settings.hero_unit }}</text>
                      </svg>
                      <span class="coa-panel__hero-label">{{ block.settings.hero_label }}</span>
                      {%- if block.settings.hero_standard != blank -%}
                        <span class="coa-panel__hero-standard">{{ block.settings.hero_standard }}</span>
                      {%- endif -%}
                    </div>

                    <!-- Column 2: Safety Checks -->
                    <div class="coa-panel__safety">
                      {%- if block.settings.safety_1_label != blank -%}
                        <div class="coa-panel__safety-row coa-panel__safety-row--1">
                          <span class="coa-panel__safety-icon coa-panel__safety-icon--shield">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="#108474" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                          </span>
                          <span class="coa-panel__safety-text">
                            <span class="coa-panel__safety-label">{{ block.settings.safety_1_label }}</span>
                            <span class="coa-panel__safety-value">{{ block.settings.safety_1_value }}</span>
                          </span>
                        </div>
                      {%- endif -%}
                      {%- if block.settings.safety_2_label != blank -%}
                        <div class="coa-panel__safety-row coa-panel__safety-row--2">
                          <span class="coa-panel__safety-icon coa-panel__safety-icon--micro">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="8" r="3" stroke="#3a7d5c" stroke-width="1.5"/><path d="M12 11v4M8 21h8M12 15v6M6 18h12" stroke="#3a7d5c" stroke-width="1.5" stroke-linecap="round"/></svg>
                          </span>
                          <span class="coa-panel__safety-text">
                            <span class="coa-panel__safety-label">{{ block.settings.safety_2_label }}</span>
                            <span class="coa-panel__safety-value">{{ block.settings.safety_2_value }}</span>
                          </span>
                        </div>
                      {%- endif -%}
                      {%- if block.settings.safety_3_label != blank -%}
                        <div class="coa-panel__safety-row coa-panel__safety-row--3">
                          <span class="coa-panel__safety-icon coa-panel__safety-icon--cert">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><rect x="4" y="2" width="16" height="20" rx="2" stroke="#b8976a" stroke-width="1.5"/><path d="M8 7h8M8 11h8M8 15h4" stroke="#b8976a" stroke-width="1.5" stroke-linecap="round"/></svg>
                          </span>
                          <span class="coa-panel__safety-text">
                            <span class="coa-panel__safety-label">{{ block.settings.safety_3_label }}</span>
                            <span class="coa-panel__safety-value">{{ block.settings.safety_3_value }}</span>
                          </span>
                        </div>
                      {%- endif -%}
                    </div>

                    <!-- Column 3: Provenance & Source -->
                    <div class="coa-panel__provenance">
                      {%- if block.settings.supplier_name != blank -%}
                        <span class="coa-panel__supplier-pill coa-panel__prov-item--1">
                          {{ block.settings.supplier_name }}{%- if block.settings.supplier_country != blank %} &middot; {{ block.settings.supplier_country }}{%- endif -%}
                        </span>
                      {%- endif -%}

                      {%- if block.settings.cert_1 != blank or block.settings.cert_2 != blank -%}
                        <div class="coa-panel__certs coa-panel__prov-item--2">
                          {%- if block.settings.cert_1 != blank -%}
                            <span class="coa-panel__cert-pill">{{ block.settings.cert_1 }}</span>
                          {%- endif -%}
                          {%- if block.settings.cert_2 != blank -%}
                            <span class="coa-panel__cert-pill">{{ block.settings.cert_2 }}</span>
                          {%- endif -%}
                        </div>
                      {%- endif -%}

                      {%- if block.settings.cite_label != blank and block.settings.cite_pmid != blank -%}
                        {%- assign cite_parts = block.settings.cite_label | split: ' — ' -%}
                        <a class="coa-panel__cite-chip coa-panel__prov-item--3" href="https://pubmed.ncbi.nlm.nih.gov/{{ block.settings.cite_pmid }}/" target="_blank" rel="noopener noreferrer">
                          {{ cite_parts[0] }}
                        </a>
                      {%- endif -%}
                    </div>
                  </div>

                  <div class="coa-panel__footer">
                    Daha fazla detay için <a href="mailto:info@cyrasoul.com">info@cyrasoul.com</a>
                  </div>
                </div>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>

    {%- if total_slides > 1 -%}
      <div class="ingredient-showcase__nav">
        <button
          class="ingredient-showcase__arrow ingredient-showcase__arrow--prev"
          aria-label="Önceki içerik"
          data-prev
          disabled
        >
          <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M13 4L7 10L13 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>

        <div class="ingredient-showcase__dots" role="tablist" aria-label="Slayt seçici">
          {%- for block in section.blocks -%}
            <button
              class="ingredient-showcase__dot{% if forloop.first %} ingredient-showcase__dot--active{% endif %}"
              role="tab"
              aria-label="İçerik {{ forloop.index }}"
              aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
              data-dot="{{ forloop.index0 }}"
            ></button>
          {%- endfor -%}
        </div>

        <button
          class="ingredient-showcase__arrow ingredient-showcase__arrow--next"
          aria-label="Sonraki içerik"
          data-next
        >
          <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M7 4L13 10L7 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    {%- endif -%}
  </section>
{%- endif -%}

{% stylesheet %}
  .ingredient-showcase {
    background-color: var(--bg-color, #ffffff);
    color: var(--text-color, #171717);
    padding-top: var(--padding-top, 40px);
    padding-bottom: var(--padding-bottom, 40px);
    font-family: var(--body-font, inherit);
  }

  /* Header */
  .ingredient-showcase__header {
    text-align: center;
    padding: 0 20px;
    margin-bottom: 20px;
  }

  .ingredient-showcase__heading {
    font-family: var(--heading-font, inherit);
    font-size: 1.375rem;
    font-weight: 600;
    line-height: 1.25;
    margin: 0 0 6px;
    color: var(--text-color, #171717);
  }

  .ingredient-showcase__subheading {
    font-size: 0.8125rem;
    line-height: 1.5;
    color: var(--text-color, #171717);
    opacity: 0.7;
    margin: 0;
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
  }

  /* Tabs — hidden on mobile */
  .ingredient-showcase__tabs {
    display: none;
  }

  /* Carousel */
  .ingredient-showcase__carousel {
    overflow: hidden;
    position: relative;
  }

  .ingredient-showcase__track {
    display: flex;
    transition: transform 300ms ease;
    will-change: transform;
  }

  .ingredient-showcase__slide {
    flex: 0 0 100%;
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 0 20px;
    box-sizing: border-box;
  }

  /* Content wrapper (benefits + description) — used for desktop grid */
  .ingredient-showcase__content {
    display: contents;
  }

  /* Name chip — mobile only */
  .ingredient-showcase__name-chip {
    display: inline-block;
    background-color: var(--accent-color, #FFD7BF);
    color: var(--text-color, #171717);
    border-radius: 9999px;
    padding: 8px 22px;
    font-size: 0.8125rem;
    font-weight: 600;
    line-height: 1.3;
    margin-bottom: 12px;
  }

  /* Image */
  .ingredient-showcase__image-wrap {
    width: 55%;
    max-width: 220px;
    margin-bottom: 14px;
  }

  .ingredient-showcase__image {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: 12px;
  }

  .ingredient-showcase__image--placeholder {
    aspect-ratio: 1 / 1;
    border-radius: 12px;
    background-color: #f5f5f5;
  }

  /* Benefits */
  .ingredient-showcase__benefits {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 6px;
    margin-bottom: 10px;
    padding: 0 4px;
  }

  .ingredient-showcase__tag {
    display: inline-block;
    border: 1.5px solid var(--tag-border-color, #171717);
    border-radius: 8px;
    padding: 5px 14px;
    font-size: 0.75rem;
    line-height: 1.3;
    white-space: nowrap;
  }

  /* Description */
  .ingredient-showcase__description {
    font-size: 0.8125rem;
    line-height: 1.55;
    color: var(--text-color, #171717);
    opacity: 0.75;
    margin: 0;
    max-width: 300px;
  }

  /* ── CoA Smart Panel ── */

  /* Trigger button */
  .coa-panel__trigger {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 12px;
    padding: 7px 16px;
    border: 1px solid rgba(0,0,0,0.12);
    border-radius: 9999px;
    background: transparent;
    color: var(--text-color, #171717);
    font-size: 12px;
    font-weight: 500;
    font-family: inherit;
    cursor: pointer;
    transition: background-color 200ms ease, border-color 200ms ease;
    line-height: 1.3;
  }

  .coa-panel__trigger:hover {
    background-color: rgba(0,0,0,0.03);
    border-color: rgba(0,0,0,0.2);
  }

  .coa-panel__trigger svg {
    flex-shrink: 0;
  }

  .coa-panel__chevron {
    font-size: 10px;
    transition: transform 300ms ease;
    display: inline-block;
  }

  .coa-panel__trigger.is-open .coa-panel__chevron {
    transform: rotate(180deg);
  }

  /* Panel body */
  .coa-panel__body {
    max-height: 0;
    overflow: hidden;
    transition: max-height 500ms cubic-bezier(0.22,1,0.36,1);
    width: 100%;
  }

  .coa-panel__body.is-open {
    max-height: 600px;
  }

  .coa-panel__body.is-open .coa-panel__grid {
    background: rgba(0,0,0,0.015);
    border-top: 1px solid rgba(0,0,0,0.06);
    padding: 20px;
    border-radius: 0 0 10px 10px;
  }

  .coa-panel__grid {
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    text-align: left;
    background: rgba(0,0,0,0.015);
    border-top: 1px solid rgba(0,0,0,0.06);
    border-radius: 0 0 10px 10px;
  }

  /* Column 1: Hero Metric */
  .coa-panel__hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }

  .coa-panel__ring {
    display: block;
  }

  .coa-panel__ring-fg {
    stroke-dashoffset: 226;
    transition: none;
  }

  .coa-panel__body.is-open .coa-panel__ring-fg {
    transition: stroke-dashoffset 1000ms ease-out;
  }

  .coa-panel__hero-label {
    font-size: 12px;
    opacity: 0.55;
    text-align: center;
    line-height: 1.3;
  }

  .coa-panel__hero-standard {
    display: inline-block;
    font-size: 10px;
    border: 1px solid rgba(0,0,0,0.12);
    border-radius: 9999px;
    padding: 2px 8px;
    opacity: 0.5;
    line-height: 1.3;
  }

  /* Column 2: Safety Checks */
  .coa-panel__safety {
    display: flex;
    flex-direction: column;
  }

  .coa-panel__safety-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 0;
    border-bottom: 1px solid rgba(0,0,0,0.05);
    opacity: 0;
    transform: translateY(8px);
  }

  .coa-panel__safety-row:last-child {
    border-bottom: none;
  }

  .coa-panel__body.is-open .coa-panel__safety-row--1 {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 400ms ease 200ms, transform 400ms ease 200ms;
  }

  .coa-panel__body.is-open .coa-panel__safety-row--2 {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 400ms ease 350ms, transform 400ms ease 350ms;
  }

  .coa-panel__body.is-open .coa-panel__safety-row--3 {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 400ms ease 500ms, transform 400ms ease 500ms;
  }

  .coa-panel__safety-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .coa-panel__safety-icon--shield {
    background-color: rgba(16,132,116,0.08);
  }

  .coa-panel__safety-icon--micro {
    background-color: rgba(58,125,92,0.08);
  }

  .coa-panel__safety-icon--cert {
    background-color: rgba(184,151,106,0.08);
  }

  .coa-panel__safety-text {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .coa-panel__safety-label {
    font-size: 12.5px;
    font-weight: 600;
    opacity: 0.75;
    line-height: 1.3;
  }

  .coa-panel__safety-value {
    font-size: 11.5px;
    font-weight: 400;
    opacity: 0.5;
    line-height: 1.3;
  }

  /* Column 3: Provenance & Source */
  .coa-panel__provenance {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 8px;
  }

  .coa-panel__supplier-pill {
    display: inline-block;
    font-size: 11.5px;
    font-weight: 500;
    border: 1px solid rgba(0,0,0,0.1);
    border-radius: 9999px;
    padding: 4px 12px;
    line-height: 1.3;
    opacity: 0;
    transform: translateY(6px);
  }

  .coa-panel__body.is-open .coa-panel__prov-item--1 {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 400ms ease 300ms, transform 400ms ease 300ms;
  }

  .coa-panel__certs {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    opacity: 0;
    transform: translateY(6px);
  }

  .coa-panel__body.is-open .coa-panel__prov-item--2 {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 400ms ease 450ms, transform 400ms ease 450ms;
  }

  .coa-panel__cert-pill {
    display: inline-block;
    font-size: 10px;
    font-weight: 500;
    background: rgba(16,132,116,0.06);
    color: #108474;
    border-radius: 9999px;
    padding: 2px 8px;
    line-height: 1.3;
  }

  .coa-panel__cite-chip {
    display: inline-block;
    font-size: 10px;
    font-weight: 500;
    padding: 2px 7px;
    border-radius: 9999px;
    border: 1px solid rgba(0,0,0,0.1);
    color: #7B7B7B;
    opacity: 0;
    transform: translateY(6px);
    text-decoration: none;
    line-height: 1.3;
    transition: background-color 200ms ease, color 200ms ease, border-color 200ms ease, opacity 400ms ease 600ms, transform 400ms ease 600ms;
  }

  .coa-panel__body.is-open .coa-panel__prov-item--3 {
    opacity: 0.6;
    transform: translateY(0);
    transition: background-color 200ms ease, color 200ms ease, border-color 200ms ease, opacity 400ms ease 600ms, transform 400ms ease 600ms;
  }

  .coa-panel__cite-chip:hover {
    background-color: #108474;
    color: #ffffff;
    border-color: #108474;
    opacity: 1;
  }

  /* Footer */
  .coa-panel__footer {
    font-size: 11px;
    opacity: 0.3;
    border-top: 1px solid rgba(0,0,0,0.05);
    padding-top: 12px;
    margin-top: 16px;
    text-align: center;
  }

  .coa-panel__footer a {
    color: inherit;
    text-decoration: underline;
  }

  /* ── CoA Desktop ── */
  @media screen and (min-width: 768px) {
    .coa-panel__grid {
      grid-template-columns: 1fr 1fr 1fr;
      gap: 24px;
    }
  }

  /* Navigation */
  .ingredient-showcase__nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    margin-top: 18px;
    padding: 0 20px;
  }

  .ingredient-showcase__arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: 1.5px solid var(--text-color, #171717);
    background: transparent;
    color: var(--text-color, #171717);
    cursor: pointer;
    transition: opacity 200ms ease;
    flex-shrink: 0;
    padding: 0;
  }

  .ingredient-showcase__arrow:disabled {
    opacity: 0.25;
    cursor: default;
  }

  .ingredient-showcase__arrow:not(:disabled):hover {
    opacity: 0.6;
  }

  .ingredient-showcase__dots {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .ingredient-showcase__dot {
    width: 7px;
    height: 7px;
    border-radius: 2px;
    border: none;
    padding: 0;
    background-color: var(--text-color, #171717);
    opacity: 0.2;
    cursor: pointer;
    transition: opacity 200ms ease;
  }

  .ingredient-showcase__dot--active {
    opacity: 1;
  }

  /* ── Desktop ── */
  @media screen and (min-width: 768px) {
    .ingredient-showcase__header {
      margin-bottom: 28px;
    }

    .ingredient-showcase__heading {
      font-size: 2.25rem;
      font-weight: 400;
      letter-spacing: -0.01em;
    }

    .ingredient-showcase__subheading {
      font-size: 1rem;
    }

    /* Tab bar — visible on desktop */
    .ingredient-showcase__tabs {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 10px;
      padding: 0 40px;
      margin-bottom: 40px;
    }

    .ingredient-showcase__tab {
      padding: 12px 24px;
      border-radius: 9999px;
      border: 1px solid #d4d4d4;
      background: transparent;
      color: var(--text-color, #171717);
      font-size: 0.875rem;
      font-family: inherit;
      cursor: pointer;
      white-space: nowrap;
      transition: background-color 200ms ease, border-color 200ms ease;
    }

    .ingredient-showcase__tab:hover {
      border-color: #999;
    }

    .ingredient-showcase__tab--active {
      background-color: var(--accent-color, #FFD7BF);
      border-color: var(--accent-color, #FFD7BF);
    }

    /* Hide name chip on desktop — shown via tabs */
    .ingredient-showcase__name-chip {
      display: none;
    }

    /* Two-column slide — slide stays full-width, grid content is centered */
    .ingredient-showcase__slide {
      display: grid;
      grid-template-columns: 300px minmax(0, 400px);
      justify-content: center;
      column-gap: 48px;
      text-align: left;
      align-items: center;
      padding: 0 40px;
    }

    .ingredient-showcase__image-wrap {
      width: 100%;
      max-width: none;
      margin-bottom: 0;
    }

    .ingredient-showcase__content {
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .ingredient-showcase__benefits {
      justify-content: flex-start;
      margin-bottom: 16px;
      padding: 0;
      gap: 8px;
    }

    .ingredient-showcase__tag {
      padding: 8px 20px;
      font-size: 0.875rem;
    }

    .ingredient-showcase__description {
      max-width: none;
      font-size: 0.9375rem;
      line-height: 1.6;
    }

    /* Hide mobile nav on desktop */
    .ingredient-showcase__nav {
      display: none;
    }
  }

  /* ── Large desktop ── */
  @media screen and (min-width: 1024px) {
    .ingredient-showcase__slide {
      grid-template-columns: 340px minmax(0, 440px);
      column-gap: 56px;
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .ingredient-showcase__track {
      transition: none;
    }

    .ingredient-showcase__arrow,
    .ingredient-showcase__dot,
    .ingredient-showcase__tab {
      transition: none;
    }

    .coa-panel__body {
      transition: none;
    }

    .coa-panel__ring-fg {
      transition: none !important;
    }

    .coa-panel__safety-row,
    .coa-panel__body.is-open .coa-panel__safety-row--1,
    .coa-panel__body.is-open .coa-panel__safety-row--2,
    .coa-panel__body.is-open .coa-panel__safety-row--3 {
      transition: none;
      opacity: 1;
      transform: none;
    }

    .coa-panel__supplier-pill,
    .coa-panel__certs,
    .coa-panel__cite-chip,
    .coa-panel__body.is-open .coa-panel__prov-item--1,
    .coa-panel__body.is-open .coa-panel__prov-item--2,
    .coa-panel__body.is-open .coa-panel__prov-item--3 {
      transition: none;
      opacity: 1;
      transform: none;
    }

    .coa-panel__chevron {
      transition: none;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    function IngredientShowcase(section) {
      this.section = section;
      this.track = section.querySelector('[data-track]');
      this.carousel = section.querySelector('.ingredient-showcase__carousel');
      this.slides = section.querySelectorAll('.ingredient-showcase__slide');
      this.prevBtn = section.querySelector('[data-prev]');
      this.nextBtn = section.querySelector('[data-next]');
      this.dots = section.querySelectorAll('[data-dot]');
      this.tabs = section.querySelectorAll('[data-tab]');
      this.currentIndex = 0;
      this.totalSlides = this.slides.length;

      this.touchStartX = 0;
      this.touchStartY = 0;
      this.touchStartTime = 0;
      this.isDragging = false;
      this.directionLocked = false;
      this.isHorizontal = false;

      if (this.totalSlides < 2) return;

      this.bindEvents();
      this.updateState();
    }

    IngredientShowcase.prototype.bindEvents = function () {
      var self = this;

      if (this.prevBtn) {
        this.prevBtn.addEventListener('click', function () {
          self.goTo(self.currentIndex - 1);
        });
      }

      if (this.nextBtn) {
        this.nextBtn.addEventListener('click', function () {
          self.goTo(self.currentIndex + 1);
        });
      }

      this.dots.forEach(function (dot) {
        dot.addEventListener('click', function () {
          var index = parseInt(this.getAttribute('data-dot'), 10);
          self.goTo(index);
        });
      });

      this.tabs.forEach(function (tab) {
        tab.addEventListener('click', function () {
          var index = parseInt(this.getAttribute('data-tab'), 10);
          self.goTo(index);
        });
      });

      this.track.addEventListener('touchstart', function (e) {
        self.onTouchStart(e);
      }, { passive: true });

      this.track.addEventListener('touchmove', function (e) {
        self.onTouchMove(e);
      }, { passive: false });

      this.track.addEventListener('touchend', function (e) {
        self.onTouchEnd(e);
      }, { passive: true });

      this.track.addEventListener('touchcancel', function () {
        self.onTouchCancel();
      }, { passive: true });

      this.section.addEventListener('keydown', function (e) {
        self.onKeyDown(e);
      });

      /* CoA Smart Panel toggle */
      this.section.addEventListener('click', function(e) {
        var trigger = e.target.closest('[data-coa-toggle]');
        if (trigger) {
          e.preventDefault();
          trigger.classList.toggle('is-open');
          var body = trigger.nextElementSibling;
          if (body) {
            body.classList.toggle('is-open');
            /* Animate ring stroke-dashoffset when opening */
            if (body.classList.contains('is-open')) {
              var rings = body.querySelectorAll('.coa-panel__ring-fg');
              rings.forEach(function(ring) {
                var targetOffset = ring.getAttribute('data-target-offset');
                if (targetOffset !== null) {
                  ring.style.strokeDashoffset = targetOffset;
                }
              });
            } else {
              var rings = body.querySelectorAll('.coa-panel__ring-fg');
              rings.forEach(function(ring) {
                ring.style.strokeDashoffset = '226';
              });
            }
          }
        }
      });
    };

    IngredientShowcase.prototype.getSlideWidth = function () {
      return this.carousel.offsetWidth;
    };

    IngredientShowcase.prototype.goTo = function (index) {
      if (index < 0 || index >= this.totalSlides) return;
      this.currentIndex = index;
      this.updateState();
    };

    IngredientShowcase.prototype.updateState = function () {
      var offset = -(this.currentIndex * 100);
      this.track.style.transform = 'translateX(' + offset + '%)';

      if (this.prevBtn) {
        this.prevBtn.disabled = this.currentIndex === 0;
      }

      if (this.nextBtn) {
        this.nextBtn.disabled = this.currentIndex === this.totalSlides - 1;
      }

      var self = this;
      this.dots.forEach(function (dot) {
        var dotIndex = parseInt(dot.getAttribute('data-dot'), 10);
        var isActive = dotIndex === self.currentIndex;
        dot.classList.toggle('ingredient-showcase__dot--active', isActive);
        dot.setAttribute('aria-selected', isActive ? 'true' : 'false');
      });

      this.tabs.forEach(function (tab) {
        var tabIndex = parseInt(tab.getAttribute('data-tab'), 10);
        tab.classList.toggle('ingredient-showcase__tab--active', tabIndex === self.currentIndex);
      });
    };

    IngredientShowcase.prototype.onTouchStart = function (e) {
      this.touchStartX = e.touches[0].clientX;
      this.touchStartY = e.touches[0].clientY;
      this.touchStartTime = Date.now();
      this.isDragging = true;
      this.directionLocked = false;
      this.isHorizontal = false;
      this.track.style.transition = 'none';
    };

    IngredientShowcase.prototype.onTouchMove = function (e) {
      if (!this.isDragging) return;

      var currentX = e.touches[0].clientX;
      var currentY = e.touches[0].clientY;
      var deltaX = currentX - this.touchStartX;
      var deltaY = currentY - this.touchStartY;

      if (!this.directionLocked) {
        if (Math.abs(deltaX) < 5 && Math.abs(deltaY) < 5) return;
        this.directionLocked = true;
        this.isHorizontal = Math.abs(deltaX) > Math.abs(deltaY);
      }

      if (!this.isHorizontal) {
        this.isDragging = false;
        this.track.style.transition = '';
        return;
      }

      e.preventDefault();

      var slideWidth = this.getSlideWidth();
      var movePercent = (deltaX / slideWidth) * 100;

      var atStart = this.currentIndex === 0 && deltaX > 0;
      var atEnd = this.currentIndex === this.totalSlides - 1 && deltaX < 0;
      if (atStart || atEnd) {
        movePercent *= 0.25;
      }

      var baseOffset = -(this.currentIndex * 100);
      this.track.style.transform = 'translateX(' + (baseOffset + movePercent) + '%)';
    };

    IngredientShowcase.prototype.onTouchEnd = function (e) {
      if (!this.isDragging) return;
      this.isDragging = false;
      this.track.style.transition = '';

      if (!this.directionLocked || !this.isHorizontal) {
        this.updateState();
        return;
      }

      var deltaX = e.changedTouches[0].clientX - this.touchStartX;
      var elapsed = Date.now() - this.touchStartTime;
      var velocity = Math.abs(deltaX) / elapsed;
      var slideWidth = this.getSlideWidth();

      var swipedEnough = Math.abs(deltaX) > slideWidth * 0.2;
      var flickedFast = velocity > 0.5 && Math.abs(deltaX) > 30;

      if (swipedEnough || flickedFast) {
        if (deltaX < 0) {
          this.goTo(this.currentIndex + 1);
        } else {
          this.goTo(this.currentIndex - 1);
        }
      } else {
        this.updateState();
      }
    };

    IngredientShowcase.prototype.onTouchCancel = function () {
      this.isDragging = false;
      this.track.style.transition = '';
      this.updateState();
    };

    IngredientShowcase.prototype.onKeyDown = function (e) {
      if (e.key === 'ArrowLeft') {
        e.preventDefault();
        this.goTo(this.currentIndex - 1);
      } else if (e.key === 'ArrowRight') {
        e.preventDefault();
        this.goTo(this.currentIndex + 1);
      }
    };

    function init() {
      document.querySelectorAll('.ingredient-showcase[data-section-id]').forEach(function (el) {
        if (!el.dataset.initialized) {
          new IngredientShowcase(el);
          el.dataset.initialized = 'true';
        }
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }

    document.addEventListener('shopify:section:load', function (e) {
      var section = e.target.querySelector('.ingredient-showcase[data-section-id]');
      if (section) {
        section.removeAttribute('data-initialized');
        new IngredientShowcase(section);
        section.dataset.initialized = 'true';
      }
    });
  })();
{% endjavascript %}

