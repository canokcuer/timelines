{%- if section.blocks.size > 0 -%}
  {%- assign total_slides = section.blocks.size -%}
  <section
    class="ingredient-showcase"
    data-section-id="{{ section.id }}"
    style="
      --bg-color: {{ section.settings.bg_color }};
      --text-color: {{ section.settings.text_color }};
      --accent-color: {{ section.settings.accent_color }};
      --tag-border-color: {{ section.settings.tag_border_color }};
      --heading-font: inherit;
      --body-font: inherit;
      --padding-top: {{ section.settings.padding_top }}px;
      --padding-bottom: {{ section.settings.padding_bottom }}px;
    "
  >
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="ingredient-showcase__header">
        {%- if section.settings.heading != blank -%}
          <h2 class="ingredient-showcase__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="ingredient-showcase__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if total_slides > 1 -%}
      <div class="ingredient-showcase__tabs">
        {%- for block in section.blocks -%}
          <button
            class="ingredient-showcase__tab{% if forloop.first %} ingredient-showcase__tab--active{% endif %}"
            data-tab="{{ forloop.index0 }}"
          >
            {{ block.settings.name }}
          </button>
        {%- endfor -%}
      </div>
    {%- endif -%}

    <div
      class="ingredient-showcase__carousel"
      role="region"
      aria-label="{{ section.settings.heading | default: 'İçerik vitrini' }}"
      aria-roledescription="carousel"
    >
      <div class="ingredient-showcase__track" data-track>
        {%- for block in section.blocks -%}
          <div
            class="ingredient-showcase__slide"
            role="group"
            aria-roledescription="slide"
            aria-label="{{ forloop.index }} / {{ total_slides }}"
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.name != blank -%}
              <span class="ingredient-showcase__name-chip">{{ block.settings.name }}</span>
            {%- endif -%}

            {%- if block.settings.image != blank -%}
              <div class="ingredient-showcase__image-wrap">
                {{
                  block.settings.image
                  | image_url: width: 600
                  | image_tag:
                    loading: 'lazy',
                    widths: '200, 300, 400, 600',
                    sizes: '(min-width: 768px) 300px, 55vw',
                    class: 'ingredient-showcase__image'
                }}
              </div>
            {%- else -%}
              <div class="ingredient-showcase__image-wrap">
                {{ 'product-1' | placeholder_svg_tag: 'ingredient-showcase__image ingredient-showcase__image--placeholder' }}
              </div>
            {%- endif -%}

            <div class="ingredient-showcase__content">
              {%- if block.settings.benefit_1 != blank
                or block.settings.benefit_2 != blank
                or block.settings.benefit_3 != blank
              -%}
                <div class="ingredient-showcase__benefits">
                  {%- if block.settings.benefit_1 != blank -%}
                    <span class="ingredient-showcase__tag">{{ block.settings.benefit_1 }}</span>
                  {%- endif -%}
                  {%- if block.settings.benefit_2 != blank -%}
                    <span class="ingredient-showcase__tag">{{ block.settings.benefit_2 }}</span>
                  {%- endif -%}
                  {%- if block.settings.benefit_3 != blank -%}
                    <span class="ingredient-showcase__tag">{{ block.settings.benefit_3 }}</span>
                  {%- endif -%}
                </div>
              {%- endif -%}

              {%- if block.settings.description != blank -%}
                <p class="ingredient-showcase__description">{{ block.settings.description }}</p>
              {%- endif -%}

              {%- if block.settings.cite_pmid != blank -%}
                {%- assign cite_chip_label = block.settings.cite_label | split: ' — ' | first -%}
                {%- if cite_chip_label == blank -%}{%- assign cite_chip_label = 'PubMed' -%}{%- endif -%}
                <a href="https://pubmed.ncbi.nlm.nih.gov/{{ block.settings.cite_pmid }}/" target="_blank" rel="noopener" class="ingredient-showcase__cite">{{ cite_chip_label }}</a>
              {%- endif -%}

              {%- if block.settings.coa_1 != blank -%}
                {%- assign coa_style = block.settings.coa_style | default: 'list' -%}
                <div class="ingredient-showcase__coa">
                  <button class="ingredient-showcase__coa-trigger" data-coa-toggle>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 12h6M9 16h6M13 3H7a2 2 0 00-2 2v14a2 2 0 002 2h10a2 2 0 002-2V9l-6-6z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M13 3v6h6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    Analiz Sertifikasını İncele
                    <span class="coa-chevron">▾</span>
                  </button>
                  <div class="ingredient-showcase__coa-body">
                    {%- case coa_style -%}
                      {%- when 'bars' -%}
                        {%- comment -%} Style A — Progress Bars {%- endcomment -%}
                        <div class="coa-a">
                          {%- if block.settings.coa_1 != blank -%}
                            <div class="coa-a__row">
                              <div class="coa-a__header">
                                <span class="coa-a__label">{{ block.settings.coa_1 }}</span>
                                <span class="coa-a__value">{{ block.settings.coa_val_1 }}%</span>
                              </div>
                              <div class="coa-a__track">
                                <div class="coa-a__fill" style="--bar-w:{{ block.settings.coa_val_1 }}%"></div>
                              </div>
                            </div>
                          {%- endif -%}
                          {%- if block.settings.coa_2 != blank -%}
                            <div class="coa-a__row">
                              <div class="coa-a__header">
                                <span class="coa-a__label">{{ block.settings.coa_2 }}</span>
                                <span class="coa-a__value">{{ block.settings.coa_val_2 }}%</span>
                              </div>
                              <div class="coa-a__track">
                                <div class="coa-a__fill" style="--bar-w:{{ block.settings.coa_val_2 }}%"></div>
                              </div>
                            </div>
                          {%- endif -%}
                          {%- if block.settings.coa_3 != blank -%}
                            <div class="coa-a__row">
                              <div class="coa-a__header">
                                <span class="coa-a__label">{{ block.settings.coa_3 }}</span>
                                <span class="coa-a__value">{{ block.settings.coa_val_3 }}%</span>
                              </div>
                              <div class="coa-a__track">
                                <div class="coa-a__fill" style="--bar-w:{{ block.settings.coa_val_3 }}%"></div>
                              </div>
                            </div>
                          {%- endif -%}
                          {%- if block.settings.coa_4 != blank -%}
                            <div class="coa-a__row">
                              <div class="coa-a__header">
                                <span class="coa-a__label">{{ block.settings.coa_4 }}</span>
                                <span class="coa-a__value">{{ block.settings.coa_val_4 }}%</span>
                              </div>
                              <div class="coa-a__track">
                                <div class="coa-a__fill" style="--bar-w:{{ block.settings.coa_val_4 }}%"></div>
                              </div>
                            </div>
                          {%- endif -%}
                        </div>
                      {%- when 'cards' -%}
                        {%- comment -%} Style B — Card Grid {%- endcomment -%}
                        <div class="coa-b">
                          {%- if block.settings.coa_1 != blank -%}
                            <div class="coa-b__card" style="--coa-b-i:0">{{ block.settings.coa_1 }}</div>
                          {%- endif -%}
                          {%- if block.settings.coa_2 != blank -%}
                            <div class="coa-b__card" style="--coa-b-i:1">{{ block.settings.coa_2 }}</div>
                          {%- endif -%}
                          {%- if block.settings.coa_3 != blank -%}
                            <div class="coa-b__card" style="--coa-b-i:2">{{ block.settings.coa_3 }}</div>
                          {%- endif -%}
                          {%- if block.settings.coa_4 != blank -%}
                            <div class="coa-b__card" style="--coa-b-i:3">{{ block.settings.coa_4 }}</div>
                          {%- endif -%}
                        </div>
                      {%- when 'badge' -%}
                        {%- comment -%} Style C — Certificate Badge {%- endcomment -%}
                        <div class="coa-c">
                          <div class="coa-c__seal" aria-hidden="true">
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="none">
                              <circle cx="12" cy="10" r="7" stroke="#b8976a" stroke-width="1.3"/>
                              <path d="M9 10l2 2 4-4" stroke="#b8976a" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
                              <path d="M8.5 16l-1 5.5 2.5-1.5L12 21.5l2-1.5 2.5 1.5-1-5.5" stroke="#b8976a" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                          </div>
                          <div class="coa-c__details">
                            {%- if block.settings.coa_1 != blank -%}
                              <p class="coa-c__line coa-c__line--first">{{ block.settings.coa_1 }}</p>
                            {%- endif -%}
                            {%- if block.settings.coa_2 != blank -%}
                              <p class="coa-c__line">{{ block.settings.coa_2 }}</p>
                            {%- endif -%}
                            {%- if block.settings.coa_3 != blank -%}
                              <p class="coa-c__line">{{ block.settings.coa_3 }}</p>
                            {%- endif -%}
                            {%- if block.settings.coa_4 != blank -%}
                              <p class="coa-c__line">{{ block.settings.coa_4 }}</p>
                            {%- endif -%}
                          </div>
                        </div>
                      {%- when 'compare' -%}
                        {%- comment -%} Style D — Comparison Bars {%- endcomment -%}
                        <div class="coa-d">
                          {%- if block.settings.coa_1 != blank -%}
                            <div class="coa-d__metric">
                              <div class="coa-d__title">{{ block.settings.coa_1 }}</div>
                              <div class="coa-d__row">
                                <span class="coa-d__label coa-d__label--sector">Sektör Ort.</span>
                                <div class="coa-d__track">
                                  <div class="coa-d__fill coa-d__fill--sector" style="--bar-w:{{ block.settings.coa_val_1 }}%"></div>
                                </div>
                              </div>
                              <div class="coa-d__row">
                                <span class="coa-d__label coa-d__label--cyra">{{ block.settings.coa_2 }}</span>
                                <div class="coa-d__track">
                                  <div class="coa-d__fill coa-d__fill--cyra" style="--bar-w:{{ block.settings.coa_val_2 }}%"></div>
                                </div>
                              </div>
                            </div>
                          {%- endif -%}
                          {%- if block.settings.coa_3 != blank -%}
                            <div class="coa-d__metric">
                              <div class="coa-d__title">{{ block.settings.coa_3 }}</div>
                              <div class="coa-d__row">
                                <span class="coa-d__label coa-d__label--sector">Sektör Ort.</span>
                                <div class="coa-d__track">
                                  <div class="coa-d__fill coa-d__fill--sector" style="--bar-w:{{ block.settings.coa_val_3 }}%"></div>
                                </div>
                              </div>
                              <div class="coa-d__row">
                                <span class="coa-d__label coa-d__label--cyra">{{ block.settings.coa_4 }}</span>
                                <div class="coa-d__track">
                                  <div class="coa-d__fill coa-d__fill--cyra" style="--bar-w:{{ block.settings.coa_val_4 }}%"></div>
                                </div>
                              </div>
                            </div>
                          {%- endif -%}
                        </div>
                      {%- when 'list' -%}
                        {%- comment -%} Style E — Annotated List {%- endcomment -%}
                        <ul class="coa-e">
                          {%- if block.settings.coa_1 != blank -%}
                            <li class="coa-e__item">{{ block.settings.coa_1 }}</li>
                          {%- endif -%}
                          {%- if block.settings.coa_2 != blank -%}
                            <li class="coa-e__item">{{ block.settings.coa_2 }}</li>
                          {%- endif -%}
                          {%- if block.settings.coa_3 != blank -%}
                            <li class="coa-e__item">{{ block.settings.coa_3 }}</li>
                          {%- endif -%}
                          {%- if block.settings.coa_4 != blank -%}
                            <li class="coa-e__item">{{ block.settings.coa_4 }}</li>
                          {%- endif -%}
                        </ul>
                    {%- endcase -%}
                    <p class="coa-footer">Daha fazla detay için <a href="mailto:info@cyrasoul.com">info@cyrasoul.com</a></p>
                  </div>
                </div>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>

    {%- if total_slides > 1 -%}
      <div class="ingredient-showcase__nav">
        <button
          class="ingredient-showcase__arrow ingredient-showcase__arrow--prev"
          aria-label="Önceki içerik"
          data-prev
          disabled
        >
          <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M13 4L7 10L13 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>

        <div class="ingredient-showcase__dots" role="tablist" aria-label="Slayt seçici">
          {%- for block in section.blocks -%}
            <button
              class="ingredient-showcase__dot{% if forloop.first %} ingredient-showcase__dot--active{% endif %}"
              role="tab"
              aria-label="İçerik {{ forloop.index }}"
              aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
              data-dot="{{ forloop.index0 }}"
            ></button>
          {%- endfor -%}
        </div>

        <button
          class="ingredient-showcase__arrow ingredient-showcase__arrow--next"
          aria-label="Sonraki içerik"
          data-next
        >
          <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M7 4L13 10L7 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    {%- endif -%}
  </section>
{%- endif -%}

{% stylesheet %}
  .ingredient-showcase {
    background-color: var(--bg-color, #ffffff);
    color: var(--text-color, #171717);
    padding-top: var(--padding-top, 40px);
    padding-bottom: var(--padding-bottom, 40px);
    font-family: var(--body-font, inherit);
  }

  /* Header */
  .ingredient-showcase__header {
    text-align: center;
    padding: 0 20px;
    margin-bottom: 20px;
  }

  .ingredient-showcase__heading {
    font-family: var(--heading-font, inherit);
    font-size: 1.375rem;
    font-weight: 600;
    line-height: 1.25;
    margin: 0 0 6px;
    color: var(--text-color, #171717);
  }

  .ingredient-showcase__subheading {
    font-size: 0.8125rem;
    line-height: 1.5;
    color: var(--text-color, #171717);
    opacity: 0.7;
    margin: 0;
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
  }

  /* Tabs — hidden on mobile */
  .ingredient-showcase__tabs {
    display: none;
  }

  /* Carousel */
  .ingredient-showcase__carousel {
    overflow: hidden;
    position: relative;
  }

  .ingredient-showcase__track {
    display: flex;
    transition: transform 300ms ease;
    will-change: transform;
  }

  .ingredient-showcase__slide {
    flex: 0 0 100%;
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 0 20px;
    box-sizing: border-box;
  }

  /* Content wrapper (benefits + description) — used for desktop grid */
  .ingredient-showcase__content {
    display: contents;
  }

  /* Name chip — mobile only */
  .ingredient-showcase__name-chip {
    display: inline-block;
    background-color: var(--accent-color, #FFD7BF);
    color: var(--text-color, #171717);
    border-radius: 9999px;
    padding: 8px 22px;
    font-size: 0.8125rem;
    font-weight: 600;
    line-height: 1.3;
    margin-bottom: 12px;
  }

  /* Image */
  .ingredient-showcase__image-wrap {
    width: 55%;
    max-width: 220px;
    margin-bottom: 14px;
  }

  .ingredient-showcase__image {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: 12px;
  }

  .ingredient-showcase__image--placeholder {
    aspect-ratio: 1 / 1;
    border-radius: 12px;
    background-color: #f5f5f5;
  }

  /* Benefits */
  .ingredient-showcase__benefits {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 6px;
    margin-bottom: 10px;
    padding: 0 4px;
  }

  .ingredient-showcase__tag {
    display: inline-block;
    border: 1.5px solid var(--tag-border-color, #171717);
    border-radius: 8px;
    padding: 5px 14px;
    font-size: 0.75rem;
    line-height: 1.3;
    white-space: nowrap;
  }

  /* Description */
  .ingredient-showcase__description {
    font-size: 0.8125rem;
    line-height: 1.55;
    color: var(--text-color, #171717);
    opacity: 0.75;
    margin: 0;
    max-width: 300px;
  }

  /* Citation chip */
  .ingredient-showcase__cite {
    display: inline-flex;
    align-items: center;
    font-size: 10px;
    font-weight: 500;
    padding: 2px 7px;
    border-radius: 9999px;
    background: transparent;
    color: #7B7B7B;
    opacity: 0.6;
    border: 1px solid rgba(0, 0, 0, 0.1);
    text-decoration: none;
    white-space: nowrap;
    margin-top: 10px;
    transition: all 200ms ease;
  }
  .ingredient-showcase__cite:hover {
    opacity: 1;
    background: #108474;
    color: #ffffff;
    border-color: #108474;
  }

  /* CoA shared wrapper */
  .ingredient-showcase__coa { margin-top: 14px; width: 100%; max-width: 380px; }
  .ingredient-showcase__coa-trigger {
    display: inline-flex; align-items: center; gap: 6px;
    font-family: inherit; font-size: 0.75rem; font-weight: 600;
    color: var(--text-color, #171717); opacity: 0.5;
    cursor: pointer; padding: 6px 0; border: none; background: none;
    transition: opacity 200ms ease; -webkit-tap-highlight-color: transparent;
  }
  .ingredient-showcase__coa-trigger:hover { opacity: 0.85; }
  .ingredient-showcase__coa-trigger svg { opacity: 0.6; }
  .coa-chevron { display: inline-block; transition: transform 300ms ease; font-size: 0.625rem; }
  .ingredient-showcase__coa-trigger.is-open .coa-chevron { transform: rotate(180deg); }
  .ingredient-showcase__coa-body {
    overflow: hidden; max-height: 0;
    transition: max-height 400ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .ingredient-showcase__coa-body.is-open { max-height: 500px; }
  .coa-footer {
    font-size: 0.6875rem; color: var(--text-color, #171717); opacity: 0.35;
    margin-top: 12px; padding-top: 10px; border-top: 1px solid rgba(0,0,0,0.06);
  }
  .coa-footer a { color: inherit; text-decoration: underline; }

  /* Style A — Progress Bars */
  .coa-a {
    padding-top: 12px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .coa-a__row {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .coa-a__header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }
  .coa-a__label {
    font-size: 12px;
    line-height: 1.3;
    color: inherit;
    opacity: 0.7;
  }
  .coa-a__value {
    font-size: 12px;
    line-height: 1.3;
    color: inherit;
    opacity: 0.5;
  }
  .coa-a__track {
    width: 100%;
    height: 6px;
    background: rgba(0, 0, 0, 0.06);
    border-radius: 3px;
    overflow: hidden;
  }
  .coa-a__fill {
    height: 100%;
    width: 0;
    border-radius: 3px;
    background: linear-gradient(90deg, #108474, #0aab8f);
    transition: width 800ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .ingredient-showcase__coa-body.is-open .coa-a__fill {
    width: var(--bar-w, 0%);
  }
  @media (prefers-reduced-motion: reduce) {
    .coa-a__fill { transition: none; }
  }

  /* Style B — Card Grid */
  @keyframes coa-b-fadeIn {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 0.7; transform: translateY(0); }
  }
  .coa-b {
    padding-top: 12px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }
  .coa-b__card {
    padding: 10px 14px;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 10px;
    background: rgba(0, 0, 0, 0.015);
    font-size: 12.5px;
    line-height: 1.45;
    color: inherit;
    opacity: 0;
    transition: transform 200ms ease, box-shadow 200ms ease;
  }
  .ingredient-showcase__coa-body.is-open .coa-b__card {
    animation: coa-b-fadeIn 350ms ease forwards;
    animation-delay: calc(var(--coa-b-i, 0) * 60ms);
  }
  .coa-b__card:hover {
    transform: translateY(-1px);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  }
  @media (prefers-reduced-motion: reduce) {
    .coa-b__card { animation: none !important; }
    .ingredient-showcase__coa-body.is-open .coa-b__card { opacity: 0.7; }
  }

  /* Style C — Certificate Badge */
  @keyframes coa-c-seal {
    from { opacity: 0; transform: scale(0.8) rotate(-10deg); }
    to   { opacity: 1; transform: scale(1) rotate(0deg); }
  }
  .coa-c {
    padding-top: 14px;
    display: flex;
    flex-direction: row;
    gap: 16px;
    align-items: flex-start;
  }
  .coa-c__seal {
    flex-shrink: 0;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: linear-gradient(135deg, #fef3e2, #fce8c8);
    border: 1px solid rgba(184, 151, 106, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
  }
  .ingredient-showcase__coa-body.is-open .coa-c__seal {
    animation: coa-c-seal 400ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  .coa-c__details {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .coa-c__line {
    font-size: 12.5px;
    line-height: 1.55;
    color: inherit;
    opacity: 0.65;
    margin: 0;
    border-left: 2px solid rgba(184, 151, 106, 0.25);
    padding-left: 10px;
  }
  .coa-c__line--first {
    border-left-color: rgba(184, 151, 106, 0.6);
  }
  @media (prefers-reduced-motion: reduce) {
    .coa-c__seal { animation: none !important; }
    .ingredient-showcase__coa-body.is-open .coa-c__seal { opacity: 1; }
  }

  /* Style D — Comparison Bars */
  .coa-d {
    padding-top: 14px;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .coa-d__metric {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .coa-d__title {
    font-size: 12.5px;
    font-weight: 700;
    line-height: 1.3;
    color: inherit;
    opacity: 0.75;
    margin-bottom: 8px;
  }
  .coa-d__row {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .coa-d__label {
    font-size: 11px;
    font-weight: 600;
    min-width: 90px;
    flex-shrink: 0;
    line-height: 1.3;
    white-space: nowrap;
  }
  .coa-d__label--sector {
    color: #999;
  }
  .coa-d__label--cyra {
    color: #108474;
    font-weight: 700;
  }
  .coa-d__track {
    flex: 1;
    height: 10px;
    background: rgba(0, 0, 0, 0.04);
    border-radius: 5px;
    overflow: hidden;
  }
  .coa-d__fill {
    height: 100%;
    width: 0;
    border-radius: 5px;
  }
  .coa-d__fill--sector {
    background: #d4d4d4;
    transition: width 600ms cubic-bezier(0.22, 1, 0.36, 1) 0ms;
  }
  .coa-d__fill--cyra {
    background: linear-gradient(90deg, #108474, #0aab8f);
    transition: width 800ms cubic-bezier(0.22, 1, 0.36, 1) 300ms;
  }
  .ingredient-showcase__coa-body.is-open .coa-d__fill--sector {
    width: var(--bar-w, 0%);
  }
  .ingredient-showcase__coa-body.is-open .coa-d__fill--cyra {
    width: var(--bar-w, 0%);
  }
  @media (prefers-reduced-motion: reduce) {
    .coa-d__fill--sector,
    .coa-d__fill--cyra { transition: none; }
  }

  /* Style E — Annotated List */
  .coa-e {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding-top: 12px;
    margin: 0;
    padding-left: 0;
  }
  .coa-e__item {
    font-size: 13px;
    line-height: 1.5;
    color: inherit;
    opacity: 0.65;
    padding-left: 18px;
    position: relative;
    transition: opacity 0.2s ease;
  }
  .coa-e__item:hover { opacity: 0.9; }
  .coa-e__item::before {
    content: '';
    display: block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    position: absolute;
    left: 0;
    top: 7px;
  }
  .coa-e__item:nth-child(1)::before { background-color: #108474; }
  .coa-e__item:nth-child(2)::before { background-color: #e25c4f; }
  .coa-e__item:nth-child(3)::before { background-color: #3a7d5c; }
  .coa-e__item:nth-child(4)::before { background-color: #b8976a; }
  @keyframes coa-e-slideIn {
    from { opacity: 0; transform: translateX(-10px); }
    to { opacity: 1; transform: translateX(0); }
  }
  .is-open .coa-e__item:nth-child(1) { animation: coa-e-slideIn 300ms ease forwards; animation-delay: 0ms; }
  .is-open .coa-e__item:nth-child(2) { animation: coa-e-slideIn 300ms ease forwards; animation-delay: 80ms; }
  .is-open .coa-e__item:nth-child(3) { animation: coa-e-slideIn 300ms ease forwards; animation-delay: 160ms; }
  .is-open .coa-e__item:nth-child(4) { animation: coa-e-slideIn 300ms ease forwards; animation-delay: 240ms; }
  @media (prefers-reduced-motion: reduce) {
    .coa-e__item { animation: none !important; opacity: 0.65; }
  }

  /* Navigation */
  .ingredient-showcase__nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    margin-top: 18px;
    padding: 0 20px;
  }

  .ingredient-showcase__arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: 1.5px solid var(--text-color, #171717);
    background: transparent;
    color: var(--text-color, #171717);
    cursor: pointer;
    transition: opacity 200ms ease;
    flex-shrink: 0;
    padding: 0;
  }

  .ingredient-showcase__arrow:disabled {
    opacity: 0.25;
    cursor: default;
  }

  .ingredient-showcase__arrow:not(:disabled):hover {
    opacity: 0.6;
  }

  .ingredient-showcase__dots {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .ingredient-showcase__dot {
    width: 7px;
    height: 7px;
    border-radius: 2px;
    border: none;
    padding: 0;
    background-color: var(--text-color, #171717);
    opacity: 0.2;
    cursor: pointer;
    transition: opacity 200ms ease;
  }

  .ingredient-showcase__dot--active {
    opacity: 1;
  }

  /* ── Desktop ── */
  @media screen and (min-width: 768px) {
    .ingredient-showcase__header {
      margin-bottom: 28px;
    }

    .ingredient-showcase__heading {
      font-size: 2.25rem;
      font-weight: 400;
      letter-spacing: -0.01em;
    }

    .ingredient-showcase__subheading {
      font-size: 1rem;
    }

    /* Tab bar — visible on desktop */
    .ingredient-showcase__tabs {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 10px;
      padding: 0 40px;
      margin-bottom: 40px;
    }

    .ingredient-showcase__tab {
      padding: 12px 24px;
      border-radius: 9999px;
      border: 1px solid #d4d4d4;
      background: transparent;
      color: var(--text-color, #171717);
      font-size: 0.875rem;
      font-family: inherit;
      cursor: pointer;
      white-space: nowrap;
      transition: background-color 200ms ease, border-color 200ms ease;
    }

    .ingredient-showcase__tab:hover {
      border-color: #999;
    }

    .ingredient-showcase__tab--active {
      background-color: var(--accent-color, #FFD7BF);
      border-color: var(--accent-color, #FFD7BF);
    }

    /* Hide name chip on desktop — shown via tabs */
    .ingredient-showcase__name-chip {
      display: none;
    }

    /* Two-column slide — slide stays full-width, grid content is centered */
    .ingredient-showcase__slide {
      display: grid;
      grid-template-columns: 300px minmax(0, 400px);
      justify-content: center;
      column-gap: 48px;
      text-align: left;
      align-items: center;
      padding: 0 40px;
    }

    .ingredient-showcase__image-wrap {
      width: 100%;
      max-width: none;
      margin-bottom: 0;
    }

    .ingredient-showcase__content {
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .ingredient-showcase__benefits {
      justify-content: flex-start;
      margin-bottom: 16px;
      padding: 0;
      gap: 8px;
    }

    .ingredient-showcase__tag {
      padding: 8px 20px;
      font-size: 0.875rem;
    }

    .ingredient-showcase__description {
      max-width: none;
      font-size: 0.9375rem;
      line-height: 1.6;
    }

    /* Hide mobile nav on desktop */
    .ingredient-showcase__nav {
      display: none;
    }
  }

  /* ── Large desktop ── */
  @media screen and (min-width: 1024px) {
    .ingredient-showcase__slide {
      grid-template-columns: 340px minmax(0, 440px);
      column-gap: 56px;
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .ingredient-showcase__track {
      transition: none;
    }

    .ingredient-showcase__arrow,
    .ingredient-showcase__dot,
    .ingredient-showcase__tab {
      transition: none;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    function IngredientShowcase(section) {
      this.section = section;
      this.track = section.querySelector('[data-track]');
      this.carousel = section.querySelector('.ingredient-showcase__carousel');
      this.slides = section.querySelectorAll('.ingredient-showcase__slide');
      this.prevBtn = section.querySelector('[data-prev]');
      this.nextBtn = section.querySelector('[data-next]');
      this.dots = section.querySelectorAll('[data-dot]');
      this.tabs = section.querySelectorAll('[data-tab]');
      this.currentIndex = 0;
      this.totalSlides = this.slides.length;

      this.touchStartX = 0;
      this.touchStartY = 0;
      this.touchStartTime = 0;
      this.isDragging = false;
      this.directionLocked = false;
      this.isHorizontal = false;

      if (this.totalSlides < 2) return;

      this.bindEvents();
      this.updateState();
    }

    IngredientShowcase.prototype.bindEvents = function () {
      var self = this;

      if (this.prevBtn) {
        this.prevBtn.addEventListener('click', function () {
          self.goTo(self.currentIndex - 1);
        });
      }

      if (this.nextBtn) {
        this.nextBtn.addEventListener('click', function () {
          self.goTo(self.currentIndex + 1);
        });
      }

      this.dots.forEach(function (dot) {
        dot.addEventListener('click', function () {
          var index = parseInt(this.getAttribute('data-dot'), 10);
          self.goTo(index);
        });
      });

      this.tabs.forEach(function (tab) {
        tab.addEventListener('click', function () {
          var index = parseInt(this.getAttribute('data-tab'), 10);
          self.goTo(index);
        });
      });

      this.track.addEventListener('touchstart', function (e) {
        self.onTouchStart(e);
      }, { passive: true });

      this.track.addEventListener('touchmove', function (e) {
        self.onTouchMove(e);
      }, { passive: false });

      this.track.addEventListener('touchend', function (e) {
        self.onTouchEnd(e);
      }, { passive: true });

      this.track.addEventListener('touchcancel', function () {
        self.onTouchCancel();
      }, { passive: true });

      this.section.addEventListener('keydown', function (e) {
        self.onKeyDown(e);
      });

      this.section.addEventListener('click', function (e) {
        var coaTrigger = e.target.closest('[data-coa-toggle]');
        if (coaTrigger) {
          e.preventDefault();
          coaTrigger.classList.toggle('is-open');
          var body = coaTrigger.nextElementSibling;
          if (body) body.classList.toggle('is-open');
        }
      });
    };

    IngredientShowcase.prototype.getSlideWidth = function () {
      return this.carousel.offsetWidth;
    };

    IngredientShowcase.prototype.goTo = function (index) {
      if (index < 0 || index >= this.totalSlides) return;
      this.currentIndex = index;
      this.updateState();
    };

    IngredientShowcase.prototype.updateState = function () {
      var offset = -(this.currentIndex * 100);
      this.track.style.transform = 'translateX(' + offset + '%)';

      if (this.prevBtn) {
        this.prevBtn.disabled = this.currentIndex === 0;
      }

      if (this.nextBtn) {
        this.nextBtn.disabled = this.currentIndex === this.totalSlides - 1;
      }

      var self = this;
      this.dots.forEach(function (dot) {
        var dotIndex = parseInt(dot.getAttribute('data-dot'), 10);
        var isActive = dotIndex === self.currentIndex;
        dot.classList.toggle('ingredient-showcase__dot--active', isActive);
        dot.setAttribute('aria-selected', isActive ? 'true' : 'false');
      });

      this.tabs.forEach(function (tab) {
        var tabIndex = parseInt(tab.getAttribute('data-tab'), 10);
        tab.classList.toggle('ingredient-showcase__tab--active', tabIndex === self.currentIndex);
      });
    };

    IngredientShowcase.prototype.onTouchStart = function (e) {
      this.touchStartX = e.touches[0].clientX;
      this.touchStartY = e.touches[0].clientY;
      this.touchStartTime = Date.now();
      this.isDragging = true;
      this.directionLocked = false;
      this.isHorizontal = false;
      this.track.style.transition = 'none';
    };

    IngredientShowcase.prototype.onTouchMove = function (e) {
      if (!this.isDragging) return;

      var currentX = e.touches[0].clientX;
      var currentY = e.touches[0].clientY;
      var deltaX = currentX - this.touchStartX;
      var deltaY = currentY - this.touchStartY;

      if (!this.directionLocked) {
        if (Math.abs(deltaX) < 5 && Math.abs(deltaY) < 5) return;
        this.directionLocked = true;
        this.isHorizontal = Math.abs(deltaX) > Math.abs(deltaY);
      }

      if (!this.isHorizontal) {
        this.isDragging = false;
        this.track.style.transition = '';
        return;
      }

      e.preventDefault();

      var slideWidth = this.getSlideWidth();
      var movePercent = (deltaX / slideWidth) * 100;

      var atStart = this.currentIndex === 0 && deltaX > 0;
      var atEnd = this.currentIndex === this.totalSlides - 1 && deltaX < 0;
      if (atStart || atEnd) {
        movePercent *= 0.25;
      }

      var baseOffset = -(this.currentIndex * 100);
      this.track.style.transform = 'translateX(' + (baseOffset + movePercent) + '%)';
    };

    IngredientShowcase.prototype.onTouchEnd = function (e) {
      if (!this.isDragging) return;
      this.isDragging = false;
      this.track.style.transition = '';

      if (!this.directionLocked || !this.isHorizontal) {
        this.updateState();
        return;
      }

      var deltaX = e.changedTouches[0].clientX - this.touchStartX;
      var elapsed = Date.now() - this.touchStartTime;
      var velocity = Math.abs(deltaX) / elapsed;
      var slideWidth = this.getSlideWidth();

      var swipedEnough = Math.abs(deltaX) > slideWidth * 0.2;
      var flickedFast = velocity > 0.5 && Math.abs(deltaX) > 30;

      if (swipedEnough || flickedFast) {
        if (deltaX < 0) {
          this.goTo(this.currentIndex + 1);
        } else {
          this.goTo(this.currentIndex - 1);
        }
      } else {
        this.updateState();
      }
    };

    IngredientShowcase.prototype.onTouchCancel = function () {
      this.isDragging = false;
      this.track.style.transition = '';
      this.updateState();
    };

    IngredientShowcase.prototype.onKeyDown = function (e) {
      if (e.key === 'ArrowLeft') {
        e.preventDefault();
        this.goTo(this.currentIndex - 1);
      } else if (e.key === 'ArrowRight') {
        e.preventDefault();
        this.goTo(this.currentIndex + 1);
      }
    };

    function init() {
      document.querySelectorAll('.ingredient-showcase[data-section-id]').forEach(function (el) {
        if (!el.dataset.initialized) {
          new IngredientShowcase(el);
          el.dataset.initialized = 'true';
        }
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }

    document.addEventListener('shopify:section:load', function (e) {
      var section = e.target.querySelector('.ingredient-showcase[data-section-id]');
      if (section) {
        section.removeAttribute('data-initialized');
        new IngredientShowcase(section);
        section.dataset.initialized = 'true';
      }
    });
  })();
{% endjavascript %}

