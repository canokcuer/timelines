{% comment %}
  TheChill Transformation Journey — Horizontal Stepper Timeline.
  Self-contained: all styles, scripts, and SVG illustrations inlined.
  4 science-backed milestones in a compact ~1-viewport stepper layout.
{% endcomment %}

<cs-transform-timeline>
<section
  id="cs-transform-{{ section.id }}"
  class="cs-timeline cs-transform"
  aria-label="{{ section.settings.kicker | default: 'Dönüşüm Yolculuğu' }}"
  data-cs-transform
>
  <div class="cs-timeline__container">

    {%- comment -%} ── Section Header ──────────────────────────────── {%- endcomment -%}
    <header class="cs-timeline__header cs-transform__header">
      {%- if section.settings.kicker != blank -%}
        <span class="cs-timeline__kicker cs-transform__kicker">
          {{ section.settings.kicker }}
        </span>
      {%- endif -%}

      <h2 class="cs-timeline__title cs-transform__title">
        {{ section.settings.title }}
      </h2>

      {%- if section.settings.subtitle != blank -%}
        <p class="cs-timeline__subtitle cs-transform__subtitle">
          {{ section.settings.subtitle }}
        </p>
      {%- endif -%}
    </header>

    {%- comment -%} ── Stepper Navigation ──────────────────────────── {%- endcomment -%}
    <div class="cs-transform__stepper" role="tablist" aria-label="Dönüşüm adımları">
      <div class="cs-transform__stepper-track">
        <div class="cs-transform__stepper-rail" aria-hidden="true">
          <div class="cs-transform__stepper-fill" data-cs-stepper-fill></div>
        </div>

        {%- for block in section.blocks -%}
          <button
            class="cs-transform__step{% if forloop.first %} cs-transform__step--active{% endif %}"
            role="tab"
            type="button"
            aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
            aria-controls="ct-panel-{{ forloop.index0 }}-{{ section.id }}"
            id="ct-tab-{{ forloop.index0 }}-{{ section.id }}"
            data-cs-step="{{ forloop.index0 }}"
            tabindex="{% if forloop.first %}0{% else %}-1{% endif %}"
            {{ block.shopify_attributes }}
          >
            <span class="cs-transform__step-node" aria-hidden="true">{{ forloop.index }}</span>
            <span class="cs-transform__step-label">{{ block.settings.time_label }}</span>
          </button>
        {%- endfor -%}
      </div>
    </div>

    {%- comment -%} ── Detail Panels ───────────────────────────────── {%- endcomment -%}
    <div class="cs-transform__details" data-cs-details>
      {%- for block in section.blocks -%}
        {%- assign is_last = false -%}
        {%- if forloop.last -%}{%- assign is_last = true -%}{%- endif -%}

        <div
          class="cs-transform__detail{% if forloop.first %} cs-transform__detail--active{% endif %}"
          role="tabpanel"
          id="ct-panel-{{ forloop.index0 }}-{{ section.id }}"
          aria-labelledby="ct-tab-{{ forloop.index0 }}-{{ section.id }}"
          {% unless forloop.first %}aria-hidden="true"{% endunless %}
          data-cs-detail="{{ forloop.index0 }}"
        >
          <div class="cs-transform__detail-grid">

            {%- comment -%} ── SVG Illustration ─────────────────────── {%- endcomment -%}
            <div class="cs-transform__detail-visual">
              <div class="cs-transform__illust-frame">
                {%- case block.settings.illustration -%}

                  {%- when 'molecule' -%}
                    <svg class="cs-transform__illust-svg" viewBox="0 0 240 240" fill="none" aria-hidden="true" focusable="false">
                      <defs>
                        <radialGradient id="ct-fglow-{{ section.id }}" cx="50%" cy="42%" r="38%">
                          <stop offset="0%" stop-color="#0D4F47" stop-opacity="0.07"/>
                          <stop offset="100%" stop-color="#0D4F47" stop-opacity="0"/>
                        </radialGradient>
                        <linearGradient id="ct-petal-{{ section.id }}" x1="0" y1="0" x2="0" y2="1">
                          <stop offset="0%" stop-color="#0D4F47" stop-opacity="0.08"/>
                          <stop offset="100%" stop-color="#0D4F47" stop-opacity="0.02"/>
                        </linearGradient>
                      </defs>
                      <circle cx="120" cy="100" r="88" fill="url(#ct-fglow-{{ section.id }})"/>
                      <circle cx="120" cy="120" r="115" stroke="#0D4F47" stroke-width="0.5" opacity="0.07" stroke-dasharray="2 8"/>
                      <!-- Chamomile — 12 petals -->
                      <g transform="translate(120,95)">
                        <ellipse rx="7" ry="30" fill="url(#ct-petal-{{ section.id }})" stroke="#0D4F47" stroke-width="0.8" opacity="0.55"/>
                        <ellipse rx="7" ry="30" fill="url(#ct-petal-{{ section.id }})" stroke="#0D4F47" stroke-width="0.8" opacity="0.5" transform="rotate(30)"/>
                        <ellipse rx="7" ry="30" fill="url(#ct-petal-{{ section.id }})" stroke="#0D4F47" stroke-width="0.8" opacity="0.55" transform="rotate(60)"/>
                        <ellipse rx="7" ry="30" fill="url(#ct-petal-{{ section.id }})" stroke="#0D4F47" stroke-width="0.8" opacity="0.48" transform="rotate(90)"/>
                        <ellipse rx="7" ry="30" fill="url(#ct-petal-{{ section.id }})" stroke="#0D4F47" stroke-width="0.8" opacity="0.55" transform="rotate(120)"/>
                        <ellipse rx="7" ry="30" fill="url(#ct-petal-{{ section.id }})" stroke="#0D4F47" stroke-width="0.8" opacity="0.5" transform="rotate(150)"/>
                        <!-- Petal veins -->
                        <line x1="0" y1="-6" x2="0" y2="-28" stroke="#0D4F47" stroke-width="0.35" opacity="0.18"/>
                        <line x1="0" y1="-6" x2="0" y2="-28" stroke="#0D4F47" stroke-width="0.35" opacity="0.18" transform="rotate(60)"/>
                        <line x1="0" y1="-6" x2="0" y2="-28" stroke="#0D4F47" stroke-width="0.35" opacity="0.18" transform="rotate(120)"/>
                        <!-- Centre disc -->
                        <circle r="12" fill="#C4973B" opacity="0.12" stroke="#C4973B" stroke-width="1"/>
                        <circle cx="-4" cy="-4" r="1.8" fill="#C4973B" opacity="0.4"/>
                        <circle cx="4" cy="2" r="1.5" fill="#C4973B" opacity="0.35"/>
                        <circle cx="-1" cy="5" r="1.2" fill="#C4973B" opacity="0.28"/>
                        <circle cx="5" cy="-3" r="1" fill="#C4973B" opacity="0.25"/>
                        <circle r="2.2" fill="#C4973B" opacity="0.5"/>
                      </g>
                      <!-- Stem & leaves -->
                      <path d="M120 125 Q117 148,113 168 Q109 185,105 200" stroke="#0D4F47" stroke-width="1.2" opacity="0.22" fill="none"/>
                      <path d="M114 150 Q102 143,95 148 Q103 153,114 150Z" stroke="#0D4F47" stroke-width="0.7" opacity="0.18" fill="#0D4F47" fill-opacity="0.04"/>
                      <path d="M110 175 Q122 168,130 173 Q122 178,110 175Z" stroke="#0D4F47" stroke-width="0.7" opacity="0.18" fill="#0D4F47" fill-opacity="0.04"/>
                      <!-- Apigenin molecule — three fused hexagonal rings -->
                      <g transform="translate(175,178)" opacity="0.55">
                        <polygon points="0,-14 12,-7 12,7 0,14 -12,7 -12,-7" stroke="#C4973B" stroke-width="1" fill="none"/>
                        <polygon points="24,-14 36,-7 36,7 24,14 12,7 12,-7" stroke="#C4973B" stroke-width="1" fill="none"/>
                        <polygon points="24,14 36,21 36,35 24,42 12,35 12,21" stroke="#C4973B" stroke-width="1" fill="none"/>
                        <line x1="2" y1="-11" x2="9" y2="-8" stroke="#C4973B" stroke-width="0.5" opacity="0.4"/>
                        <line x1="2" y1="11" x2="9" y2="8" stroke="#C4973B" stroke-width="0.5" opacity="0.4"/>
                        <circle cx="-12" cy="7" r="3.5" stroke="#108474" stroke-width="0.7" fill="#108474" fill-opacity="0.12"/>
                        <circle cx="36" cy="-7" r="3.5" stroke="#108474" stroke-width="0.7" fill="#108474" fill-opacity="0.12"/>
                        <circle cx="36" cy="35" r="3.5" stroke="#108474" stroke-width="0.7" fill="#108474" fill-opacity="0.12"/>
                      </g>
                      <!-- Connecting dotted line -->
                      <path d="M132 115 Q155 140,168 168" stroke="#C4973B" stroke-width="0.7" stroke-dasharray="3 4" opacity="0.18" fill="none"/>
                      <!-- Floating particles -->
                      <circle cx="75" cy="55" r="2" fill="#0D4F47" opacity="0.09"/>
                      <circle cx="165" cy="45" r="1.5" fill="#C4973B" opacity="0.13"/>
                      <circle cx="50" cy="135" r="1.8" fill="#0D4F47" opacity="0.07"/>
                      <circle cx="195" cy="85" r="1.5" fill="#C4973B" opacity="0.1"/>
                      <circle cx="65" cy="190" r="1" fill="#0D4F47" opacity="0.06"/>
                    </svg>

                  {%- when 'wave' -%}
                    <svg class="cs-transform__illust-svg" viewBox="0 0 240 240" fill="none" aria-hidden="true" focusable="false">
                      <defs>
                        <linearGradient id="ct-ngrd-{{ section.id }}" x1="0" y1="0" x2="0" y2="1">
                          <stop offset="0%" stop-color="#0D4F47" stop-opacity="0.06"/>
                          <stop offset="60%" stop-color="#0D4F47" stop-opacity="0.02"/>
                          <stop offset="100%" stop-color="#0D4F47" stop-opacity="0"/>
                        </linearGradient>
                        <linearGradient id="ct-wgrd-{{ section.id }}" x1="0" y1="0" x2="1" y2="0">
                          <stop offset="0%" stop-color="#0D4F47"/>
                          <stop offset="100%" stop-color="#C4973B"/>
                        </linearGradient>
                      </defs>
                      <circle cx="120" cy="120" r="110" fill="url(#ct-ngrd-{{ section.id }})"/>
                      <circle cx="120" cy="120" r="115" stroke="#0D4F47" stroke-width="0.5" opacity="0.07" stroke-dasharray="2 8"/>
                      <!-- Crescent moon -->
                      <path d="M125 28 A28 28 0 1 0 125 84 A20 20 0 1 1 125 28Z" stroke="#C4973B" stroke-width="1.2" opacity="0.5" fill="#C4973B" fill-opacity="0.06"/>
                      <circle cx="112" cy="50" r="3" fill="#C4973B" opacity="0.07"/>
                      <circle cx="108" cy="63" r="2" fill="#C4973B" opacity="0.05"/>
                      <!-- Stars — 4-pointed -->
                      <path d="M70 33 L72 38 L77 40 L72 42 L70 47 L68 42 L63 40 L68 38Z" fill="#C4973B" opacity="0.28"/>
                      <path d="M170 53 L171.5 57 L175.5 58.5 L171.5 60 L170 64 L168.5 60 L164.5 58.5 L168.5 57Z" fill="#C4973B" opacity="0.22"/>
                      <!-- Stars — dots -->
                      <circle cx="55" cy="48" r="1.2" fill="#C4973B" opacity="0.22"/>
                      <circle cx="185" cy="36" r="1" fill="#C4973B" opacity="0.18"/>
                      <circle cx="90" cy="23" r="0.8" fill="#C4973B" opacity="0.16"/>
                      <circle cx="155" cy="26" r="1" fill="#C4973B" opacity="0.2"/>
                      <circle cx="200" cy="63" r="0.8" fill="#C4973B" opacity="0.14"/>
                      <circle cx="42" cy="73" r="1" fill="#C4973B" opacity="0.16"/>
                      <!-- Cloud wisps -->
                      <path d="M40 85 Q65 80,90 85 Q110 82,130 86" stroke="#0D4F47" stroke-width="0.6" opacity="0.09" fill="none"/>
                      <path d="M100 90 Q130 85,160 90 Q180 87,200 91" stroke="#0D4F47" stroke-width="0.5" opacity="0.06" fill="none"/>
                      <!-- Horizon -->
                      <line x1="20" y1="105" x2="220" y2="105" stroke="#0D4F47" stroke-width="0.5" opacity="0.08"/>
                      <!-- Sleep waves — deeper = calmer -->
                      <path d="M15 120 Q40 105,65 120 Q90 135,115 120 Q140 105,165 120 Q190 135,215 120" stroke="url(#ct-wgrd-{{ section.id }})" stroke-width="1.5" opacity="0.5" fill="none"/>
                      <path d="M15 140 Q45 128,75 140 Q105 152,135 140 Q165 128,195 140 Q215 148,225 143" stroke="url(#ct-wgrd-{{ section.id }})" stroke-width="1.3" opacity="0.32" fill="none"/>
                      <path d="M15 158 Q50 149,85 158 Q120 167,155 158 Q190 149,225 158" stroke="url(#ct-wgrd-{{ section.id }})" stroke-width="1" opacity="0.22" fill="none"/>
                      <path d="M15 174 Q55 168,95 174 Q135 180,175 174 Q205 170,225 173" stroke="url(#ct-wgrd-{{ section.id }})" stroke-width="0.8" opacity="0.13" fill="none"/>
                      <!-- Floating z's -->
                      <text x="150" y="42" font-family="var(--cs-font-family)" font-size="14" font-weight="300" fill="#C4973B" opacity="0.18">z</text>
                      <text x="163" y="32" font-family="var(--cs-font-family)" font-size="10" font-weight="300" fill="#C4973B" opacity="0.13">z</text>
                      <text x="173" y="24" font-family="var(--cs-font-family)" font-size="7" font-weight="300" fill="#C4973B" opacity="0.09">z</text>
                      <!-- Particles -->
                      <circle cx="45" cy="180" r="1.5" fill="#0D4F47" opacity="0.07"/>
                      <circle cx="195" cy="170" r="1.2" fill="#C4973B" opacity="0.09"/>
                    </svg>

                  {%- when 'brain' -%}
                    <svg class="cs-transform__illust-svg" viewBox="0 0 240 240" fill="none" aria-hidden="true" focusable="false">
                      <defs>
                        <radialGradient id="ct-bglow-{{ section.id }}" cx="50%" cy="38%" r="36%">
                          <stop offset="0%" stop-color="#0D4F47" stop-opacity="0.06"/>
                          <stop offset="100%" stop-color="#0D4F47" stop-opacity="0"/>
                        </radialGradient>
                      </defs>
                      <circle cx="120" cy="100" r="88" fill="url(#ct-bglow-{{ section.id }})"/>
                      <circle cx="120" cy="120" r="115" stroke="#0D4F47" stroke-width="0.5" opacity="0.07" stroke-dasharray="2 8"/>
                      <!-- Brain — left hemisphere -->
                      <path d="M120 30 C95 30,75 42,68 58 C62 72,58 85,60 100 C62 110,68 118,72 125 C65 132,60 142,63 152 C66 162,78 168,90 165 C98 163,108 158,115 150 L120 145" stroke="#0D4F47" stroke-width="1.3" opacity="0.42" fill="#0D4F47" fill-opacity="0.02"/>
                      <!-- Brain — right hemisphere -->
                      <path d="M120 30 C145 30,165 42,172 58 C178 72,182 85,180 100 C178 110,172 118,168 125 C175 132,180 142,177 152 C174 162,162 168,150 165 C142 163,132 158,125 150 L120 145" stroke="#0D4F47" stroke-width="1.3" opacity="0.42" fill="#0D4F47" fill-opacity="0.02"/>
                      <!-- Centre line -->
                      <line x1="120" y1="33" x2="120" y2="143" stroke="#0D4F47" stroke-width="0.6" opacity="0.12"/>
                      <!-- Gyri folds — left -->
                      <path d="M80 55 Q90 50,100 58" stroke="#0D4F47" stroke-width="0.7" opacity="0.18" fill="none"/>
                      <path d="M72 75 Q85 68,98 78" stroke="#0D4F47" stroke-width="0.7" opacity="0.15" fill="none"/>
                      <path d="M68 95 Q82 88,96 98" stroke="#0D4F47" stroke-width="0.7" opacity="0.13" fill="none"/>
                      <path d="M75 115 Q88 108,100 118" stroke="#0D4F47" stroke-width="0.7" opacity="0.12" fill="none"/>
                      <!-- Gyri folds — right -->
                      <path d="M160 55 Q150 50,140 58" stroke="#0D4F47" stroke-width="0.7" opacity="0.18" fill="none"/>
                      <path d="M168 75 Q155 68,142 78" stroke="#0D4F47" stroke-width="0.7" opacity="0.15" fill="none"/>
                      <path d="M172 95 Q158 88,144 98" stroke="#0D4F47" stroke-width="0.7" opacity="0.13" fill="none"/>
                      <path d="M165 115 Q152 108,140 118" stroke="#0D4F47" stroke-width="0.7" opacity="0.12" fill="none"/>
                      <!-- Neural dots + connections -->
                      <circle cx="88" cy="65" r="2" fill="#0D4F47" opacity="0.13"/>
                      <circle cx="105" cy="82" r="2" fill="#0D4F47" opacity="0.1"/>
                      <circle cx="92" cy="100" r="1.8" fill="#0D4F47" opacity="0.09"/>
                      <circle cx="152" cy="65" r="2" fill="#0D4F47" opacity="0.13"/>
                      <circle cx="135" cy="82" r="2" fill="#0D4F47" opacity="0.1"/>
                      <circle cx="148" cy="100" r="1.8" fill="#0D4F47" opacity="0.09"/>
                      <line x1="88" y1="65" x2="105" y2="82" stroke="#0D4F47" stroke-width="0.4" opacity="0.07"/>
                      <line x1="105" y1="82" x2="92" y2="100" stroke="#0D4F47" stroke-width="0.4" opacity="0.07"/>
                      <line x1="152" y1="65" x2="135" y2="82" stroke="#0D4F47" stroke-width="0.4" opacity="0.07"/>
                      <line x1="135" y1="82" x2="148" y2="100" stroke="#0D4F47" stroke-width="0.4" opacity="0.07"/>
                      <!-- Balance scales -->
                      <polygon points="120,170 114,180 126,180" stroke="#C4973B" stroke-width="1" opacity="0.45" fill="#C4973B" fill-opacity="0.05"/>
                      <line x1="78" y1="170" x2="162" y2="170" stroke="#C4973B" stroke-width="1.2" opacity="0.42"/>
                      <circle cx="120" cy="170" r="2.5" fill="#C4973B" opacity="0.38"/>
                      <!-- Left pan — cortisol down -->
                      <line x1="78" y1="170" x2="78" y2="183" stroke="#C4973B" stroke-width="0.8" opacity="0.3"/>
                      <path d="M66 183 Q72 187,78 183 Q84 187,90 183" stroke="#C4973B" stroke-width="0.8" opacity="0.3" fill="#C4973B" fill-opacity="0.03"/>
                      <path d="M72 189 L75 193 L78 189 L81 193 L84 189" stroke="#C4973B" stroke-width="0.6" opacity="0.2" fill="none"/>
                      <!-- Right pan — wellness up -->
                      <line x1="162" y1="170" x2="162" y2="183" stroke="#C4973B" stroke-width="0.8" opacity="0.3"/>
                      <path d="M150 183 Q156 187,162 183 Q168 187,174 183" stroke="#C4973B" stroke-width="0.8" opacity="0.3" fill="#C4973B" fill-opacity="0.03"/>
                      <path d="M154 190 Q158 186,162 190 Q166 194,170 190" stroke="#108474" stroke-width="0.7" opacity="0.25" fill="none"/>
                      <!-- Arrows -->
                      <line x1="52" y1="88" x2="52" y2="118" stroke="#C4973B" stroke-width="0.9" opacity="0.2"/>
                      <polyline points="48,113 52,120 56,113" stroke="#C4973B" stroke-width="0.9" opacity="0.2" fill="none"/>
                      <line x1="188" y1="118" x2="188" y2="88" stroke="#108474" stroke-width="0.9" opacity="0.2"/>
                      <polyline points="184,93 188,86 192,93" stroke="#108474" stroke-width="0.9" opacity="0.2" fill="none"/>
                      <!-- Calm radiations -->
                      <circle cx="120" cy="90" r="52" stroke="#0D4F47" stroke-width="0.3" opacity="0.05" fill="none"/>
                      <circle cx="120" cy="90" r="72" stroke="#0D4F47" stroke-width="0.25" opacity="0.03" fill="none"/>
                    </svg>

                  {%- when 'harmony' -%}
                    <svg class="cs-transform__illust-svg" viewBox="0 0 240 240" fill="none" aria-hidden="true" focusable="false">
                      <defs>
                        <radialGradient id="ct-hglow-{{ section.id }}" cx="50%" cy="50%" r="42%">
                          <stop offset="0%" stop-color="#0D4F47" stop-opacity="0.05"/>
                          <stop offset="100%" stop-color="#0D4F47" stop-opacity="0"/>
                        </radialGradient>
                      </defs>
                      <circle cx="120" cy="120" r="105" fill="url(#ct-hglow-{{ section.id }})"/>
                      <!-- Decorative rings -->
                      <circle cx="120" cy="120" r="115" stroke="#0D4F47" stroke-width="0.5" opacity="0.07" stroke-dasharray="2 8"/>
                      <circle cx="120" cy="120" r="98" stroke="#0D4F47" stroke-width="0.35" opacity="0.05"/>
                      <circle cx="120" cy="120" r="55" stroke="#0D4F47" stroke-width="0.6" opacity="0.08" stroke-dasharray="4 4"/>
                      <!-- Central medallion -->
                      <circle cx="120" cy="120" r="18" stroke="#C4973B" stroke-width="1" opacity="0.38" fill="#C4973B" fill-opacity="0.04"/>
                      <circle cx="120" cy="120" r="8" fill="#C4973B" opacity="0.13"/>
                      <!-- Connecting lines -->
                      <line x1="120" y1="102" x2="120" y2="38" stroke="#0D4F47" stroke-width="0.5" opacity="0.08"/>
                      <line x1="136" y1="111" x2="191" y2="78" stroke="#0D4F47" stroke-width="0.5" opacity="0.08"/>
                      <line x1="136" y1="129" x2="191" y2="162" stroke="#0D4F47" stroke-width="0.5" opacity="0.08"/>
                      <line x1="120" y1="138" x2="120" y2="202" stroke="#0D4F47" stroke-width="0.5" opacity="0.08"/>
                      <line x1="104" y1="129" x2="49" y2="162" stroke="#0D4F47" stroke-width="0.5" opacity="0.08"/>
                      <line x1="104" y1="111" x2="49" y2="78" stroke="#0D4F47" stroke-width="0.5" opacity="0.08"/>
                      <!-- 1 · Rhodiola Rosea (0°) — rosette -->
                      <g transform="translate(120,36)">
                        <ellipse rx="5" ry="13" stroke="#0D4F47" stroke-width="0.8" opacity="0.48" fill="#0D4F47" fill-opacity="0.03"/>
                        <ellipse rx="5" ry="13" stroke="#0D4F47" stroke-width="0.8" opacity="0.42" fill="#0D4F47" fill-opacity="0.02" transform="rotate(45)"/>
                        <ellipse rx="5" ry="13" stroke="#0D4F47" stroke-width="0.8" opacity="0.48" fill="#0D4F47" fill-opacity="0.03" transform="rotate(90)"/>
                        <ellipse rx="5" ry="13" stroke="#0D4F47" stroke-width="0.8" opacity="0.42" fill="#0D4F47" fill-opacity="0.02" transform="rotate(135)"/>
                        <circle r="3" fill="#0D4F47" opacity="0.13"/>
                      </g>
                      <!-- 2 · Chamomile (60°) — daisy -->
                      <g transform="translate(191,76)">
                        <ellipse rx="4" ry="10" stroke="#0D4F47" stroke-width="0.7" opacity="0.42" fill="none"/>
                        <ellipse rx="4" ry="10" stroke="#0D4F47" stroke-width="0.7" opacity="0.38" fill="none" transform="rotate(45)"/>
                        <ellipse rx="4" ry="10" stroke="#0D4F47" stroke-width="0.7" opacity="0.42" fill="none" transform="rotate(90)"/>
                        <ellipse rx="4" ry="10" stroke="#0D4F47" stroke-width="0.7" opacity="0.38" fill="none" transform="rotate(135)"/>
                        <circle r="4" stroke="#C4973B" stroke-width="0.7" fill="#C4973B" opacity="0.18"/>
                      </g>
                      <!-- 3 · Passiflora (120°) — star corona -->
                      <g transform="translate(191,164)">
                        <polygon points="0,-14 3,-5 12,-5 5,1 7,10 0,5 -7,10 -5,1 -12,-5 -3,-5" stroke="#C4973B" stroke-width="0.7" opacity="0.38" fill="#C4973B" fill-opacity="0.03"/>
                        <line x1="0" y1="0" x2="0" y2="-11" stroke="#C4973B" stroke-width="0.4" opacity="0.2"/>
                        <line x1="0" y1="0" x2="10" y2="-4" stroke="#C4973B" stroke-width="0.4" opacity="0.2"/>
                        <line x1="0" y1="0" x2="6" y2="9" stroke="#C4973B" stroke-width="0.4" opacity="0.2"/>
                        <line x1="0" y1="0" x2="-6" y2="9" stroke="#C4973B" stroke-width="0.4" opacity="0.2"/>
                        <line x1="0" y1="0" x2="-10" y2="-4" stroke="#C4973B" stroke-width="0.4" opacity="0.2"/>
                        <circle r="2.5" fill="#C4973B" opacity="0.18"/>
                      </g>
                      <!-- 4 · Melissa (180°) — heart-leaf -->
                      <g transform="translate(120,202)">
                        <path d="M0,-14 C8,-14 14,-6 14,2 C14,8 8,14 0,16 C-8,14 -14,8 -14,2 C-14,-6 -8,-14 0,-14Z" stroke="#0D4F47" stroke-width="0.8" opacity="0.45" fill="#0D4F47" fill-opacity="0.03"/>
                        <line x1="0" y1="-12" x2="0" y2="14" stroke="#0D4F47" stroke-width="0.35" opacity="0.18"/>
                        <line x1="0" y1="0" x2="8" y2="-4" stroke="#0D4F47" stroke-width="0.3" opacity="0.12"/>
                        <line x1="0" y1="4" x2="-7" y2="0" stroke="#0D4F47" stroke-width="0.3" opacity="0.12"/>
                      </g>
                      <!-- 5 · B6 (240°) — pyridine hex -->
                      <g transform="translate(49,164)">
                        <polygon points="0,-13 11,-6.5 11,6.5 0,13 -11,6.5 -11,-6.5" stroke="#C4973B" stroke-width="1" opacity="0.42" fill="#C4973B" fill-opacity="0.04"/>
                        <circle r="3" fill="#C4973B" opacity="0.18"/>
                        <text x="-4" y="3" font-family="var(--cs-font-family)" font-size="6" fill="#C4973B" opacity="0.35" font-weight="600">B6</text>
                      </g>
                      <!-- 6 · B12 (300°) — corrin ring -->
                      <g transform="translate(49,76)">
                        <rect x="-12" y="-12" width="24" height="24" rx="3" stroke="#C4973B" stroke-width="0.8" opacity="0.38" fill="#C4973B" fill-opacity="0.03" transform="rotate(45)"/>
                        <circle r="5" stroke="#C4973B" stroke-width="0.7" opacity="0.28" fill="#C4973B" fill-opacity="0.08"/>
                        <text x="-6" y="3" font-family="var(--cs-font-family)" font-size="5.5" fill="#C4973B" opacity="0.32" font-weight="600">B12</text>
                      </g>
                      <!-- Outer dots -->
                      <circle cx="120" cy="22" r="2" fill="#0D4F47" opacity="0.1"/>
                      <circle cx="205" cy="70" r="2" fill="#0D4F47" opacity="0.1"/>
                      <circle cx="205" cy="170" r="2" fill="#C4973B" opacity="0.1"/>
                      <circle cx="120" cy="218" r="2" fill="#0D4F47" opacity="0.1"/>
                      <circle cx="35" cy="170" r="2" fill="#C4973B" opacity="0.1"/>
                      <circle cx="35" cy="70" r="2" fill="#C4973B" opacity="0.1"/>
                    </svg>

                  {%- else -%}
                    <svg class="cs-transform__illust-svg" viewBox="0 0 240 240" fill="none" aria-hidden="true" focusable="false">
                      <circle cx="120" cy="120" r="60" stroke="#0D4F47" stroke-width="1" opacity="0.15"/>
                      <circle cx="120" cy="120" r="8" fill="#C4973B" opacity="0.2"/>
                    </svg>
                {%- endcase -%}
              </div>
            </div>

            {%- comment -%} ── Content ──────────────────────────────── {%- endcomment -%}
            <div class="cs-transform__detail-content">
              <h3 class="cs-transform__detail-headline">
                {{ block.settings.headline }}
              </h3>

              <ul class="cs-transform__benefits" role="list">
                {%- if block.settings.benefit_1 != blank -%}
                  <li class="cs-transform__benefit">
                    <span class="cs-transform__benefit-text">{{ block.settings.benefit_1 }}</span>
                    {%- if block.settings.ingredient_1 != blank -%}
                      <span class="cs-transform__ingredient-pill">{{ block.settings.ingredient_1 }}</span>
                    {%- endif -%}
                  </li>
                {%- endif -%}
                {%- if block.settings.benefit_2 != blank -%}
                  <li class="cs-transform__benefit">
                    <span class="cs-transform__benefit-text">{{ block.settings.benefit_2 }}</span>
                    {%- if block.settings.ingredient_2 != blank -%}
                      <span class="cs-transform__ingredient-pill">{{ block.settings.ingredient_2 }}</span>
                    {%- endif -%}
                  </li>
                {%- endif -%}
                {%- if block.settings.benefit_3 != blank -%}
                  <li class="cs-transform__benefit">
                    <span class="cs-transform__benefit-text">{{ block.settings.benefit_3 }}</span>
                    {%- if block.settings.ingredient_3 != blank -%}
                      <span class="cs-transform__ingredient-pill">{{ block.settings.ingredient_3 }}</span>
                    {%- endif -%}
                  </li>
                {%- endif -%}
              </ul>

              {%- if block.settings.science_callout != blank -%}
                <div class="cs-transform__science-callout">
                  <span class="cs-transform__science-label">Bilimsel Mekanizma</span>
                  <p class="cs-transform__science-text">{{ block.settings.science_callout }}</p>
                  {%- if block.settings.stat_reference != blank -%}
                    <cite class="cs-transform__science-ref">{{ block.settings.stat_reference }}</cite>
                  {%- endif -%}
                </div>
              {%- endif -%}

              {%- if is_last and section.settings.cta_text != blank -%}
                <div class="cs-transform__cta-wrap">
                  <a
                    href="{{ section.settings.cta_url }}"
                    class="cs-transform__cta"
                    aria-label="{{ section.settings.cta_text }}"
                  >
                    {{- section.settings.cta_text -}}
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" focusable="false">
                      <path d="M3.333 8h9.334M8.667 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </a>
                </div>
              {%- endif -%}
            </div>

          </div>
        </div>
      {%- endfor -%}
    </div>

  </div>
</section>
</cs-transform-timeline>

<style>
/* ============================================================================
   CS Timeline Base — Design Tokens & Shared Utilities
   ============================================================================ */

:root {
  --cs-gold: #FFDF00;
  --cs-gold-soft: rgba(255, 223, 0, 0.15);
  --cs-gold-medium: rgba(255, 223, 0, 0.4);
  --cs-teal: #108474;
  --cs-teal-soft: rgba(16, 132, 116, 0.15);
  --cs-teal-medium: rgba(16, 132, 116, 0.4);
  --cs-indigo: #3B3073;
  --cs-indigo-soft: rgba(59, 48, 115, 0.15);

  --cs-bg-dark: #171717;
  --cs-bg-deep: #0a0a0a;
  --cs-bg-warm: #f9f6f2;
  --cs-bg-white: #ffffff;
  --cs-bg-card-dark: rgba(255, 255, 255, 0.04);
  --cs-bg-card-frost: rgba(255, 255, 255, 0.06);

  --cs-text-white: #ffffff;
  --cs-text-white-muted: rgba(255, 255, 255, 0.7);
  --cs-text-white-subtle: rgba(255, 255, 255, 0.5);
  --cs-text-dark: #171717;
  --cs-text-dark-muted: rgba(23, 23, 23, 0.7);
  --cs-text-dark-subtle: rgba(23, 23, 23, 0.5);

  --cs-border-light: rgba(255, 255, 255, 0.08);
  --cs-border-gold: rgba(255, 223, 0, 0.3);
  --cs-border-teal: rgba(16, 132, 116, 0.3);

  --cs-font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  --cs-font-size-xs: clamp(0.6875rem, 0.625rem + 0.25vw, 0.75rem);
  --cs-font-size-sm: clamp(0.75rem, 0.6875rem + 0.25vw, 0.875rem);
  --cs-font-size-base: clamp(0.875rem, 0.8125rem + 0.25vw, 1rem);
  --cs-font-size-md: clamp(1rem, 0.9375rem + 0.25vw, 1.125rem);
  --cs-font-size-lg: clamp(1.125rem, 1rem + 0.5vw, 1.375rem);
  --cs-font-size-xl: clamp(1.375rem, 1.125rem + 1vw, 1.75rem);
  --cs-font-size-2xl: clamp(1.75rem, 1.375rem + 1.5vw, 2.5rem);
  --cs-font-size-3xl: clamp(2rem, 1.5rem + 2vw, 3rem);

  --cs-space-xs: clamp(0.25rem, 0.125rem + 0.5vw, 0.5rem);
  --cs-space-sm: clamp(0.5rem, 0.375rem + 0.5vw, 0.75rem);
  --cs-space-md: clamp(0.75rem, 0.5rem + 1vw, 1.25rem);
  --cs-space-lg: clamp(1.25rem, 0.875rem + 1.5vw, 2rem);
  --cs-space-xl: clamp(2rem, 1.25rem + 3vw, 3.5rem);
  --cs-space-2xl: clamp(3rem, 2rem + 4vw, 5rem);
  --cs-space-3xl: clamp(4rem, 2.5rem + 6vw, 7.5rem);

  --cs-radius-sm: 4px;
  --cs-radius-md: 8px;
  --cs-radius-lg: 12px;
  --cs-radius-xl: 16px;
  --cs-radius-full: 9999px;

  --cs-shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.12);
  --cs-shadow-md: 0 4px 12px rgba(0, 0, 0, 0.15);
  --cs-shadow-lg: 0 8px 30px rgba(0, 0, 0, 0.2);
  --cs-shadow-gold: 0 0 20px rgba(255, 223, 0, 0.15);
  --cs-shadow-teal: 0 0 20px rgba(16, 132, 116, 0.15);

  --cs-ease-out: cubic-bezier(0.16, 1, 0.3, 1);
  --cs-ease-in-out: cubic-bezier(0.65, 0, 0.35, 1);
  --cs-duration-fast: 200ms;
  --cs-duration-base: 400ms;
  --cs-duration-slow: 600ms;
  --cs-duration-draw: 1200ms;

  --cs-z-base: 1;
  --cs-z-above: 10;
  --cs-z-sticky: 100;
  --cs-z-overlay: 200;
  --cs-z-modal: 300;

  --cs-content-max: 1200px;
  --cs-content-narrow: 640px;
  --cs-mobile-dock-clearance: 95px;
}

/* --------------------------------------------------------------------------
   Base Reset
   -------------------------------------------------------------------------- */
.cs-timeline {
  font-family: var(--cs-font-family);
  line-height: 1.6;
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

.cs-timeline *,
.cs-timeline *::before,
.cs-timeline *::after {
  box-sizing: inherit;
}

.cs-timeline__container {
  width: 100%;
  max-width: var(--cs-content-max);
  margin-inline: auto;
  padding-inline: var(--cs-space-md);
}

/* --------------------------------------------------------------------------
   Section Header (shared)
   -------------------------------------------------------------------------- */
.cs-timeline__header {
  text-align: center;
  margin-block-end: var(--cs-space-xl);
}

.cs-timeline__kicker {
  display: inline-block;
  font-size: var(--cs-font-size-xs);
  font-weight: 600;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  margin-block-end: var(--cs-space-sm);
}

.cs-timeline__title {
  font-size: var(--cs-font-size-2xl);
  font-weight: 700;
  letter-spacing: -0.03em;
  line-height: 1.12;
  margin: 0 0 var(--cs-space-md);
}

.cs-timeline__subtitle {
  font-size: var(--cs-font-size-md);
  line-height: 1.5;
  max-width: 540px;
  margin-inline: auto;
}

/* --------------------------------------------------------------------------
   Calming Reveal — opacity-only, no translate
   -------------------------------------------------------------------------- */
.cs-transform__reveal {
  opacity: 0;
  transition: opacity 800ms var(--cs-ease-out);
}

.cs-transform__reveal--visible {
  opacity: 1;
}

/* Fallback: if JS doesn't run within 3s, show everything */
@keyframes ct-reveal-fallback {
  to { opacity: 1; }
}

.cs-transform__reveal:not(.cs-transform__reveal--visible) {
  animation: ct-reveal-fallback 0s 3s forwards;
}

/* --------------------------------------------------------------------------
   Responsive Utilities
   -------------------------------------------------------------------------- */
@media screen and (max-width: 749px) {
  .cs-timeline--hide-mobile { display: none !important; }
  .cs-timeline { padding-block-end: var(--cs-mobile-dock-clearance); }
}

@media screen and (min-width: 750px) {
  .cs-timeline--hide-desktop { display: none !important; }
}

.cs-timeline__sr-only {
  position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
  overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border-width: 0;
}

/* ============================================================================
   CS Transform — TheChill Horizontal Stepper
   ============================================================================ */

.cs-transform {
  --ct-deep-teal: #0D4F47;
  --ct-soft-teal: #108474;
  --ct-warm-gold: #C4973B;
  --ct-text-primary: #1a1a1a;
  --ct-text-secondary: #6B6B6B;
  --ct-card-bg: #ffffff;
  --ct-science-bg: #E8F4F2;
  --ct-pill-bg: rgba(16, 132, 116, 0.1);
  --ct-pill-border: rgba(16, 132, 116, 0.25);
}

/* --------------------------------------------------------------------------
   Section Root
   -------------------------------------------------------------------------- */
.cs-transform {
  background: linear-gradient(180deg, #f9f6f2 0%, #f0ebe4 100%);
  color: var(--ct-text-primary);
  padding-block: var(--cs-space-3xl) var(--cs-space-2xl);
  overflow: hidden;
  position: relative;
}

.cs-transform__kicker { color: var(--ct-deep-teal); }
.cs-transform__title { color: var(--ct-text-primary); }
.cs-transform__subtitle { color: var(--ct-text-secondary); }

/* --------------------------------------------------------------------------
   Stepper Bar
   -------------------------------------------------------------------------- */
.cs-transform__stepper {
  margin-block-end: var(--cs-space-xl);
}

.cs-transform__stepper-track {
  display: flex;
  justify-content: space-between;
  position: relative;
  max-width: 640px;
  margin-inline: auto;
}

/* Rail behind steps */
.cs-transform__stepper-rail {
  position: absolute;
  top: 14px;
  left: 0;
  right: 0;
  height: 2px;
  background: rgba(0, 0, 0, 0.07);
  z-index: 0;
  border-radius: 1px;
}

.cs-transform__stepper-fill {
  position: absolute;
  top: 0;
  left: 0;
  height: 100%;
  width: 0%;
  background: linear-gradient(90deg, var(--ct-deep-teal), var(--ct-warm-gold));
  border-radius: 1px;
  transition: width 600ms var(--cs-ease-out);
}

/* Step button */
.cs-transform__step {
  position: relative;
  z-index: var(--cs-z-base);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--cs-space-xs);
  background: none;
  border: none;
  padding: 0;
  cursor: pointer;
  font-family: var(--cs-font-family);
  -webkit-tap-highlight-color: transparent;
  outline-offset: 4px;
}

.cs-transform__step:focus-visible {
  outline: 2px solid var(--ct-deep-teal);
  border-radius: var(--cs-radius-sm);
}

/* Node circle */
.cs-transform__step-node {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 28px;
  height: 28px;
  border-radius: var(--cs-radius-full);
  border: 2px solid rgba(0, 0, 0, 0.12);
  background: var(--ct-card-bg);
  font-size: 11px;
  font-weight: 700;
  color: var(--ct-text-secondary);
  transition:
    background 500ms var(--cs-ease-out),
    border-color 500ms var(--cs-ease-out),
    color 500ms var(--cs-ease-out),
    box-shadow 500ms var(--cs-ease-out),
    transform 500ms var(--cs-ease-out);
}

.cs-transform__step--active .cs-transform__step-node {
  background: var(--ct-warm-gold);
  border-color: var(--ct-warm-gold);
  color: #fff;
  box-shadow: 0 0 0 4px rgba(196, 151, 59, 0.15), 0 2px 8px rgba(196, 151, 59, 0.25);
  transform: scale(1.08);
}

.cs-transform__step--completed .cs-transform__step-node {
  background: var(--ct-deep-teal);
  border-color: var(--ct-deep-teal);
  color: #fff;
}

/* Step label */
.cs-transform__step-label {
  font-size: var(--cs-font-size-xs);
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--ct-text-secondary);
  transition: color 400ms var(--cs-ease-out);
  white-space: nowrap;
}

.cs-transform__step--active .cs-transform__step-label {
  color: var(--ct-deep-teal);
}

.cs-transform__step--completed .cs-transform__step-label {
  color: var(--ct-deep-teal);
}

/* --------------------------------------------------------------------------
   Detail Panels — grid overlay for crossfade
   -------------------------------------------------------------------------- */
.cs-transform__details {
  display: grid;
  grid-template-columns: 1fr;
  grid-template-rows: 1fr;
}

.cs-transform__detail {
  grid-area: 1 / 1;
  opacity: 0;
  visibility: hidden;
  transition: opacity 500ms var(--cs-ease-out), visibility 0s 500ms;
  pointer-events: none;
}

.cs-transform__detail--active {
  opacity: 1;
  visibility: visible;
  transition: opacity 500ms var(--cs-ease-out), visibility 0s 0s;
  pointer-events: auto;
}

/* Inner grid: illustration left, content right */
.cs-transform__detail-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--cs-space-xl);
  align-items: center;
  max-width: 1040px;
  margin-inline: auto;
}

@media screen and (min-width: 750px) {
  .cs-transform__detail-grid {
    grid-template-columns: 340px 1fr;
    gap: var(--cs-space-2xl);
  }
}

@media screen and (min-width: 990px) {
  .cs-transform__detail-grid {
    grid-template-columns: 380px 1fr;
  }
}

/* --------------------------------------------------------------------------
   Illustration Frame
   -------------------------------------------------------------------------- */
.cs-transform__detail-visual {
  display: flex;
  justify-content: center;
}

.cs-transform__illust-frame {
  width: 220px;
  height: 220px;
  border-radius: var(--cs-radius-full);
  background: rgba(13, 79, 71, 0.025);
  border: 1px solid rgba(13, 79, 71, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  animation: ct-float 5s ease-in-out infinite;
}

.cs-transform__illust-svg {
  width: 88%;
  height: 88%;
}

@keyframes ct-float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-6px); }
}

@media screen and (min-width: 750px) {
  .cs-transform__illust-frame {
    width: 300px;
    height: 300px;
  }
}

@media screen and (min-width: 990px) {
  .cs-transform__illust-frame {
    width: 340px;
    height: 340px;
  }
}

/* --------------------------------------------------------------------------
   Detail Content
   -------------------------------------------------------------------------- */
.cs-transform__detail-content {
  min-width: 0;
}

.cs-transform__detail-headline {
  font-size: var(--cs-font-size-xl);
  font-weight: 700;
  color: var(--ct-text-primary);
  margin: 0 0 var(--cs-space-md);
  line-height: 1.2;
  letter-spacing: -0.02em;
}

/* Benefits */
.cs-transform__benefits {
  list-style: none;
  padding: 0;
  margin: 0 0 var(--cs-space-md);
  display: flex;
  flex-direction: column;
  gap: var(--cs-space-sm);
}

.cs-transform__benefit {
  display: flex;
  align-items: baseline;
  gap: var(--cs-space-sm);
  flex-wrap: wrap;
}

.cs-transform__benefit::before {
  content: '';
  width: 5px;
  height: 5px;
  border-radius: var(--cs-radius-full);
  background: var(--ct-soft-teal);
  flex-shrink: 0;
  margin-top: 0.55em;
  align-self: flex-start;
}

.cs-transform__benefit-text {
  font-size: var(--cs-font-size-sm);
  color: var(--ct-text-secondary);
  line-height: 1.55;
  flex: 1;
  min-width: 0;
}

.cs-transform__ingredient-pill {
  display: inline-flex;
  align-items: center;
  font-size: 10px;
  font-weight: 700;
  padding: 0.2em 0.6em;
  border-radius: var(--cs-radius-full);
  background: var(--ct-pill-bg);
  color: var(--ct-soft-teal);
  border: 1px solid var(--ct-pill-border);
  white-space: nowrap;
  flex-shrink: 0;
  letter-spacing: 0.02em;
  text-transform: uppercase;
}

/* Science Callout */
.cs-transform__science-callout {
  background: var(--ct-science-bg);
  border-radius: var(--cs-radius-md);
  padding: var(--cs-space-md);
  margin-block-start: var(--cs-space-xs);
}

.cs-transform__science-label {
  display: block;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--ct-deep-teal);
  margin-block-end: var(--cs-space-xs);
}

.cs-transform__science-text {
  font-size: var(--cs-font-size-sm);
  font-style: italic;
  color: var(--ct-text-secondary);
  line-height: 1.5;
  margin: 0;
}

.cs-transform__science-ref {
  display: block;
  font-size: 10px;
  color: var(--ct-soft-teal);
  margin-block-start: 6px;
  font-style: normal;
  opacity: 0.8;
}

/* --------------------------------------------------------------------------
   CTA
   -------------------------------------------------------------------------- */
.cs-transform__cta-wrap {
  margin-block-start: var(--cs-space-lg);
}

.cs-transform__cta {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5em;
  font-family: var(--cs-font-family);
  font-size: var(--cs-font-size-sm);
  font-weight: 600;
  letter-spacing: 0.04em;
  text-decoration: none;
  padding: 0.875em 2em;
  border-radius: 3.75rem;
  border: none;
  cursor: pointer;
  min-height: 44px;
  min-width: 44px;
  background: var(--ct-deep-teal);
  color: #ffffff;
  transition:
    background var(--cs-duration-fast) var(--cs-ease-out),
    transform var(--cs-duration-fast) var(--cs-ease-out),
    box-shadow var(--cs-duration-fast) var(--cs-ease-out);
}

.cs-transform__cta:hover {
  background: var(--ct-soft-teal);
  transform: translateY(-1px);
  box-shadow: 0 4px 16px rgba(13, 79, 71, 0.2);
}

.cs-transform__cta:active {
  transform: translateY(0);
}

/* --------------------------------------------------------------------------
   Mobile Overrides (< 750px)
   -------------------------------------------------------------------------- */
@media screen and (max-width: 749px) {
  .cs-transform__stepper-track {
    max-width: 100%;
    gap: 0;
  }

  .cs-transform__step {
    flex: 1;
    min-width: 0;
  }

  .cs-transform__step-label {
    font-size: 9px;
    letter-spacing: 0.03em;
    text-align: center;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
  }

  .cs-transform__step-node {
    width: 24px;
    height: 24px;
    font-size: 10px;
  }

  .cs-transform__detail-content {
    text-align: left;
  }

  .cs-transform__detail-headline {
    font-size: var(--cs-font-size-lg);
  }
}

/* --------------------------------------------------------------------------
   Reduced Motion
   -------------------------------------------------------------------------- */
@media (prefers-reduced-motion: reduce) {
  .cs-transform__reveal,
  .cs-transform__detail,
  .cs-transform__detail--active,
  .cs-transform__step-node,
  .cs-transform__step-label,
  .cs-transform__stepper-fill,
  .cs-transform__cta,
  .cs-transform__illust-frame {
    transition: none !important;
    animation: none !important;
  }

  .cs-transform__reveal {
    opacity: 1;
  }
}
</style>

<script>
/* ============================================================================
   CS Timeline — Shared Utilities (inlined)
   ============================================================================ */

function csTimelineReveal(selector, options = {}) {
  const {
    threshold = 0.15,
    rootMargin = '0px 0px -60px 0px',
    once = true,
    onReveal = null
  } = options;

  const elements = document.querySelectorAll(selector);
  if (!elements.length) return null;

  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    elements.forEach((el) => {
      el.classList.add('cs-transform__reveal--visible');
      if (onReveal) onReveal(el);
    });
    return null;
  }

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('cs-transform__reveal--visible');
          if (onReveal) onReveal(entry.target);
          if (once) observer.unobserve(entry.target);
        }
      });
    },
    { threshold, rootMargin }
  );

  elements.forEach((el) => observer.observe(el));
  return observer;
}

/* ============================================================================
   CS Transform Timeline — Web Component
   ============================================================================ */

class CsTransformTimeline extends HTMLElement {
  constructor() {
    super();
    this._observer = null;
    this._activeIndex = 0;
    this._onKeydown = this._onKeydown.bind(this);
  }

  connectedCallback() {
    this._initReveal();
    this._initStepper();
  }

  disconnectedCallback() {
    if (this._observer) {
      this._observer.disconnect();
      this._observer = null;
    }
    const tablist = this.querySelector('[role="tablist"]');
    if (tablist) tablist.removeEventListener('keydown', this._onKeydown);
  }

  _initReveal() {
    this._observer = csTimelineReveal(
      '.cs-transform .cs-transform__reveal',
      { threshold: 0.2, rootMargin: '0px 0px -40px 0px', once: true }
    );
  }

  _initStepper() {
    const steps = this.querySelectorAll('[data-cs-step]');
    const tablist = this.querySelector('[role="tablist"]');
    if (!steps.length || !tablist) return;

    steps.forEach((step) => {
      step.addEventListener('click', () => {
        const idx = parseInt(step.dataset.csStep, 10);
        this._goToStep(idx);
      });
    });

    tablist.addEventListener('keydown', this._onKeydown);
  }

  _onKeydown(e) {
    const steps = [...this.querySelectorAll('[data-cs-step]')];
    const total = steps.length;
    if (!total) return;

    let next = this._activeIndex;
    if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
      next = (this._activeIndex + 1) % total;
      e.preventDefault();
    } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
      next = (this._activeIndex - 1 + total) % total;
      e.preventDefault();
    } else if (e.key === 'Home') {
      next = 0;
      e.preventDefault();
    } else if (e.key === 'End') {
      next = total - 1;
      e.preventDefault();
    } else {
      return;
    }

    this._goToStep(next);
    steps[next].focus();
  }

  _goToStep(index) {
    const steps = this.querySelectorAll('[data-cs-step]');
    const panels = this.querySelectorAll('[data-cs-detail]');
    const fill = this.querySelector('[data-cs-stepper-fill]');
    const total = steps.length;
    if (index < 0 || index >= total) return;

    /* Update steps */
    steps.forEach((step, i) => {
      const isActive = i === index;
      const isCompleted = i < index;
      step.classList.toggle('cs-transform__step--active', isActive);
      step.classList.toggle('cs-transform__step--completed', isCompleted);
      step.setAttribute('aria-selected', isActive ? 'true' : 'false');
      step.setAttribute('tabindex', isActive ? '0' : '-1');
    });

    /* Update panels */
    panels.forEach((panel, i) => {
      const isActive = i === index;
      panel.classList.toggle('cs-transform__detail--active', isActive);
      panel.setAttribute('aria-hidden', isActive ? 'false' : 'true');
    });

    /* Update progress fill */
    if (fill && total > 1) {
      fill.style.width = (index / (total - 1)) * 100 + '%';
    }

    this._activeIndex = index;
  }
}

if (!customElements.get('cs-transform-timeline')) {
  customElements.define('cs-transform-timeline', CsTransformTimeline);
}
</script>

