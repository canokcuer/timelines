  line-height: 1.5;
}

.cs-transform__ingredient-pill {
  display: inline-flex;
  align-items: center;
  font-size: var(--cs-font-size-xs);
  font-weight: 600;
  padding: 0.2em 0.65em;
  border-radius: var(--cs-radius-full);
  background: var(--ct-pill-bg);
  color: var(--ct-soft-teal);
  border: 1px solid var(--ct-pill-border);
  white-space: nowrap;
  flex-shrink: 0;
}

/* --------------------------------------------------------------------------
