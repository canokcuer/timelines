  justify-content: center;
  align-items: center;
}

.cs-transform__illust-circle {
  width: 140px;
  height: 140px;
  border-radius: var(--cs-radius-full);
  background: rgba(13, 79, 71, 0.04);
  border: 1px solid rgba(13, 79, 71, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.cs-transform__illust-svg {
  width: 80%;
  height: 80%;
}

/* --------------------------------------------------------------------------
   Desktop Layout (>= 750px) — 3-column alternating spine
   -------------------------------------------------------------------------- */
@media screen and (min-width: 750px) {
  .cs-transform__panel {
    grid-template-columns: 1fr 48px 1fr;
    grid-template-rows: 1fr;
    gap: var(--cs-space-xl);
    padding-inline: var(--cs-space-lg);
  }

  .cs-transform__node-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    grid-column: 2;
    grid-row: 1;
    z-index: var(--cs-z-above);
  }

  /* Left-aligned: card left, illustration right */
  .cs-transform__panel--left .cs-transform__card {
    grid-column: 1;
    grid-row: 1;
    justify-self: end;
    max-width: 460px;
  }

  .cs-transform__panel--left .cs-transform__illust {
    grid-column: 3;
    grid-row: 1;
    justify-self: start;
  }

  /* Right-aligned: illustration left, card right */
  .cs-transform__panel--right .cs-transform__illust {
    grid-column: 1;
    grid-row: 1;
    justify-self: end;
  }

  .cs-transform__panel--right .cs-transform__card {
    grid-column: 3;
    grid-row: 1;
    justify-self: start;
    max-width: 460px;
  }

  .cs-transform__illust-circle {
    width: 180px;
    height: 180px;
  }
}

/* --------------------------------------------------------------------------
   Mobile Layout (< 750px) — single column, spine on left
   -------------------------------------------------------------------------- */
@media screen and (max-width: 749px) {
  .cs-transform__body {
    padding-inline-start: 40px;
  }

  /* Mobile spine line on left edge */
  .cs-transform__body::before {
    content: '';
    position: absolute;
    left: 28px;
    top: 0;
    bottom: 0;
    width: var(--ct-spine-width);
    background: linear-gradient(180deg, var(--ct-deep-teal), var(--ct-warm-gold));
    opacity: 0.3;
  }

  .cs-transform__panel {
    grid-template-columns: 1fr;
    padding-block: var(--cs-space-lg);
    gap: var(--cs-space-md);
    position: relative;
  }

  /* Mobile node — positioned on left spine */
  .cs-transform__node-wrap {
    display: block;
    position: absolute;
    left: -28px;
    top: var(--cs-space-lg);
    transform: translateX(-50%);
  }

  .cs-transform__time-badge {
    display: none;
  }

  /* Show time label above headline on mobile via data attribute */
  .cs-transform__card-headline::before {
    content: attr(data-time-label);
    display: block;
    font-size: var(--cs-font-size-xs);
    font-weight: 700;
    color: var(--ct-deep-teal);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-block-end: var(--cs-space-xs);
  }
}

/* --------------------------------------------------------------------------
   Reduced Motion — section-specific overrides
   -------------------------------------------------------------------------- */
@media (prefers-reduced-motion: reduce) {
  .cs-transform__node {
    background: var(--ct-warm-gold) !important;
    box-shadow: 0 0 16px rgba(196, 151, 59, 0.3) !important;
  }

  .cs-transform__spine-line {
    stroke-dashoffset: 0 !important;
  }

  @keyframes cs-transform-pulse {
    0%, 50%, 100% { transform: scale(1); }
  }
}
