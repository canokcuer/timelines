                        <line x1="0" y1="-12" x2="0" y2="14" stroke="#0D4F47" stroke-width="0.35" opacity="0.18"/>
                        <line x1="0" y1="0" x2="8" y2="-4" stroke="#0D4F47" stroke-width="0.3" opacity="0.12"/>
                        <line x1="0" y1="4" x2="-7" y2="0" stroke="#0D4F47" stroke-width="0.3" opacity="0.12"/>
                      </g>
                      <g transform="translate(49,164)">
                        <polygon points="0,-13 11,-6.5 11,6.5 0,13 -11,6.5 -11,-6.5" stroke="#C4973B" stroke-width="1" opacity="0.42" fill="#C4973B" fill-opacity="0.04"/>
