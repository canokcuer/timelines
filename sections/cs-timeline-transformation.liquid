                      <circle cx="205" cy="170" r="2" fill="#C4973B" opacity="0.1"/>
                      <circle cx="120" cy="218" r="2" fill="#0D4F47" opacity="0.1"/>
                      <circle cx="35" cy="170" r="2" fill="#C4973B" opacity="0.1"/>
                      <circle cx="35" cy="70" r="2" fill="#C4973B" opacity="0.1"/>
                    </svg>

                  {%- else -%}
                    <svg class="cs-transform__illust-svg" viewBox="0 0 240 240" fill="none" aria-hidden="true" focusable="false">
                      <circle cx="120" cy="120" r="60" stroke="#0D4F47" stroke-width="1" opacity="0.15"/>
                      <circle cx="120" cy="120" r="8" fill="#C4973B" opacity="0.2"/>
                    </svg>
                {%- endcase -%}
              </div>

              {%- comment -%} Headline {%- endcomment -%}
              <h3 class="cs-transform__slide-headline">
                {{ block.settings.headline }}
              </h3>

              {%- comment -%} Ingredient Pills {%- endcomment -%}
              {%- if block.settings.ingredient_pills != blank -%}
                <div class="cs-transform__pills" aria-label="Bileşenler">
                  {%- assign pills = block.settings.ingredient_pills | split: ',' -%}
                  {%- for pill in pills -%}
                    {%- assign trimmed = pill | strip -%}
                    {%- if trimmed != blank -%}
                      <span class="cs-transform__pill">{{ trimmed }}</span>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              {%- endif -%}

              {%- comment -%} Storytelling {%- endcomment -%}
              {%- if block.settings.storytelling != blank -%}
                <p class="cs-transform__story">
                  {{ block.settings.storytelling }}
                </p>
              {%- endif -%}

              {%- comment -%} Science Callout {%- endcomment -%}
              {%- if block.settings.science_text != blank -%}
                <div class="cs-transform__science">
                  <span class="cs-transform__science-icon" aria-hidden="true">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                      <path d="M6 2v4L4 9v1h8V9l-2-3V2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                      <path d="M4 13h8" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                      <circle cx="8" cy="9" r="1" fill="currentColor"/>
                    </svg>
                  </span>
                  <div>
                    <p class="cs-transform__science-text">{{ block.settings.science_text }}</p>
                    {%- if block.settings.science_pmid != blank -%}
                      <cite class="cs-transform__science-ref">
                        PMID: {{ block.settings.science_pmid }}
                      </cite>
                    {%- endif -%}
                  </div>
                </div>
              {%- endif -%}

              {%- comment -%} CTA Button {%- endcomment -%}
              <div class="cs-transform__cta-wrap">
                {%- assign product = section.settings.product -%}
                {%- if product != blank and product.available -%}
                  <button
                    type="button"
                    class="cs-transform__cta"
                    data-cs-add-to-cart
                    data-variant-id="{{ product.selected_or_first_available_variant.id }}"
                    data-cart-quantity="{{ block.settings.cart_quantity | default: 1 }}"
                    aria-label="Yolculuğuna Başla — {{ block.settings.cart_quantity | default: 1 }} adet sepete ekle"
                  >
                    Yolculuğuna Başla
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" focusable="false">
                      <path d="M3.333 8h9.334M8.667 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </button>
                {%- elsif product != blank -%}
                  <a
                    href="{{ product.url }}"
                    class="cs-transform__cta"
                    aria-label="Yolculuğuna Başla — Ürün sayfasına git"
                  >
                    Yolculuğuna Başla
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" focusable="false">
                      <path d="M3.333 8h9.334M8.667 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </a>
                {%- else -%}
                  <a
                    href="{{ section.settings.cta_url | default: '#' }}"
                    class="cs-transform__cta"
                    aria-label="Yolculuğuna Başla"
                  >
                    Yolculuğuna Başla
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" focusable="false">
                      <path d="M3.333 8h9.334M8.667 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </a>
                {%- endif -%}
              </div>

            </div>
          </div>
        {%- endfor -%}
      </div>

      {%- comment -%} ── Navigation ─────────────────────────────── {%- endcomment -%}
      <div class="cs-transform__nav">
        <button
          type="button"
          class="cs-transform__arrow cs-transform__arrow--prev"
          aria-label="Önceki adım"
          data-cs-prev
          disabled
        >
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true" focusable="false">
            <path d="M12.5 15l-5-5 5-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>

        <div class="cs-transform__dots" role="tablist" aria-label="Slayt seçimi">
          {%- for block in section.blocks -%}
            <button
              type="button"
              class="cs-transform__dot{% if forloop.first %} cs-transform__dot--active{% endif %}"
              role="tab"
              aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
              aria-label="Slayt {{ forloop.index }}: {{ block.settings.time_label }}"
              data-cs-dot="{{ forloop.index0 }}"
              tabindex="{% if forloop.first %}0{% else %}-1{% endif %}"
            ></button>
          {%- endfor -%}
        </div>

        <button
          type="button"
          class="cs-transform__arrow cs-transform__arrow--next"
          aria-label="Sonraki adım"
          data-cs-next
        >
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true" focusable="false">
            <path d="M7.5 5l5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>

    </div>

  </div>
</section>
</cs-transform-timeline>

<style>
/* ============================================================================
   CS Timeline Base — Design Tokens & Shared Utilities
   ============================================================================ */

:root {
  --cs-gold: #FFDF00;
  --cs-gold-soft: rgba(255, 223, 0, 0.15);
  --cs-gold-medium: rgba(255, 223, 0, 0.4);
  --cs-teal: #108474;
  --cs-teal-soft: rgba(16, 132, 116, 0.15);
  --cs-teal-medium: rgba(16, 132, 116, 0.4);
  --cs-indigo: #3B3073;
  --cs-indigo-soft: rgba(59, 48, 115, 0.15);

  --cs-bg-dark: #171717;
  --cs-bg-deep: #0a0a0a;
  --cs-bg-warm: #f9f6f2;
  --cs-bg-white: #ffffff;
  --cs-bg-card-dark: rgba(255, 255, 255, 0.04);
  --cs-bg-card-frost: rgba(255, 255, 255, 0.06);

  --cs-text-white: #ffffff;
  --cs-text-white-muted: rgba(255, 255, 255, 0.7);
  --cs-text-white-subtle: rgba(255, 255, 255, 0.5);
  --cs-text-dark: #171717;
  --cs-text-dark-muted: rgba(23, 23, 23, 0.7);
  --cs-text-dark-subtle: rgba(23, 23, 23, 0.5);

  --cs-border-light: rgba(255, 255, 255, 0.08);
  --cs-border-gold: rgba(255, 223, 0, 0.3);
  --cs-border-teal: rgba(16, 132, 116, 0.3);

  --cs-font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  --cs-font-size-xs: clamp(0.6875rem, 0.625rem + 0.25vw, 0.75rem);
  --cs-font-size-sm: clamp(0.75rem, 0.6875rem + 0.25vw, 0.875rem);
  --cs-font-size-base: clamp(0.875rem, 0.8125rem + 0.25vw, 1rem);
  --cs-font-size-md: clamp(1rem, 0.9375rem + 0.25vw, 1.125rem);
  --cs-font-size-lg: clamp(1.125rem, 1rem + 0.5vw, 1.375rem);
  --cs-font-size-xl: clamp(1.375rem, 1.125rem + 1vw, 1.75rem);
  --cs-font-size-2xl: clamp(1.75rem, 1.375rem + 1.5vw, 2.5rem);
  --cs-font-size-3xl: clamp(2rem, 1.5rem + 2vw, 3rem);

  --cs-space-xs: clamp(0.25rem, 0.125rem + 0.5vw, 0.5rem);
  --cs-space-sm: clamp(0.5rem, 0.375rem + 0.5vw, 0.75rem);
  --cs-space-md: clamp(0.75rem, 0.5rem + 1vw, 1.25rem);
  --cs-space-lg: clamp(1.25rem, 0.875rem + 1.5vw, 2rem);
  --cs-space-xl: clamp(2rem, 1.25rem + 3vw, 3.5rem);
  --cs-space-2xl: clamp(3rem, 2rem + 4vw, 5rem);
  --cs-space-3xl: clamp(4rem, 2.5rem + 6vw, 7.5rem);

  --cs-radius-sm: 4px;
  --cs-radius-md: 8px;
  --cs-radius-lg: 12px;
  --cs-radius-xl: 16px;
  --cs-radius-full: 9999px;

  --cs-shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.12);
  --cs-shadow-md: 0 4px 12px rgba(0, 0, 0, 0.15);
  --cs-shadow-lg: 0 8px 30px rgba(0, 0, 0, 0.2);
  --cs-shadow-gold: 0 0 20px rgba(255, 223, 0, 0.15);
  --cs-shadow-teal: 0 0 20px rgba(16, 132, 116, 0.15);

  --cs-ease-out: cubic-bezier(0.16, 1, 0.3, 1);
  --cs-ease-in-out: cubic-bezier(0.65, 0, 0.35, 1);
  --cs-duration-fast: 200ms;
  --cs-duration-base: 400ms;
  --cs-duration-slow: 600ms;
  --cs-duration-draw: 1200ms;

  --cs-z-base: 1;
  --cs-z-above: 10;
  --cs-z-sticky: 100;
  --cs-z-overlay: 200;
  --cs-z-modal: 300;

  --cs-content-max: 1200px;
  --cs-content-narrow: 640px;
  --cs-mobile-dock-clearance: 95px;
}

/* --------------------------------------------------------------------------
   Base Reset
   -------------------------------------------------------------------------- */
.cs-timeline {
  font-family: var(--cs-font-family);
  line-height: 1.6;
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

.cs-timeline *,
.cs-timeline *::before,
.cs-timeline *::after {
  box-sizing: inherit;
}

.cs-timeline__container {
  width: 100%;
  max-width: var(--cs-content-max);
  margin-inline: auto;
  padding-inline: var(--cs-space-md);
}

/* --------------------------------------------------------------------------
   Section Header (shared)
   -------------------------------------------------------------------------- */
.cs-timeline__header {
  text-align: center;
  margin-block-end: var(--cs-space-xl);
}

.cs-timeline__kicker {
  display: inline-block;
  font-size: var(--cs-font-size-xs);
  font-weight: 600;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  margin-block-end: var(--cs-space-sm);
}

.cs-timeline__title {
  font-size: var(--cs-font-size-2xl);
  font-weight: 700;
  letter-spacing: -0.03em;
  line-height: 1.12;
  margin: 0 0 var(--cs-space-md);
}

.cs-timeline__subtitle {
  font-size: var(--cs-font-size-md);
  line-height: 1.5;
  max-width: 540px;
  margin-inline: auto;
}

/* --------------------------------------------------------------------------
   Calming Reveal
   -------------------------------------------------------------------------- */
.cs-transform__reveal {
  opacity: 0;
  transition: opacity 800ms var(--cs-ease-out);
}

.cs-transform__reveal--visible {
  opacity: 1;
}

/* --------------------------------------------------------------------------
   Responsive Utilities
   -------------------------------------------------------------------------- */
@media screen and (max-width: 749px) {
  .cs-timeline--hide-mobile { display: none !important; }
  .cs-timeline { padding-block-end: var(--cs-mobile-dock-clearance); }
}

@media screen and (min-width: 750px) {
  .cs-timeline--hide-desktop { display: none !important; }
}

.cs-timeline__sr-only {
  position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
  overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border-width: 0;
}

/* ============================================================================
   CS Transform — Swipeable Carousel
   ============================================================================ */

.cs-transform {
  --ct-deep-teal: #0D4F47;
  --ct-soft-teal: #108474;
  --ct-warm-gold: #C4973B;
  --ct-text-primary: #1a1a1a;
  --ct-text-secondary: #6B6B6B;
  --ct-card-bg: #ffffff;
  --ct-science-bg: #E8F4F2;
  --ct-pill-bg: rgba(16, 132, 116, 0.1);
  --ct-pill-border: rgba(16, 132, 116, 0.25);
}

/* --------------------------------------------------------------------------
   Section Root
   -------------------------------------------------------------------------- */
.cs-transform {
  background: linear-gradient(180deg, #f9f6f2 0%, #f0ebe4 100%);
  color: var(--ct-text-primary);
  padding-block: var(--cs-space-3xl) var(--cs-space-2xl);
  overflow: hidden;
  position: relative;
}

.cs-transform__kicker { color: var(--ct-deep-teal); }
.cs-transform__title { color: var(--ct-text-primary); }
.cs-transform__subtitle { color: var(--ct-text-secondary); }

/* --------------------------------------------------------------------------
   Carousel Wrapper
   -------------------------------------------------------------------------- */
.cs-transform__carousel {
  position: relative;
  max-width: 900px;
  margin-inline: auto;
}

/* --------------------------------------------------------------------------
   Scroll-Snap Track
   -------------------------------------------------------------------------- */
.cs-transform__track {
  display: flex;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
  scroll-behavior: smooth;
  gap: 0;
}

/* Hide scrollbar */
.cs-transform__track::-webkit-scrollbar {
  display: none;
}

.cs-transform__track {
  scrollbar-width: none;
  -ms-overflow-style: none;
}

/* --------------------------------------------------------------------------
   Slide
   -------------------------------------------------------------------------- */
.cs-transform__slide {
  flex: 0 0 100%;
  scroll-snap-align: center;
  min-width: 0;
}

.cs-transform__slide-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  max-width: 640px;
  margin-inline: auto;
  padding: var(--cs-space-lg) var(--cs-space-md);
}

/* --------------------------------------------------------------------------
   Time Badge
   -------------------------------------------------------------------------- */
.cs-transform__time-badge {
  display: inline-flex;
  align-items: center;
  font-size: var(--cs-font-size-xs);
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--ct-deep-teal);
  background: var(--ct-card-bg);
  border: 1px solid rgba(0, 0, 0, 0.08);
  border-left: 3px solid var(--ct-warm-gold);
  border-radius: var(--cs-radius-full);
  padding: 0.4em 1.2em 0.4em 1em;
  margin-block-end: var(--cs-space-lg);
  box-shadow: var(--cs-shadow-sm);
}

/* --------------------------------------------------------------------------
   Illustration Frame (carousel version)
   -------------------------------------------------------------------------- */
.cs-transform__illust-frame {
  width: 200px;
  height: 200px;
  border-radius: var(--cs-radius-full);
  background: rgba(13, 79, 71, 0.025);
  border: 1px solid rgba(13, 79, 71, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-block-end: var(--cs-space-lg);
  animation: ct-float 5s ease-in-out infinite;
}

.cs-transform__illust-svg {
  width: 88%;
  height: 88%;
}

@keyframes ct-float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-6px); }
}

@media screen and (min-width: 750px) {
  .cs-transform__illust-frame {
    width: 260px;
    height: 260px;
  }
}

/* --------------------------------------------------------------------------
   Slide Headline
   -------------------------------------------------------------------------- */
.cs-transform__slide-headline {
  font-size: var(--cs-font-size-xl);
  font-weight: 700;
  color: var(--ct-text-primary);
  margin: 0 0 var(--cs-space-md);
  line-height: 1.2;
  letter-spacing: -0.02em;
}

/* --------------------------------------------------------------------------
   Ingredient Pills
   -------------------------------------------------------------------------- */
.cs-transform__pills {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: var(--cs-space-xs);
  margin-block-end: var(--cs-space-md);
}

.cs-transform__pill {
  display: inline-flex;
  align-items: center;
  font-size: 11px;
  font-weight: 700;
  padding: 0.3em 0.8em;
  border-radius: var(--cs-radius-full);
  background: var(--ct-pill-bg);
  color: var(--ct-soft-teal);
  border: 1px solid var(--ct-pill-border);
  white-space: nowrap;
  letter-spacing: 0.02em;
  text-transform: uppercase;
}

/* --------------------------------------------------------------------------
   Storytelling Paragraph
   -------------------------------------------------------------------------- */
.cs-transform__story {
  font-size: var(--cs-font-size-sm);
  color: var(--ct-text-secondary);
  line-height: 1.65;
  margin: 0 0 var(--cs-space-md);
  max-width: 520px;
}

/* --------------------------------------------------------------------------
   Science Callout
   -------------------------------------------------------------------------- */
.cs-transform__science {
  display: flex;
  align-items: flex-start;
  gap: var(--cs-space-sm);
  background: var(--ct-science-bg);
  border-radius: var(--cs-radius-md);
  border-left: 3px solid var(--ct-soft-teal);
  padding: var(--cs-space-md);
  margin-block-end: var(--cs-space-lg);
  text-align: left;
  max-width: 520px;
}

.cs-transform__science-icon {
  flex-shrink: 0;
  color: var(--ct-soft-teal);
  margin-top: 2px;
}

.cs-transform__science-text {
  font-size: var(--cs-font-size-sm);
  font-style: italic;
  color: var(--ct-text-secondary);
  line-height: 1.5;
  margin: 0;
}

.cs-transform__science-ref {
  display: block;
  font-size: 10px;
  color: var(--ct-soft-teal);
  margin-block-start: 6px;
  font-style: normal;
  opacity: 0.8;
  font-weight: 600;
}

/* --------------------------------------------------------------------------
   CTA Button
   -------------------------------------------------------------------------- */
.cs-transform__cta-wrap {
  width: 100%;
  display: flex;
  justify-content: center;
}

.cs-transform__cta {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5em;
  font-family: var(--cs-font-family);
  font-size: var(--cs-font-size-sm);
  font-weight: 600;
  letter-spacing: 0.04em;
  text-decoration: none;
  padding: 0.875em 2em;
  border-radius: 3.75rem;
  border: none;
  cursor: pointer;
  min-height: 44px;
  min-width: 44px;
  background: var(--ct-deep-teal);
  color: #ffffff;
  transition:
    background var(--cs-duration-fast) var(--cs-ease-out),
    transform var(--cs-duration-fast) var(--cs-ease-out),
    box-shadow var(--cs-duration-fast) var(--cs-ease-out);
}

.cs-transform__cta:hover {
  background: var(--ct-soft-teal);
  transform: translateY(-1px);
  box-shadow: 0 4px 16px rgba(13, 79, 71, 0.2);
}

.cs-transform__cta:active {
  transform: translateY(0);
}

.cs-transform__cta[disabled] {
  opacity: 0.6;
  cursor: not-allowed;
}

/* --------------------------------------------------------------------------
   Navigation — Arrows + Dots
   -------------------------------------------------------------------------- */
.cs-transform__nav {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--cs-space-md);
  margin-block-start: var(--cs-space-lg);
}

/* Arrow Buttons */
.cs-transform__arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  border-radius: var(--cs-radius-full);
  background: var(--ct-deep-teal);
  color: #ffffff;
  border: none;
  cursor: pointer;
  flex-shrink: 0;
  transition:
    background var(--cs-duration-fast) var(--cs-ease-out),
    opacity var(--cs-duration-fast) var(--cs-ease-out),
    transform var(--cs-duration-fast) var(--cs-ease-out);
}

.cs-transform__arrow:hover:not([disabled]) {
  background: var(--ct-soft-teal);
  transform: scale(1.05);
}

.cs-transform__arrow[disabled] {
  opacity: 0.3;
  cursor: default;
}

.cs-transform__arrow:focus-visible {
  outline: 2px solid var(--ct-deep-teal);
  outline-offset: 2px;
}

/* Dot Pagination */
.cs-transform__dots {
  display: flex;
  align-items: center;
  gap: 10px;
}

.cs-transform__dot {
  width: 10px;
  height: 10px;
  border-radius: var(--cs-radius-full);
  border: 2px solid var(--ct-text-secondary);
  background: transparent;
  padding: 0;
  cursor: pointer;
  transition:
    background var(--cs-duration-fast) var(--cs-ease-out),
    border-color var(--cs-duration-fast) var(--cs-ease-out),
    transform var(--cs-duration-fast) var(--cs-ease-out);
}

.cs-transform__dot--active {
  background: var(--ct-warm-gold);
  border-color: var(--ct-warm-gold);
  transform: scale(1.2);
}

.cs-transform__dot:hover:not(.cs-transform__dot--active) {
  border-color: var(--ct-deep-teal);
}

.cs-transform__dot:focus-visible {
  outline: 2px solid var(--ct-deep-teal);
  outline-offset: 2px;
}

/* --------------------------------------------------------------------------
   Mobile Overrides (< 750px)
   -------------------------------------------------------------------------- */
@media screen and (max-width: 749px) {
  .cs-transform__slide-inner {
    padding-inline: var(--cs-space-sm);
  }

  .cs-transform__slide-headline {
    font-size: var(--cs-font-size-lg);
  }

  .cs-transform__illust-frame {
    width: 180px;
    height: 180px;
  }

  .cs-transform__arrow {
    display: none;
  }

  .cs-transform__story {
    font-size: var(--cs-font-size-xs);
  }

  .cs-transform__science {
    padding: var(--cs-space-sm);
  }

  .cs-transform__science-text {
    font-size: var(--cs-font-size-xs);
  }
}

/* --------------------------------------------------------------------------
   Reduced Motion
   -------------------------------------------------------------------------- */
@media (prefers-reduced-motion: reduce) {
  .cs-transform__reveal,
  .cs-transform__cta,
  .cs-transform__arrow,
  .cs-transform__dot,
  .cs-transform__illust-frame {
    transition: none !important;
    animation: none !important;
  }

  .cs-transform__reveal {
    opacity: 1;
  }

  .cs-transform__track {
    scroll-behavior: auto;
  }
}
</style>

<script>
/* ============================================================================
   CS Timeline — Shared Utilities (inlined)
   ============================================================================ */

function csTimelineReveal(selector, options = {}) {
  const {
    threshold = 0.15,
    rootMargin = '0px 0px -60px 0px',
    once = true,
    onReveal = null
  } = options;

  const elements = document.querySelectorAll(selector);
  if (!elements.length) return null;

  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    elements.forEach((el) => {
      el.classList.add('cs-transform__reveal--visible');
      if (onReveal) onReveal(el);
    });
    return null;
  }

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('cs-transform__reveal--visible');
          if (onReveal) onReveal(entry.target);
          if (once) observer.unobserve(entry.target);
        }
      });
    },
    { threshold, rootMargin }
  );

  elements.forEach((el) => observer.observe(el));
  return observer;
}

/* ============================================================================
   CS Transform Timeline — Swipeable Carousel Web Component
   ============================================================================ */

class CsTransformTimeline extends HTMLElement {
  constructor() {
    super();
    this._observer = null;
    this._activeIndex = 0;
    this._scrollTimeout = null;
    this._onScroll = this._onScroll.bind(this);
    this._onKeydown = this._onKeydown.bind(this);
  }

  connectedCallback() {
    this._track = this.querySelector('[data-cs-track]');
    this._slides = [...this.querySelectorAll('[data-cs-slide]')];
    this._dots = [...this.querySelectorAll('[data-cs-dot]')];
    this._prevBtn = this.querySelector('[data-cs-prev]');
    this._nextBtn = this.querySelector('[data-cs-next]');

    if (!this._track || !this._slides.length) return;

    this._initReveal();
    this._initCarousel();
    this._initCTA();
  }

  disconnectedCallback() {
    if (this._observer) {
      this._observer.disconnect();
      this._observer = null;
    }
    if (this._track) {
      this._track.removeEventListener('scroll', this._onScroll);
    }
    this.removeEventListener('keydown', this._onKeydown);
  }

  /* ── Reveal ─────────────────────────────────────────────────────────── */

  _initReveal() {
    this._observer = csTimelineReveal(
      '.cs-transform .cs-transform__reveal',
      { threshold: 0.2, rootMargin: '0px 0px -40px 0px', once: true }
    );
  }

  /* ── Carousel ───────────────────────────────────────────────────────── */

  _initCarousel() {
    this._track.addEventListener('scroll', this._onScroll, { passive: true });

    if (this._prevBtn) {
      this._prevBtn.addEventListener('click', () => this._onPrev());
    }
    if (this._nextBtn) {
      this._nextBtn.addEventListener('click', () => this._onNext());
    }

    this._dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        const idx = parseInt(dot.dataset.csDot, 10);
        this._goToSlide(idx);
      });
    });

    this.addEventListener('keydown', this._onKeydown);

    this._updateIndicators(0);
  }

  _onScroll() {
    clearTimeout(this._scrollTimeout);
    this._scrollTimeout = setTimeout(() => {
      const slideWidth = this._slides[0].offsetWidth;
      if (slideWidth === 0) return;
      const index = Math.round(this._track.scrollLeft / slideWidth);
      const clamped = Math.max(0, Math.min(index, this._slides.length - 1));
      if (clamped !== this._activeIndex) {
        this._activeIndex = clamped;
        this._updateIndicators(clamped);
      }
    }, 60);
  }

  _goToSlide(index) {
    if (index < 0 || index >= this._slides.length) return;
    const slideWidth = this._slides[0].offsetWidth;
    this._track.scrollTo({ left: index * slideWidth, behavior: 'smooth' });
    this._activeIndex = index;
    this._updateIndicators(index);
  }

  _onPrev() {
    this._goToSlide(this._activeIndex - 1);
  }

  _onNext() {
    this._goToSlide(this._activeIndex + 1);
  }

  _updateIndicators(index) {
    const total = this._slides.length;

    this._dots.forEach((dot, i) => {
      const isActive = i === index;
      dot.classList.toggle('cs-transform__dot--active', isActive);
      dot.setAttribute('aria-selected', isActive ? 'true' : 'false');
      dot.setAttribute('tabindex', isActive ? '0' : '-1');
    });

    if (this._prevBtn) {
      this._prevBtn.disabled = index === 0;
    }
    if (this._nextBtn) {
      this._nextBtn.disabled = index === total - 1;
    }
  }

  _onKeydown(e) {
    if (e.target.closest('[data-cs-dot]')) {
      let next = this._activeIndex;
      if (e.key === 'ArrowRight') {
        next = Math.min(this._activeIndex + 1, this._slides.length - 1);
        e.preventDefault();
      } else if (e.key === 'ArrowLeft') {
        next = Math.max(this._activeIndex - 1, 0);
        e.preventDefault();
      } else if (e.key === 'Home') {
        next = 0;
        e.preventDefault();
      } else if (e.key === 'End') {
        next = this._slides.length - 1;
        e.preventDefault();
      } else {
        return;
      }
      this._goToSlide(next);
      this._dots[next].focus();
      return;
    }

    if (e.target.closest('.cs-transform__carousel')) {
      if (e.key === 'ArrowRight') {
        this._onNext();
        e.preventDefault();
      } else if (e.key === 'ArrowLeft') {
        this._onPrev();
        e.preventDefault();
      }
    }
  }

  /* ── Cart Integration ───────────────────────────────────────────────── */

  _initCTA() {
    const buttons = this.querySelectorAll('[data-cs-add-to-cart]');
    buttons.forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        this._addToCart(btn);
      });
    });
  }

  async _addToCart(btn) {
    const variantId = btn.dataset.variantId;
    const quantity = parseInt(btn.dataset.cartQuantity, 10) || 1;

    if (!variantId) return;

    btn.disabled = true;
    const originalText = btn.textContent;

    try {
      const response = await fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          items: [{ id: parseInt(variantId, 10), quantity: quantity }]
        })
      });

      if (!response.ok) throw new Error('Cart add failed');

      window.location.href = '/cart';
    } catch (err) {
      btn.disabled = false;
    }
  }
}

if (!customElements.get('cs-transform-timeline')) {
  customElements.define('cs-transform-timeline', CsTransformTimeline);
}
</script>

