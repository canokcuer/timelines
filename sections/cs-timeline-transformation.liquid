{% comment %}
  Renders "Your Transformation Journey" results timeline section.
  Self-contained: all styles, scripts, and CTA markup are inlined.
{% endcomment %}

<cs-transformation-timeline>
<section
  id="cs-transformation-{{ section.id }}"
  class="cs-timeline cs-transformation"
  aria-label="{{ section.settings.kicker | default: 'Donusum Sureci' }}"
  data-cs-transformation
>
  <div class="cs-timeline__container">
    {%- comment -%} Section Header {%- endcomment -%}
    <header class="cs-timeline__header cs-timeline__reveal">
      {%- if section.settings.kicker != blank -%}
        <p class="cs-timeline__kicker cs-transformation__kicker">
          {{ section.settings.kicker }}
        </p>
      {%- endif -%}

      <h2 class="cs-timeline__title cs-transformation__title">
        {{ section.settings.title }}
      </h2>

      {%- if section.settings.subtitle != blank -%}
        <p class="cs-timeline__subtitle cs-transformation__subtitle">
          {{ section.settings.subtitle }}
        </p>
      {%- endif -%}
    </header>

    {%- comment -%} Timeline Track {%- endcomment -%}
    <div class="cs-transformation__track" role="list" aria-label="Donusum zaman cizelgesi">
      {%- comment -%} SVG connector lines — desktop {%- endcomment -%}
      <svg class="cs-transformation__connector cs-timeline--hide-mobile" aria-hidden="true" preserveAspectRatio="none">
        <line
          class="cs-timeline__line-draw cs-transformation__line"
          x1="0" y1="50%" x2="100%" y2="50%"
          stroke="var(--cs-gold)"
          stroke-width="2"
        />
      </svg>

      {%- comment -%} SVG connector line — mobile {%- endcomment -%}
      <svg class="cs-transformation__connector cs-transformation__connector--mobile cs-timeline--hide-desktop" aria-hidden="true" preserveAspectRatio="none">
        <line
          class="cs-timeline__line-draw cs-transformation__line"
          x1="50%" y1="0" x2="50%" y2="100%"
          stroke="var(--cs-gold)"
          stroke-width="2"
        />
      </svg>

      {%- for block in section.blocks -%}
        {%- assign is_last = false -%}
        {%- if forloop.last -%}
          {%- assign is_last = true -%}
        {%- endif -%}
        {%- assign delay = forloop.index0 | times: 150 -%}

        <div
          class="cs-transformation__milestone cs-timeline__reveal"
          role="listitem"
          data-milestone-index="{{ forloop.index0 }}"
          style="transition-delay: {{ delay }}ms;"
          {{ block.shopify_attributes }}
        >
          {%- comment -%} Node {%- endcomment -%}
          <div class="cs-transformation__node-wrap">
            <div class="cs-timeline__node cs-timeline__node--large cs-transformation__node" aria-hidden="true"></div>
            <span class="cs-transformation__time-label cs-timeline__tag cs-timeline__tag--gold">
              {{ block.settings.time_label }}
            </span>
          </div>

          {%- comment -%} Content Card {%- endcomment -%}
          <div class="cs-timeline__card-frost cs-transformation__card">
            <h3 class="cs-transformation__card-headline">
              {{ block.settings.headline }}
            </h3>

            {%- if block.settings.benefits != blank -%}
              <div class="cs-transformation__benefits">
                {{ block.settings.benefits }}
              </div>
            {%- endif -%}

            {%- if block.settings.stat != blank -%}
              <p class="cs-transformation__stat">
                {{ block.settings.stat }}
              </p>
            {%- endif -%}

            {%- if is_last and section.settings.cta_text != blank -%}
              <div class="cs-transformation__cta-wrap">
                <a href="{{ section.settings.cta_url }}" class="cs-timeline__cta cs-timeline__cta--gold cs-transformation__cta" aria-label="{{ section.settings.cta_text }}">
                  {{- section.settings.cta_text -}}
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" focusable="false">
                    <path d="M3.333 8h9.334M8.667 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </a>
              </div>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>
</cs-transformation-timeline>

<style>
/* ============================================================================
   CS Timeline Base — Design Tokens & Shared Utilities
   Cyrasoul Timeline Sections
   ============================================================================ */

/* --------------------------------------------------------------------------
   Design Tokens
   -------------------------------------------------------------------------- */

:root {
  /* Brand Colors */
  --cs-gold: #FFDF00;
  --cs-gold-soft: rgba(255, 223, 0, 0.15);
  --cs-gold-medium: rgba(255, 223, 0, 0.4);
  --cs-teal: #108474;
  --cs-teal-soft: rgba(16, 132, 116, 0.15);
  --cs-teal-medium: rgba(16, 132, 116, 0.4);
  --cs-indigo: #3B3073;
  --cs-indigo-soft: rgba(59, 48, 115, 0.15);

  /* Background Surfaces */
  --cs-bg-dark: #171717;
  --cs-bg-deep: #0a0a0a;
  --cs-bg-warm: #f9f6f2;
  --cs-bg-white: #ffffff;
  --cs-bg-card-dark: rgba(255, 255, 255, 0.04);
  --cs-bg-card-frost: rgba(255, 255, 255, 0.06);

  /* Text */
  --cs-text-white: #ffffff;
  --cs-text-white-muted: rgba(255, 255, 255, 0.7);
  --cs-text-white-subtle: rgba(255, 255, 255, 0.5);
  --cs-text-dark: #171717;
  --cs-text-dark-muted: rgba(23, 23, 23, 0.7);
  --cs-text-dark-subtle: rgba(23, 23, 23, 0.5);

  /* Borders */
  --cs-border-light: rgba(255, 255, 255, 0.08);
  --cs-border-gold: rgba(255, 223, 0, 0.3);
  --cs-border-teal: rgba(16, 132, 116, 0.3);

  /* Typography — Inter stack */
  --cs-font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  --cs-font-size-xs: clamp(0.6875rem, 0.625rem + 0.25vw, 0.75rem);    /* 11-12px */
  --cs-font-size-sm: clamp(0.75rem, 0.6875rem + 0.25vw, 0.875rem);    /* 12-14px */
  --cs-font-size-base: clamp(0.875rem, 0.8125rem + 0.25vw, 1rem);     /* 14-16px */
  --cs-font-size-md: clamp(1rem, 0.9375rem + 0.25vw, 1.125rem);       /* 16-18px */
  --cs-font-size-lg: clamp(1.125rem, 1rem + 0.5vw, 1.375rem);         /* 18-22px */
  --cs-font-size-xl: clamp(1.375rem, 1.125rem + 1vw, 1.75rem);        /* 22-28px */
  --cs-font-size-2xl: clamp(1.75rem, 1.375rem + 1.5vw, 2.5rem);       /* 28-40px */
  --cs-font-size-3xl: clamp(2rem, 1.5rem + 2vw, 3rem);                /* 32-48px */

  /* Spacing */
  --cs-space-xs: clamp(0.25rem, 0.125rem + 0.5vw, 0.5rem);
  --cs-space-sm: clamp(0.5rem, 0.375rem + 0.5vw, 0.75rem);
  --cs-space-md: clamp(0.75rem, 0.5rem + 1vw, 1.25rem);
  --cs-space-lg: clamp(1.25rem, 0.875rem + 1.5vw, 2rem);
  --cs-space-xl: clamp(2rem, 1.25rem + 3vw, 3.5rem);
  --cs-space-2xl: clamp(3rem, 2rem + 4vw, 5rem);
  --cs-space-3xl: clamp(4rem, 2.5rem + 6vw, 7.5rem);

  /* Radii */
  --cs-radius-sm: 4px;
  --cs-radius-md: 8px;
  --cs-radius-lg: 12px;
  --cs-radius-xl: 16px;
  --cs-radius-full: 9999px;

  /* Shadows */
  --cs-shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.12);
  --cs-shadow-md: 0 4px 12px rgba(0, 0, 0, 0.15);
  --cs-shadow-lg: 0 8px 30px rgba(0, 0, 0, 0.2);
  --cs-shadow-gold: 0 0 20px rgba(255, 223, 0, 0.15);
  --cs-shadow-teal: 0 0 20px rgba(16, 132, 116, 0.15);

  /* Transitions */
  --cs-ease-out: cubic-bezier(0.16, 1, 0.3, 1);
  --cs-ease-in-out: cubic-bezier(0.65, 0, 0.35, 1);
  --cs-duration-fast: 200ms;
  --cs-duration-base: 400ms;
  --cs-duration-slow: 600ms;
  --cs-duration-draw: 1200ms;

  /* Z-index scale */
  --cs-z-base: 1;
  --cs-z-above: 10;
  --cs-z-sticky: 100;
  --cs-z-overlay: 200;
  --cs-z-modal: 300;

  /* Layout */
  --cs-content-max: 1200px;
  --cs-content-narrow: 640px;
  --cs-mobile-dock-clearance: 95px;
}

/* --------------------------------------------------------------------------
   Base Reset & Layout
   -------------------------------------------------------------------------- */

.cs-timeline {
  font-family: var(--cs-font-family);
  line-height: 1.6;
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

.cs-timeline *,
.cs-timeline *::before,
.cs-timeline *::after {
  box-sizing: inherit;
}

.cs-timeline__container {
  width: 100%;
  max-width: var(--cs-content-max);
  margin-inline: auto;
  padding-inline: var(--cs-space-md);
}

.cs-timeline__container--narrow {
  max-width: var(--cs-content-narrow);
}

/* --------------------------------------------------------------------------
   Section Header (shared)
   -------------------------------------------------------------------------- */

.cs-timeline__header {
  text-align: center;
  margin-block-end: var(--cs-space-2xl);
}

.cs-timeline__kicker {
  display: inline-block;
  font-size: var(--cs-font-size-xs);
  font-weight: 600;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  margin-block-end: var(--cs-space-sm);
}

.cs-timeline__title {
  font-size: var(--cs-font-size-2xl);
  font-weight: 700;
  letter-spacing: -0.02em;
  line-height: 1.15;
  margin: 0 0 var(--cs-space-md);
}

.cs-timeline__subtitle {
  font-size: var(--cs-font-size-md);
  line-height: 1.5;
  max-width: 540px;
  margin-inline: auto;
}

/* --------------------------------------------------------------------------
   Shared Animation States
   -------------------------------------------------------------------------- */

.cs-timeline__reveal {
  opacity: 0;
  transform: translateY(24px);
  transition:
    opacity var(--cs-duration-slow) var(--cs-ease-out),
    transform var(--cs-duration-slow) var(--cs-ease-out);
}

.cs-timeline__reveal--visible {
  opacity: 1;
  transform: translateY(0);
}

.cs-timeline__reveal--left {
  opacity: 0;
  transform: translateX(-24px);
  transition:
    opacity var(--cs-duration-slow) var(--cs-ease-out),
    transform var(--cs-duration-slow) var(--cs-ease-out);
}

.cs-timeline__reveal--left.cs-timeline__reveal--visible {
  opacity: 1;
  transform: translateX(0);
}

.cs-timeline__reveal--right {
  opacity: 0;
  transform: translateX(24px);
  transition:
    opacity var(--cs-duration-slow) var(--cs-ease-out),
    transform var(--cs-duration-slow) var(--cs-ease-out);
}

.cs-timeline__reveal--right.cs-timeline__reveal--visible {
  opacity: 1;
  transform: translateX(0);
}

.cs-timeline__reveal--scale {
  opacity: 0;
  transform: scale(0.85);
  transition:
    opacity var(--cs-duration-slow) var(--cs-ease-out),
    transform var(--cs-duration-slow) var(--cs-ease-out);
}

.cs-timeline__reveal--scale.cs-timeline__reveal--visible {
  opacity: 1;
  transform: scale(1);
}

/* Stagger children */
.cs-timeline__reveal--visible .cs-timeline__stagger:nth-child(1) { transition-delay: 0ms; }
.cs-timeline__reveal--visible .cs-timeline__stagger:nth-child(2) { transition-delay: 80ms; }
.cs-timeline__reveal--visible .cs-timeline__stagger:nth-child(3) { transition-delay: 160ms; }
.cs-timeline__reveal--visible .cs-timeline__stagger:nth-child(4) { transition-delay: 240ms; }
.cs-timeline__reveal--visible .cs-timeline__stagger:nth-child(5) { transition-delay: 320ms; }
.cs-timeline__reveal--visible .cs-timeline__stagger:nth-child(6) { transition-delay: 400ms; }

.cs-timeline__stagger {
  opacity: 0;
  transform: translateY(12px);
  transition:
    opacity var(--cs-duration-base) var(--cs-ease-out),
    transform var(--cs-duration-base) var(--cs-ease-out);
}

.cs-timeline__reveal--visible .cs-timeline__stagger {
  opacity: 1;
  transform: translateY(0);
}

/* --------------------------------------------------------------------------
   Line Draw Animation
   -------------------------------------------------------------------------- */

.cs-timeline__line-draw {
  stroke-dasharray: var(--line-length, 1000);
  stroke-dashoffset: var(--line-length, 1000);
  transition: stroke-dashoffset var(--cs-duration-draw) var(--cs-ease-in-out);
}

.cs-timeline__line-draw--active {
  stroke-dashoffset: 0;
}

/* --------------------------------------------------------------------------
   Node (shared dot/circle on timeline)
   -------------------------------------------------------------------------- */

.cs-timeline__node {
  position: relative;
  width: 16px;
  height: 16px;
  border-radius: var(--cs-radius-full);
  border: 2px solid var(--cs-gold);
  background: transparent;
  transition: background var(--cs-duration-base) var(--cs-ease-out),
              box-shadow var(--cs-duration-base) var(--cs-ease-out);
  flex-shrink: 0;
}

.cs-timeline__node--active {
  background: var(--cs-gold);
  box-shadow: var(--cs-shadow-gold);
}

.cs-timeline__node--large {
  width: 24px;
  height: 24px;
}

/* --------------------------------------------------------------------------
   Frosted Glass Card
   -------------------------------------------------------------------------- */

.cs-timeline__card-frost {
  background: var(--cs-bg-card-frost);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid var(--cs-border-light);
  border-radius: var(--cs-radius-lg);
  padding: var(--cs-space-lg);
}

/* --------------------------------------------------------------------------
   Tag / Pill
   -------------------------------------------------------------------------- */

.cs-timeline__tag {
  display: inline-flex;
  align-items: center;
  gap: 0.25em;
  font-size: var(--cs-font-size-xs);
  font-weight: 600;
  padding: 0.25em 0.75em;
  border-radius: var(--cs-radius-full);
  white-space: nowrap;
}

.cs-timeline__tag--gold {
  background: var(--cs-gold-soft);
  color: var(--cs-gold);
  border: 1px solid var(--cs-border-gold);
}

.cs-timeline__tag--teal {
  background: var(--cs-teal-soft);
  color: var(--cs-teal);
  border: 1px solid var(--cs-border-teal);
}

/* --------------------------------------------------------------------------
   CTA Button (base)
   -------------------------------------------------------------------------- */

.cs-timeline__cta {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5em;
  font-family: var(--cs-font-family);
  font-size: var(--cs-font-size-sm);
  font-weight: 600;
  letter-spacing: 0.04em;
  text-decoration: none;
  padding: 0.875em 2em;
  border-radius: var(--cs-radius-full);
  border: none;
  cursor: pointer;
  min-height: 44px;
  min-width: 44px;
  transition:
    background var(--cs-duration-fast) var(--cs-ease-out),
    transform var(--cs-duration-fast) var(--cs-ease-out),
    box-shadow var(--cs-duration-fast) var(--cs-ease-out);
}

.cs-timeline__cta:hover {
  transform: translateY(-1px);
}

.cs-timeline__cta:active {
  transform: translateY(0);
}

.cs-timeline__cta--gold {
  background: var(--cs-gold);
  color: var(--cs-bg-dark);
}

.cs-timeline__cta--gold:hover {
  box-shadow: var(--cs-shadow-gold);
}

.cs-timeline__cta--ghost {
  background: transparent;
  border: 1px solid var(--cs-border-light);
  color: var(--cs-text-white);
}

.cs-timeline__cta--ghost:hover {
  background: rgba(255, 255, 255, 0.05);
}

/* --------------------------------------------------------------------------
   Progress Bar (shared)
   -------------------------------------------------------------------------- */

.cs-timeline__progress {
  position: relative;
  width: 100%;
  height: 2px;
  background: var(--cs-border-light);
  border-radius: var(--cs-radius-full);
  overflow: hidden;
}

.cs-timeline__progress-fill {
  position: absolute;
  inset-block: 0;
  inset-inline-start: 0;
  width: 0%;
  background: linear-gradient(90deg, var(--cs-gold), var(--cs-teal));
  border-radius: var(--cs-radius-full);
  transition: width var(--cs-duration-base) var(--cs-ease-out);
}

/* --------------------------------------------------------------------------
   Prefers Reduced Motion (base)
   -------------------------------------------------------------------------- */

@media (prefers-reduced-motion: reduce) {
  .cs-timeline__reveal,
  .cs-timeline__reveal--left,
  .cs-timeline__reveal--right,
  .cs-timeline__reveal--scale,
  .cs-timeline__stagger,
  .cs-timeline__line-draw,
  .cs-timeline__node,
  .cs-timeline__cta,
  .cs-timeline__progress-fill {
    transition-duration: 0.01ms !important;
    animation-duration: 0.01ms !important;
  }

  .cs-timeline__reveal,
  .cs-timeline__reveal--left,
  .cs-timeline__reveal--right,
  .cs-timeline__reveal--scale {
    opacity: 1;
    transform: none;
  }

  .cs-timeline__stagger {
    opacity: 1;
    transform: none;
  }

  .cs-timeline__line-draw {
    stroke-dashoffset: 0;
  }
}

/* --------------------------------------------------------------------------
   Responsive Utilities
   -------------------------------------------------------------------------- */

@media screen and (max-width: 749px) {
  .cs-timeline--hide-mobile {
    display: none !important;
  }

  .cs-timeline {
    padding-block-end: var(--cs-mobile-dock-clearance);
  }
}

@media screen and (min-width: 750px) {
  .cs-timeline--hide-desktop {
    display: none !important;
  }
}

/* Screen reader only */
.cs-timeline__sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border-width: 0;
}

/* ============================================================================
   CS Transformation Journey — Section Styles
   ============================================================================ */

/* --------------------------------------------------------------------------
   Section Root
   -------------------------------------------------------------------------- */
.cs-transformation {
  background: var(--cs-bg-dark);
  color: var(--cs-text-white);
  padding-block: var(--cs-space-3xl);
  overflow: hidden;
  position: relative;
}

/* --------------------------------------------------------------------------
   Header Overrides
   -------------------------------------------------------------------------- */
.cs-transformation__kicker {
  color: var(--cs-gold);
}

.cs-transformation__title {
  color: var(--cs-text-white);
}

.cs-transformation__subtitle {
  color: var(--cs-text-white-muted);
}

/* --------------------------------------------------------------------------
   Track — Desktop Zigzag
   -------------------------------------------------------------------------- */
.cs-transformation__track {
  position: relative;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--cs-space-md);
  align-items: start;
}

.cs-transformation__connector {
  position: absolute;
  top: 12px;
  left: 0;
  width: 100%;
  height: 24px;
  z-index: var(--cs-z-base);
  pointer-events: none;
}

/* --------------------------------------------------------------------------
   Milestone — Desktop
   -------------------------------------------------------------------------- */
.cs-transformation__milestone {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: var(--cs-z-above);
}

/* Zigzag: even milestones push card down, odd milestones are default */
.cs-transformation__milestone:nth-child(odd) .cs-transformation__card {
  margin-block-start: var(--cs-space-md);
}

.cs-transformation__milestone:nth-child(even) {
  margin-block-start: clamp(8rem, 6rem + 8vw, 14rem);
}

.cs-transformation__milestone:nth-child(even) .cs-transformation__card {
  order: -1;
  margin-block-end: var(--cs-space-md);
}

.cs-transformation__milestone:nth-child(even) .cs-transformation__node-wrap {
  order: 1;
}

/* --------------------------------------------------------------------------
   Node Wrap & Time Label
   -------------------------------------------------------------------------- */
.cs-transformation__node-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--cs-space-xs);
}

.cs-transformation__time-label {
  font-size: var(--cs-font-size-xs);
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

/* --------------------------------------------------------------------------
   Content Card
   -------------------------------------------------------------------------- */
.cs-transformation__card {
  width: 100%;
  text-align: center;
}

.cs-transformation__card-headline {
  font-size: var(--cs-font-size-lg);
  font-weight: 700;
  color: var(--cs-text-white);
  margin: 0 0 var(--cs-space-sm);
  line-height: 1.3;
}

.cs-transformation__benefits {
  font-size: var(--cs-font-size-sm);
  color: var(--cs-text-white-muted);
  line-height: 1.6;
}

.cs-transformation__benefits p {
  margin: 0 0 var(--cs-space-xs);
}

.cs-transformation__benefits ul {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: var(--cs-space-xs);
}

.cs-transformation__benefits li {
  background: var(--cs-teal-soft);
  color: var(--cs-teal);
  font-size: var(--cs-font-size-xs);
  font-weight: 600;
  padding: 0.3em 0.75em;
  border-radius: var(--cs-radius-full);
  border: 1px solid var(--cs-border-teal);
}

/* --------------------------------------------------------------------------
   Stat
   -------------------------------------------------------------------------- */
.cs-transformation__stat {
  font-size: var(--cs-font-size-xs);
  color: var(--cs-gold);
  font-weight: 600;
  margin: var(--cs-space-sm) 0 0;
  font-style: italic;
}

/* --------------------------------------------------------------------------
   CTA Wrap
   -------------------------------------------------------------------------- */
.cs-transformation__cta-wrap {
  margin-block-start: var(--cs-space-lg);
}

/* --------------------------------------------------------------------------
   Active / Revealed Node State
   -------------------------------------------------------------------------- */
.cs-timeline__reveal--visible .cs-transformation__node {
  background: var(--cs-gold);
  box-shadow: var(--cs-shadow-gold);
}

/* --------------------------------------------------------------------------
   Mobile — Vertical Timeline (< 750px)
   -------------------------------------------------------------------------- */
@media screen and (max-width: 749px) {
  .cs-transformation__track {
    display: flex;
    flex-direction: column;
    gap: var(--cs-space-xl);
    padding-inline-start: 40px;
    position: relative;
  }

  .cs-transformation__connector--mobile {
    position: absolute;
    top: 0;
    left: 11px;
    width: 24px;
    height: 100%;
    z-index: var(--cs-z-base);
  }

  .cs-transformation__milestone {
    flex-direction: row;
    align-items: flex-start;
    gap: var(--cs-space-md);
  }

  /* Reset zigzag for mobile */
  .cs-transformation__milestone:nth-child(even) {
    margin-block-start: 0;
  }

  .cs-transformation__milestone:nth-child(even) .cs-transformation__card {
    order: unset;
    margin-block-end: 0;
    margin-block-start: var(--cs-space-sm);
  }

  .cs-transformation__milestone:nth-child(even) .cs-transformation__node-wrap {
    order: unset;
  }

  .cs-transformation__milestone:nth-child(odd) .cs-transformation__card {
    margin-block-start: var(--cs-space-sm);
  }

  .cs-transformation__node-wrap {
    position: absolute;
    left: -40px;
    top: 0;
    flex-direction: column;
    align-items: center;
  }

  .cs-transformation__time-label {
    writing-mode: unset;
    white-space: nowrap;
    position: absolute;
    left: calc(100% + var(--cs-space-xs));
    top: 50%;
    transform: translateY(-50%);
    display: none;
  }

  .cs-transformation__card {
    text-align: left;
  }

  .cs-transformation__card-headline::before {
    content: attr(data-time-label);
    display: block;
    font-size: var(--cs-font-size-xs);
    font-weight: 700;
    color: var(--cs-gold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-block-end: var(--cs-space-xs);
  }

  .cs-transformation__benefits ul {
    justify-content: flex-start;
  }
}

/* --------------------------------------------------------------------------
   Reduced Motion — section-specific overrides
   -------------------------------------------------------------------------- */
@media (prefers-reduced-motion: reduce) {
  .cs-transformation__node {
    background: var(--cs-gold) !important;
    box-shadow: var(--cs-shadow-gold) !important;
  }

  .cs-transformation__line {
    stroke-dashoffset: 0 !important;
  }
}
</style>

<script>
/* ============================================================================
   CS Timeline Base — Shared JavaScript Utilities (inlined)
   ============================================================================ */

/**
 * IntersectionObserver wrapper for scroll-triggered reveal animations.
 * Adds `--visible` modifier class when element enters viewport.
 *
 * @param {string} selector - CSS selector for elements to observe
 * @param {Object} [options]
 * @param {number} [options.threshold=0.15] - Visibility threshold (0-1)
 * @param {string} [options.rootMargin='0px 0px -60px 0px'] - Root margin
 * @param {boolean} [options.once=true] - Unobserve after first trigger
 * @param {Function} [options.onReveal] - Callback when element is revealed
 * @returns {IntersectionObserver|null}
 */
function csTimelineReveal(selector, options = {}) {
  const {
    threshold = 0.15,
    rootMargin = '0px 0px -60px 0px',
    once = true,
    onReveal = null
  } = options;

  const elements = document.querySelectorAll(selector);
  if (!elements.length) return null;

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (prefersReducedMotion) {
    elements.forEach((el) => {
      el.classList.add('cs-timeline__reveal--visible');
      if (onReveal) onReveal(el);
    });
    return null;
  }

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('cs-timeline__reveal--visible');
          if (onReveal) onReveal(entry.target);
          if (once) observer.unobserve(entry.target);
        }
      });
    },
    { threshold, rootMargin }
  );

  elements.forEach((el) => observer.observe(el));
  return observer;
}

/**
 * Tracks scroll progress within a container element.
 * Calls back with a normalized 0-1 value as user scrolls through.
 *
 * @param {HTMLElement} container - The scrollable/trackable container
 * @param {Function} onProgress - Callback receiving progress (0-1)
 * @returns {Function} cleanup - Call to remove scroll listener
 */
function csTimelineScrollProgress(container, onProgress) {
  if (!container || typeof onProgress !== 'function') return () => {};

  let ticking = false;

  function update() {
    const rect = container.getBoundingClientRect();
    const viewportHeight = window.innerHeight;
    const totalTravel = rect.height + viewportHeight;
    const traveled = viewportHeight - rect.top;
    const progress = Math.min(Math.max(traveled / totalTravel, 0), 1);
    onProgress(progress);
    ticking = false;
  }

  function onScroll() {
    if (!ticking) {
      requestAnimationFrame(update);
      ticking = true;
    }
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  update();

  return () => window.removeEventListener('scroll', onScroll);
}

/* ============================================================================
   CS Transformation Journey — Web Component
   ============================================================================ */

class CsTransformationTimeline extends HTMLElement {
  constructor() {
    super();
    this._scrollCleanup = null;
    this._observer = null;
  }

  connectedCallback() {
    this._initReveal();
    this._initConnectorDraw();
    this._setMobileTimeLabels();
  }

  disconnectedCallback() {
    if (this._scrollCleanup) {
      this._scrollCleanup();
      this._scrollCleanup = null;
    }
    if (this._observer) {
      this._observer.disconnect();
      this._observer = null;
    }
  }

  /**
   * Initialize IntersectionObserver reveal for header + milestones.
   */
  _initReveal() {
    const sectionId = this.querySelector('[data-cs-transformation]')
      ? this.id || ''
      : '';
    const scope = this;

    this._observer = csTimelineReveal(
      '.cs-transformation .cs-timeline__reveal',
      {
        threshold: 0.15,
        rootMargin: '0px 0px -60px 0px',
        once: true,
        onReveal: (el) => {
          /* Activate the node fill when milestone is revealed */
          const node = el.querySelector('.cs-transformation__node');
          if (node) {
            node.classList.add('cs-timeline__node--active');
          }
        }
      }
    );
  }

  /**
   * Draw the SVG connector line as user scrolls through the section.
   */
  _initConnectorDraw() {
    const track = this.querySelector('.cs-transformation__track');
    if (!track) return;

    const lines = this.querySelectorAll('.cs-transformation__line');
    if (!lines.length) return;

    /* Measure SVG line lengths and set dasharray */
    lines.forEach((line) => {
      const length = line.getTotalLength ? line.getTotalLength() : 1000;
      line.style.setProperty('--line-length', length);
      line.style.strokeDasharray = length;
      line.style.strokeDashoffset = length;
    });

    this._scrollCleanup = csTimelineScrollProgress(track, (progress) => {
      /* Map progress 0-1 to line draw 0-100% */
      lines.forEach((line) => {
        const length = parseFloat(
          getComputedStyle(line).getPropertyValue('--line-length')
        ) || 1000;
        const offset = length * (1 - progress * 1.5);
        line.style.strokeDashoffset = Math.max(offset, 0);
      });
    });
  }

  /**
   * On mobile, copy time_label to card headline data attribute
   * so CSS ::before can display it.
   */
  _setMobileTimeLabels() {
    const milestones = this.querySelectorAll('.cs-transformation__milestone');
    milestones.forEach((ms) => {
      const label = ms.querySelector('.cs-transformation__time-label');
      const headline = ms.querySelector('.cs-transformation__card-headline');
      if (label && headline) {
        headline.setAttribute('data-time-label', label.textContent.trim());
      }
    });
  }
}

if (!customElements.get('cs-transformation-timeline')) {
  customElements.define('cs-transformation-timeline', CsTransformationTimeline);
}
</script>

