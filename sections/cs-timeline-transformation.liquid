{% comment %}
  TheChill Transformation Journey — calming timeline section.
  Self-contained: all styles, scripts, and illustrations are inlined.
  4 science-backed milestones showing TheChill's progressive benefits.
{% endcomment %}

<cs-transform-timeline>
<section
  id="cs-transform-{{ section.id }}"
  class="cs-timeline cs-transform"
  aria-label="{{ section.settings.kicker | default: 'Dönüşüm Yolculuğu' }}"
  data-cs-transform
>
  <div class="cs-timeline__container">
    {%- comment -%} Section Header {%- endcomment -%}
    <header class="cs-timeline__header cs-transform__header cs-transform__reveal">
      {%- if section.settings.kicker != blank -%}
        <span class="cs-timeline__kicker cs-transform__kicker">
          {{ section.settings.kicker }}
        </span>
      {%- endif -%}

      <h2 class="cs-timeline__title cs-transform__title">
        {{ section.settings.title }}
      </h2>

      {%- if section.settings.subtitle != blank -%}
        <p class="cs-timeline__subtitle cs-transform__subtitle">
          {{ section.settings.subtitle }}
        </p>
      {%- endif -%}
    </header>
  </div>

  {%- comment -%} Timeline Body with Vertical Spine {%- endcomment -%}
  <div class="cs-transform__body">
    {%- comment -%} Central Spine SVG (desktop only) {%- endcomment -%}
    <div class="cs-transform__spine cs-timeline--hide-mobile" aria-hidden="true">
      <svg class="cs-transform__spine-svg" viewBox="0 0 2 100" preserveAspectRatio="none" fill="none">
        <defs>
          <linearGradient id="transformSpineGrad-{{ section.id }}" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#0D4F47" />
            <stop offset="100%" stop-color="#C4973B" />
          </linearGradient>
        </defs>
        <line
          x1="1" y1="0" x2="1" y2="100"
          stroke="url(#transformSpineGrad-{{ section.id }})"
          stroke-width="2"
          class="cs-timeline__line-draw cs-transform__spine-line"
          data-cs-spine-line
          style="--line-length: 100;"
        />
      </svg>
    </div>

    {%- comment -%} Milestone Panels {%- endcomment -%}
    {%- for block in section.blocks -%}
      {%- assign is_odd = forloop.index | modulo: 2 -%}
      {%- assign panel_side = 'left' -%}
      {%- if is_odd == 0 -%}
        {%- assign panel_side = 'right' -%}
      {%- endif -%}
      {%- assign is_last = false -%}
      {%- if forloop.last -%}
        {%- assign is_last = true -%}
      {%- endif -%}

      <div
        class="cs-transform__panel cs-transform__panel--{{ panel_side }}"
        role="listitem"
        data-milestone-index="{{ forloop.index0 }}"
        {{ block.shopify_attributes }}
      >
        {%- comment -%} Node on spine {%- endcomment -%}
        <div class="cs-transform__node-wrap" aria-hidden="true">
          <div class="cs-transform__node" data-cs-node></div>
          <span class="cs-transform__time-badge">
            {{ block.settings.time_label }}
          </span>
        </div>

        {%- comment -%} Content Card {%- endcomment -%}
        <div class="cs-transform__card cs-transform__reveal" data-cs-reveal>
          <h3 class="cs-transform__card-headline" data-time-label="{{ block.settings.time_label }}">
            {{ block.settings.headline }}
          </h3>

          {%- comment -%} Benefits with ingredient pills {%- endcomment -%}
          <ul class="cs-transform__benefits" role="list">
            {%- if block.settings.benefit_1 != blank -%}
              <li class="cs-transform__benefit">
                <span class="cs-transform__benefit-text">{{ block.settings.benefit_1 }}</span>
                {%- if block.settings.ingredient_1 != blank -%}
                  <span class="cs-transform__ingredient-pill">{{ block.settings.ingredient_1 }}</span>
                {%- endif -%}
              </li>
            {%- endif -%}
            {%- if block.settings.benefit_2 != blank -%}
              <li class="cs-transform__benefit">
                <span class="cs-transform__benefit-text">{{ block.settings.benefit_2 }}</span>
                {%- if block.settings.ingredient_2 != blank -%}
                  <span class="cs-transform__ingredient-pill">{{ block.settings.ingredient_2 }}</span>
                {%- endif -%}
              </li>
            {%- endif -%}
            {%- if block.settings.benefit_3 != blank -%}
              <li class="cs-transform__benefit">
                <span class="cs-transform__benefit-text">{{ block.settings.benefit_3 }}</span>
                {%- if block.settings.ingredient_3 != blank -%}
                  <span class="cs-transform__ingredient-pill">{{ block.settings.ingredient_3 }}</span>
                {%- endif -%}
              </li>
            {%- endif -%}
          </ul>

          {%- comment -%} Science callout box {%- endcomment -%}
          {%- if block.settings.science_callout != blank -%}
            <div class="cs-transform__science-callout">
              <span class="cs-transform__science-label">Bilimsel Mekanizma</span>
              <p class="cs-transform__science-text">{{ block.settings.science_callout }}</p>
              {%- if block.settings.stat_reference != blank -%}
                <cite class="cs-transform__science-ref">{{ block.settings.stat_reference }}</cite>
              {%- endif -%}
            </div>
          {%- endif -%}

          {%- comment -%} CTA on last milestone {%- endcomment -%}
          {%- if is_last and section.settings.cta_text != blank -%}
            <div class="cs-transform__cta-wrap">
              <a
                href="{{ section.settings.cta_url }}"
                class="cs-transform__cta"
                aria-label="{{ section.settings.cta_text }}"
              >
                {{- section.settings.cta_text -}}
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" focusable="false">
                  <path d="M3.333 8h9.334M8.667 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </div>
          {%- endif -%}
        </div>

        {%- comment -%} SVG Illustration (desktop only) {%- endcomment -%}
        <div class="cs-transform__illust cs-timeline--hide-mobile cs-transform__reveal" data-cs-reveal>
          <div class="cs-transform__illust-circle">
            {%- case block.settings.illustration -%}
              {%- when 'molecule' -%}
                {%- comment -%} Chamomile flower silhouette + hexagonal apigenin ring {%- endcomment -%}
                <svg class="cs-transform__illust-svg" viewBox="0 0 120 120" fill="none" aria-hidden="true" focusable="false">
                  <!-- Chamomile petals -->
                  <ellipse cx="60" cy="32" rx="6" ry="14" stroke="#0D4F47" stroke-width="1.2" opacity="0.5" transform="rotate(0 60 60)"/>
                  <ellipse cx="60" cy="32" rx="6" ry="14" stroke="#0D4F47" stroke-width="1.2" opacity="0.45" transform="rotate(60 60 60)"/>
                  <ellipse cx="60" cy="32" rx="6" ry="14" stroke="#0D4F47" stroke-width="1.2" opacity="0.4" transform="rotate(120 60 60)"/>
                  <ellipse cx="60" cy="32" rx="6" ry="14" stroke="#0D4F47" stroke-width="1.2" opacity="0.45" transform="rotate(180 60 60)"/>
                  <ellipse cx="60" cy="32" rx="6" ry="14" stroke="#0D4F47" stroke-width="1.2" opacity="0.5" transform="rotate(240 60 60)"/>
                  <ellipse cx="60" cy="32" rx="6" ry="14" stroke="#0D4F47" stroke-width="1.2" opacity="0.4" transform="rotate(300 60 60)"/>
                  <!-- Center -->
                  <circle cx="60" cy="60" r="8" stroke="#C4973B" stroke-width="1.2" opacity="0.5"/>
                  <!-- Hexagonal apigenin ring -->
                  <polygon points="60,78 72,85 72,99 60,106 48,99 48,85" stroke="#0D4F47" stroke-width="1" opacity="0.35" fill="none"/>
                  <circle cx="60" cy="92" r="2" fill="#C4973B" opacity="0.4"/>
                </svg>

              {%- when 'wave' -%}
                {%- comment -%} Sleep wave rhythm + crescent moon {%- endcomment -%}
                <svg class="cs-transform__illust-svg" viewBox="0 0 120 120" fill="none" aria-hidden="true" focusable="false">
                  <!-- Sleep waves -->
                  <path d="M15 50 Q30 38, 45 50 Q60 62, 75 50 Q90 38, 105 50" stroke="#0D4F47" stroke-width="1.5" opacity="0.5" fill="none"/>
                  <path d="M15 60 Q30 48, 45 60 Q60 72, 75 60 Q90 48, 105 60" stroke="#0D4F47" stroke-width="1.2" opacity="0.4" fill="none"/>
                  <path d="M15 70 Q30 58, 45 70 Q60 82, 75 70 Q90 58, 105 70" stroke="#0D4F47" stroke-width="1" opacity="0.3" fill="none"/>
                  <!-- Crescent moon -->
                  <path d="M60 20 A18 18 0 1 0 60 56 A12 12 0 1 1 60 20Z" stroke="#C4973B" stroke-width="1.2" opacity="0.5" fill="none"/>
                  <!-- Stars -->
                  <circle cx="35" cy="28" r="1.5" fill="#C4973B" opacity="0.4"/>
                  <circle cx="88" cy="24" r="1" fill="#C4973B" opacity="0.35"/>
                  <circle cx="78" cy="35" r="1.2" fill="#C4973B" opacity="0.3"/>
                </svg>

              {%- when 'brain' -%}
                {%- comment -%} Brain outline with balance scales (cortisol equilibrium) {%- endcomment -%}
                <svg class="cs-transform__illust-svg" viewBox="0 0 120 120" fill="none" aria-hidden="true" focusable="false">
                  <!-- Simplified brain outline -->
                  <path d="M60 25 C42 25, 30 35, 30 50 C30 58, 34 64, 40 68 C36 72, 35 78, 38 84 C41 90, 48 92, 55 90 L60 88 L65 90 C72 92, 79 90, 82 84 C85 78, 84 72, 80 68 C86 64, 90 58, 90 50 C90 35, 78 25, 60 25Z" stroke="#0D4F47" stroke-width="1.2" opacity="0.45" fill="none"/>
                  <!-- Center divide -->
                  <line x1="60" y1="28" x2="60" y2="88" stroke="#0D4F47" stroke-width="0.8" opacity="0.25"/>
                  <!-- Balance scales below -->
                  <line x1="40" y1="102" x2="80" y2="102" stroke="#C4973B" stroke-width="1.2" opacity="0.5"/>
                  <line x1="60" y1="95" x2="60" y2="102" stroke="#C4973B" stroke-width="1.2" opacity="0.5"/>
                  <!-- Scale pans -->
                  <path d="M42 102 L38 108 L50 108 L46 102" stroke="#C4973B" stroke-width="1" opacity="0.4" fill="none"/>
                  <path d="M74 102 L70 108 L82 108 L78 102" stroke="#C4973B" stroke-width="1" opacity="0.4" fill="none"/>
                  <!-- Fulcrum -->
                  <polygon points="60,95 56,100 64,100" stroke="#C4973B" stroke-width="1" opacity="0.5" fill="none"/>
                </svg>

              {%- when 'harmony' -%}
                {%- comment -%} Botanical harmony circle — 6 radiating leaves for 6 ingredients {%- endcomment -%}
                <svg class="cs-transform__illust-svg" viewBox="0 0 120 120" fill="none" aria-hidden="true" focusable="false">
                  <!-- Central circle -->
                  <circle cx="60" cy="60" r="12" stroke="#0D4F47" stroke-width="1.2" opacity="0.5"/>
                  <circle cx="60" cy="60" r="24" stroke="#0D4F47" stroke-width="0.8" opacity="0.2" stroke-dasharray="3 3"/>
                  <!-- 6 botanical leaves radiating outward -->
                  <path d="M60 48 C56 38, 52 28, 60 20 C68 28, 64 38, 60 48Z" stroke="#0D4F47" stroke-width="1" opacity="0.5" fill="none"/>
                  <path d="M60 48 C56 38, 52 28, 60 20 C68 28, 64 38, 60 48Z" stroke="#0D4F47" stroke-width="1" opacity="0.45" fill="none" transform="rotate(60 60 60)"/>
                  <path d="M60 48 C56 38, 52 28, 60 20 C68 28, 64 38, 60 48Z" stroke="#C4973B" stroke-width="1" opacity="0.4" fill="none" transform="rotate(120 60 60)"/>
                  <path d="M60 48 C56 38, 52 28, 60 20 C68 28, 64 38, 60 48Z" stroke="#0D4F47" stroke-width="1" opacity="0.5" fill="none" transform="rotate(180 60 60)"/>
                  <path d="M60 48 C56 38, 52 28, 60 20 C68 28, 64 38, 60 48Z" stroke="#C4973B" stroke-width="1" opacity="0.45" fill="none" transform="rotate(240 60 60)"/>
                  <path d="M60 48 C56 38, 52 28, 60 20 C68 28, 64 38, 60 48Z" stroke="#0D4F47" stroke-width="1" opacity="0.4" fill="none" transform="rotate(300 60 60)"/>
                  <!-- Center dot -->
                  <circle cx="60" cy="60" r="3" fill="#C4973B" opacity="0.4"/>
                </svg>

              {%- else -%}
                {%- comment -%} Default: simple circle placeholder {%- endcomment -%}
                <svg class="cs-transform__illust-svg" viewBox="0 0 120 120" fill="none" aria-hidden="true" focusable="false">
                  <circle cx="60" cy="60" r="30" stroke="#0D4F47" stroke-width="1.2" opacity="0.3"/>
                  <circle cx="60" cy="60" r="6" fill="#C4973B" opacity="0.4"/>
                </svg>
            {%- endcase -%}
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div>
</section>
</cs-transform-timeline>

<style>
/* ============================================================================
   CS Timeline Base — Design Tokens & Shared Utilities
   Cyrasoul Timeline Sections
   ============================================================================ */

/* --------------------------------------------------------------------------
   Design Tokens
   -------------------------------------------------------------------------- */

:root {
  /* Brand Colors */
  --cs-gold: #FFDF00;
  --cs-gold-soft: rgba(255, 223, 0, 0.15);
  --cs-gold-medium: rgba(255, 223, 0, 0.4);
  --cs-teal: #108474;
  --cs-teal-soft: rgba(16, 132, 116, 0.15);
  --cs-teal-medium: rgba(16, 132, 116, 0.4);
  --cs-indigo: #3B3073;
  --cs-indigo-soft: rgba(59, 48, 115, 0.15);

  /* Background Surfaces */
  --cs-bg-dark: #171717;
  --cs-bg-deep: #0a0a0a;
  --cs-bg-warm: #f9f6f2;
  --cs-bg-white: #ffffff;
  --cs-bg-card-dark: rgba(255, 255, 255, 0.04);
  --cs-bg-card-frost: rgba(255, 255, 255, 0.06);

  /* Text */
  --cs-text-white: #ffffff;
  --cs-text-white-muted: rgba(255, 255, 255, 0.7);
  --cs-text-white-subtle: rgba(255, 255, 255, 0.5);
  --cs-text-dark: #171717;
  --cs-text-dark-muted: rgba(23, 23, 23, 0.7);
  --cs-text-dark-subtle: rgba(23, 23, 23, 0.5);

  /* Borders */
  --cs-border-light: rgba(255, 255, 255, 0.08);
  --cs-border-gold: rgba(255, 223, 0, 0.3);
  --cs-border-teal: rgba(16, 132, 116, 0.3);

  /* Typography — Inter stack */
  --cs-font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  --cs-font-size-xs: clamp(0.6875rem, 0.625rem + 0.25vw, 0.75rem);    /* 11-12px */
  --cs-font-size-sm: clamp(0.75rem, 0.6875rem + 0.25vw, 0.875rem);    /* 12-14px */
  --cs-font-size-base: clamp(0.875rem, 0.8125rem + 0.25vw, 1rem);     /* 14-16px */
  --cs-font-size-md: clamp(1rem, 0.9375rem + 0.25vw, 1.125rem);       /* 16-18px */
  --cs-font-size-lg: clamp(1.125rem, 1rem + 0.5vw, 1.375rem);         /* 18-22px */
  --cs-font-size-xl: clamp(1.375rem, 1.125rem + 1vw, 1.75rem);        /* 22-28px */
  --cs-font-size-2xl: clamp(1.75rem, 1.375rem + 1.5vw, 2.5rem);       /* 28-40px */
  --cs-font-size-3xl: clamp(2rem, 1.5rem + 2vw, 3rem);                /* 32-48px */

  /* Spacing */
  --cs-space-xs: clamp(0.25rem, 0.125rem + 0.5vw, 0.5rem);
  --cs-space-sm: clamp(0.5rem, 0.375rem + 0.5vw, 0.75rem);
  --cs-space-md: clamp(0.75rem, 0.5rem + 1vw, 1.25rem);
  --cs-space-lg: clamp(1.25rem, 0.875rem + 1.5vw, 2rem);
  --cs-space-xl: clamp(2rem, 1.25rem + 3vw, 3.5rem);
  --cs-space-2xl: clamp(3rem, 2rem + 4vw, 5rem);
  --cs-space-3xl: clamp(4rem, 2.5rem + 6vw, 7.5rem);

  /* Radii */
  --cs-radius-sm: 4px;
  --cs-radius-md: 8px;
  --cs-radius-lg: 12px;
  --cs-radius-xl: 16px;
  --cs-radius-full: 9999px;

  /* Shadows */
  --cs-shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.12);
  --cs-shadow-md: 0 4px 12px rgba(0, 0, 0, 0.15);
  --cs-shadow-lg: 0 8px 30px rgba(0, 0, 0, 0.2);
  --cs-shadow-gold: 0 0 20px rgba(255, 223, 0, 0.15);
  --cs-shadow-teal: 0 0 20px rgba(16, 132, 116, 0.15);

  /* Transitions */
  --cs-ease-out: cubic-bezier(0.16, 1, 0.3, 1);
  --cs-ease-in-out: cubic-bezier(0.65, 0, 0.35, 1);
  --cs-duration-fast: 200ms;
  --cs-duration-base: 400ms;
  --cs-duration-slow: 600ms;
  --cs-duration-draw: 1200ms;

  /* Z-index scale */
  --cs-z-base: 1;
  --cs-z-above: 10;
  --cs-z-sticky: 100;
  --cs-z-overlay: 200;
  --cs-z-modal: 300;

  /* Layout */
  --cs-content-max: 1200px;
  --cs-content-narrow: 640px;
  --cs-mobile-dock-clearance: 95px;
}

/* --------------------------------------------------------------------------
   Base Reset & Layout
   -------------------------------------------------------------------------- */

.cs-timeline {
  font-family: var(--cs-font-family);
  line-height: 1.6;
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

.cs-timeline *,
.cs-timeline *::before,
.cs-timeline *::after {
  box-sizing: inherit;
}

.cs-timeline__container {
  width: 100%;
  max-width: var(--cs-content-max);
  margin-inline: auto;
  padding-inline: var(--cs-space-md);
}

/* --------------------------------------------------------------------------
   Section Header (shared)
   -------------------------------------------------------------------------- */

.cs-timeline__header {
  text-align: center;
  margin-block-end: var(--cs-space-2xl);
}

.cs-timeline__kicker {
  display: inline-block;
  font-size: var(--cs-font-size-xs);
  font-weight: 600;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  margin-block-end: var(--cs-space-sm);
}

.cs-timeline__title {
  font-size: var(--cs-font-size-2xl);
  font-weight: 700;
  letter-spacing: -0.02em;
  line-height: 1.15;
  margin: 0 0 var(--cs-space-md);
}

.cs-timeline__subtitle {
  font-size: var(--cs-font-size-md);
  line-height: 1.5;
  max-width: 540px;
  margin-inline: auto;
}

/* --------------------------------------------------------------------------
   Shared Animation States — Calming reveal (opacity only, NO translate)
   -------------------------------------------------------------------------- */

.cs-transform__reveal {
  opacity: 0;
  transition: opacity 800ms var(--cs-ease-out);
}

.cs-transform__reveal--visible {
  opacity: 1;
}

/* --------------------------------------------------------------------------
   Line Draw Animation (shared)
   -------------------------------------------------------------------------- */

.cs-timeline__line-draw {
  stroke-dasharray: var(--line-length, 1000);
  stroke-dashoffset: var(--line-length, 1000);
  transition: stroke-dashoffset var(--cs-duration-draw) var(--cs-ease-in-out);
}

.cs-timeline__line-draw--active {
  stroke-dashoffset: 0;
}

/* --------------------------------------------------------------------------
   Tag / Pill (shared)
   -------------------------------------------------------------------------- */

.cs-timeline__tag {
  display: inline-flex;
  align-items: center;
  gap: 0.25em;
  font-size: var(--cs-font-size-xs);
  font-weight: 600;
  padding: 0.25em 0.75em;
  border-radius: var(--cs-radius-full);
  white-space: nowrap;
}

.cs-timeline__tag--teal {
  background: var(--cs-teal-soft);
  color: var(--cs-teal);
  border: 1px solid var(--cs-border-teal);
}

/* --------------------------------------------------------------------------
   Prefers Reduced Motion (base)
   -------------------------------------------------------------------------- */

@media (prefers-reduced-motion: reduce) {
  .cs-transform__reveal,
  .cs-timeline__line-draw {
    transition-duration: 0.01ms !important;
    animation-duration: 0.01ms !important;
  }

  .cs-transform__reveal {
    opacity: 1;
  }

  .cs-timeline__line-draw {
    stroke-dashoffset: 0;
  }
}

/* --------------------------------------------------------------------------
   Responsive Utilities
   -------------------------------------------------------------------------- */

@media screen and (max-width: 749px) {
  .cs-timeline--hide-mobile {
    display: none !important;
  }

  .cs-timeline {
    padding-block-end: var(--cs-mobile-dock-clearance);
  }
}

@media screen and (min-width: 750px) {
  .cs-timeline--hide-desktop {
    display: none !important;
  }
}

/* Screen reader only */
.cs-timeline__sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border-width: 0;
}

/* ============================================================================
   CS Transform Journey — Section-specific Styles (TheChill)
   ============================================================================ */

/* --------------------------------------------------------------------------
   Section-scoped Custom Properties
   -------------------------------------------------------------------------- */
.cs-transform {
  --ct-deep-teal: #0D4F47;
  --ct-soft-teal: #108474;
  --ct-warm-gold: #C4973B;
  --ct-text-primary: #1a1a1a;
  --ct-text-secondary: #6B6B6B;
  --ct-card-bg: #ffffff;
  --ct-science-bg: #E8F4F2;
  --ct-pill-bg: rgba(16, 132, 116, 0.1);
  --ct-pill-border: rgba(16, 132, 116, 0.25);
  --ct-node-size: 20px;
  --ct-spine-width: 2px;
}

/* --------------------------------------------------------------------------
   Section Root — Warm gradient background
   -------------------------------------------------------------------------- */
.cs-transform {
  background: linear-gradient(180deg, #f9f6f2 0%, #f0ebe4 100%);
  color: var(--ct-text-primary);
  padding-block: var(--cs-space-3xl);
  overflow: hidden;
  position: relative;
}

/* --------------------------------------------------------------------------
   Header Overrides
   -------------------------------------------------------------------------- */
.cs-transform__kicker {
  color: var(--ct-deep-teal);
}

.cs-transform__title {
  color: var(--ct-text-primary);
}

.cs-transform__subtitle {
  color: var(--ct-text-secondary);
}

/* --------------------------------------------------------------------------
   Timeline Body — central spine layout
   -------------------------------------------------------------------------- */
.cs-transform__body {
  position: relative;
  max-width: var(--cs-content-max);
  margin-inline: auto;
  padding-inline: var(--cs-space-md);
}

/* Spine */
.cs-transform__spine {
  position: absolute;
  left: 50%;
  top: 0;
  bottom: 0;
  width: var(--ct-spine-width);
  transform: translateX(-50%);
  z-index: var(--cs-z-base);
}

.cs-transform__spine-svg {
  width: 100%;
  height: 100%;
}

/* --------------------------------------------------------------------------
   Panel — milestone row
   -------------------------------------------------------------------------- */
.cs-transform__panel {
  position: relative;
  display: grid;
  align-items: center;
  gap: var(--cs-space-lg);
  padding-block: var(--cs-space-xl);
}

/* --------------------------------------------------------------------------
   Node on spine
   -------------------------------------------------------------------------- */
.cs-transform__node-wrap {
  display: none; /* shown on desktop via MQ */
}

.cs-transform__node {
  width: var(--ct-node-size);
  height: var(--ct-node-size);
  border-radius: var(--cs-radius-full);
  border: 2px solid var(--ct-warm-gold);
  background: transparent;
  transition: background 600ms var(--cs-ease-out),
              box-shadow 600ms var(--cs-ease-out),
