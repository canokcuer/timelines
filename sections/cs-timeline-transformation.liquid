                      </g>
                      <g transform="translate(191,76)">
                        <ellipse rx="4" ry="10" stroke="#0D4F47" stroke-width="0.7" opacity="0.42" fill="none"/>
                        <ellipse rx="4" ry="10" stroke="#0D4F47" stroke-width="0.7" opacity="0.38" fill="none" transform="rotate(45)"/>
                        <ellipse rx="4" ry="10" stroke="#0D4F47" stroke-width="0.7" opacity="0.42" fill="none" transform="rotate(90)"/>
                        <ellipse rx="4" ry="10" stroke="#0D4F47" stroke-width="0.7" opacity="0.38" fill="none" transform="rotate(135)"/>
                        <circle r="4" stroke="#C4973B" stroke-width="0.7" fill="#C4973B" opacity="0.18"/>
                      </g>
                      <g transform="translate(191,164)">
                        <polygon points="0,-14 3,-5 12,-5 5,1 7,10 0,5 -7,10 -5,1 -12,-5 -3,-5" stroke="#C4973B" stroke-width="0.7" opacity="0.38" fill="#C4973B" fill-opacity="0.03"/>
                        <line x1="0" y1="0" x2="0" y2="-11" stroke="#C4973B" stroke-width="0.4" opacity="0.2"/>
                        <line x1="0" y1="0" x2="10" y2="-4" stroke="#C4973B" stroke-width="0.4" opacity="0.2"/>
                        <line x1="0" y1="0" x2="6" y2="9" stroke="#C4973B" stroke-width="0.4" opacity="0.2"/>
                        <line x1="0" y1="0" x2="-6" y2="9" stroke="#C4973B" stroke-width="0.4" opacity="0.2"/>
                        <line x1="0" y1="0" x2="-10" y2="-4" stroke="#C4973B" stroke-width="0.4" opacity="0.2"/>
                        <circle r="2.5" fill="#C4973B" opacity="0.18"/>
                      </g>
                      <g transform="translate(120,202)">
