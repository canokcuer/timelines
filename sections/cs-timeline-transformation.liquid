  flex-direction: column;
  gap: var(--cs-space-sm);
}

.cs-transform__benefit {
  display: flex;
  align-items: baseline;
  gap: var(--cs-space-sm);
  flex-wrap: wrap;
}

.cs-transform__benefit-text {
