              {%- comment -%} Benefit Bullets with Ingredient Pills {%- endcomment -%}
              {%- if block.settings.benefit_1 != blank or block.settings.benefit_2 != blank or block.settings.benefit_3 != blank -%}
                <ul class="cs-transform__benefits" aria-label="Faydalar">
                  {%- if block.settings.benefit_1 != blank -%}
                    <li class="cs-transform__benefit">
                      <span class="cs-transform__benefit-text">{{ block.settings.benefit_1 }}</span>
                      {%- if block.settings.benefit_pill_1 != blank -%}
                        <span class="cs-transform__pill cs-transform__pill--inline">{{ block.settings.benefit_pill_1 }}</span>
                      {%- endif -%}
                    </li>
                  {%- endif -%}
                  {%- if block.settings.benefit_2 != blank -%}
                    <li class="cs-transform__benefit">
                      <span class="cs-transform__benefit-text">{{ block.settings.benefit_2 }}</span>
                      {%- if block.settings.benefit_pill_2 != blank -%}
                        <span class="cs-transform__pill cs-transform__pill--inline">{{ block.settings.benefit_pill_2 }}</span>
                      {%- endif -%}
                    </li>
                  {%- endif -%}
                  {%- if block.settings.benefit_3 != blank -%}
                    <li class="cs-transform__benefit">
                      <span class="cs-transform__benefit-text">{{ block.settings.benefit_3 }}</span>
                      {%- if block.settings.benefit_pill_3 != blank -%}
                        <span class="cs-transform__pill cs-transform__pill--inline">{{ block.settings.benefit_pill_3 }}</span>
                      {%- endif -%}
                    </li>
                  {%- endif -%}
                </ul>
              {%- endif -%}

              {%- comment -%} Ingredient Pills (legacy / summary) {%- endcomment -%}
              {%- if block.settings.ingredient_pills != blank -%}
                <div class="cs-transform__pills" aria-label="Bileşenler">
                  {%- assign pills = block.settings.ingredient_pills | split: ',' -%}
                  {%- for pill in pills -%}
                    {%- assign trimmed = pill | strip -%}
                    {%- if trimmed != blank -%}
                      <span class="cs-transform__pill">{{ trimmed }}</span>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              {%- endif -%}

              {%- comment -%} Storytelling {%- endcomment -%}
              {%- if block.settings.storytelling != blank -%}
                <p class="cs-transform__story">
                  {{ block.settings.storytelling }}
                </p>
              {%- endif -%}

              {%- comment -%} Science References (3 per slide) {%- endcomment -%}
              {%- if block.settings.science_ref_1 != blank or block.settings.science_ref_2 != blank or block.settings.science_ref_3 != blank -%}
                <div class="cs-transform__science-list">
                  <span class="cs-transform__science-list-icon" aria-hidden="true">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                      <path d="M6 2v4L4 9v1h8V9l-2-3V2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                      <path d="M4 13h8" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                      <circle cx="8" cy="9" r="1" fill="currentColor"/>
                    </svg>
                  </span>
                  <ul class="cs-transform__science-refs">
                    {%- if block.settings.science_ref_1 != blank -%}
                      <li class="cs-transform__science-ref-item">
                        <p class="cs-transform__science-text">{{ block.settings.science_ref_1 }}</p>
                        {%- if block.settings.science_pmid_1 != blank -%}
                          <cite class="cs-transform__science-ref">PMID: {{ block.settings.science_pmid_1 }}</cite>
                        {%- endif -%}
                      </li>
                    {%- endif -%}
                    {%- if block.settings.science_ref_2 != blank -%}
                      <li class="cs-transform__science-ref-item">
                        <p class="cs-transform__science-text">{{ block.settings.science_ref_2 }}</p>
                        {%- if block.settings.science_pmid_2 != blank -%}
                          <cite class="cs-transform__science-ref">PMID: {{ block.settings.science_pmid_2 }}</cite>
                        {%- endif -%}
                      </li>
                    {%- endif -%}
                    {%- if block.settings.science_ref_3 != blank -%}
                      <li class="cs-transform__science-ref-item">
                        <p class="cs-transform__science-text">{{ block.settings.science_ref_3 }}</p>
                        {%- if block.settings.science_pmid_3 != blank -%}
                          <cite class="cs-transform__science-ref">PMID: {{ block.settings.science_pmid_3 }}</cite>
                        {%- endif -%}
                      </li>
                    {%- endif -%}
                  </ul>
                </div>
              {%- endif -%}

              {%- comment -%} CTA Button — opens Visual Bundle Builder dock {%- endcomment -%}
              <div class="cs-transform__cta-wrap">
                {%- assign product = section.settings.product -%}
                {%- if product != blank -%}
                  <button
                    type="button"
                    class="cs-transform__cta"
                    data-cs-open-bundle
                    data-product-handle="{{ product.handle }}"
                    data-cart-quantity="{{ block.settings.cart_quantity | default: 1 }}"
                    aria-label="Yolculuğuna Başla — {{ block.settings.cart_quantity | default: 1 }} adet"
                  >
                    Yolculuğuna Başla
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" focusable="false">
                      <path d="M3.333 8h9.334M8.667 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </button>
                {%- else -%}
                  <a
                    href="{{ section.settings.cta_url | default: '#' }}"
                    class="cs-transform__cta"
                    aria-label="Yolculuğuna Başla"
                  >
                    Yolculuğuna Başla
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" focusable="false">
                      <path d="M3.333 8h9.334M8.667 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </a>
                {%- endif -%}
              </div>

            </div>
          </div>
        {%- endfor -%}
      </div>


    </div>

  </div>
</section>
</cs-transform-timeline>

<style>
/* ============================================================================
   CS Timeline Base — Design Tokens & Shared Utilities
   ============================================================================ */

:root {
  --cs-gold: #FFDF00;
  --cs-gold-soft: rgba(255, 223, 0, 0.15);
  --cs-gold-medium: rgba(255, 223, 0, 0.4);
  --cs-teal: #108474;
  --cs-teal-soft: rgba(16, 132, 116, 0.15);
  --cs-teal-medium: rgba(16, 132, 116, 0.4);
  --cs-indigo: #3B3073;
  --cs-indigo-soft: rgba(59, 48, 115, 0.15);

  --cs-bg-dark: #171717;
  --cs-bg-deep: #0a0a0a;
  --cs-bg-warm: #f9f6f2;
  --cs-bg-white: #ffffff;
  --cs-bg-card-dark: rgba(255, 255, 255, 0.04);
  --cs-bg-card-frost: rgba(255, 255, 255, 0.06);

  --cs-text-white: #ffffff;
  --cs-text-white-muted: rgba(255, 255, 255, 0.7);
  --cs-text-white-subtle: rgba(255, 255, 255, 0.5);
  --cs-text-dark: #171717;
  --cs-text-dark-muted: rgba(23, 23, 23, 0.7);
  --cs-text-dark-subtle: rgba(23, 23, 23, 0.5);

  --cs-border-light: rgba(255, 255, 255, 0.08);
  --cs-border-gold: rgba(255, 223, 0, 0.3);
  --cs-border-teal: rgba(16, 132, 116, 0.3);

  --cs-font-family: Inter, sans-serif;
  --cs-font-size-xs: clamp(0.6875rem, 0.625rem + 0.25vw, 0.75rem);
  --cs-font-size-sm: clamp(0.75rem, 0.6875rem + 0.25vw, 0.875rem);
  --cs-font-size-base: clamp(0.875rem, 0.8125rem + 0.25vw, 1rem);
  --cs-font-size-md: clamp(1rem, 0.9375rem + 0.25vw, 1.125rem);
  --cs-font-size-lg: clamp(1.125rem, 1rem + 0.5vw, 1.375rem);
  --cs-font-size-xl: clamp(1.375rem, 1.125rem + 1vw, 1.75rem);
  --cs-font-size-2xl: clamp(1.75rem, 1.375rem + 1.5vw, 2.5rem);
  --cs-font-size-3xl: clamp(2rem, 1.5rem + 2vw, 3rem);

  --cs-space-xs: clamp(0.25rem, 0.125rem + 0.5vw, 0.5rem);
  --cs-space-sm: clamp(0.5rem, 0.375rem + 0.5vw, 0.75rem);
  --cs-space-md: clamp(0.75rem, 0.5rem + 1vw, 1.25rem);
  --cs-space-lg: clamp(1.25rem, 0.875rem + 1.5vw, 2rem);
  --cs-space-xl: clamp(2rem, 1.25rem + 3vw, 3.5rem);
  --cs-space-2xl: clamp(3rem, 2rem + 4vw, 5rem);
  --cs-space-3xl: clamp(4rem, 2.5rem + 6vw, 7.5rem);

  --cs-radius-sm: 4px;
  --cs-radius-md: 8px;
  --cs-radius-lg: 12px;
  --cs-radius-xl: 16px;
  --cs-radius-full: 9999px;

  --cs-shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.12);
  --cs-shadow-md: 0 4px 12px rgba(0, 0, 0, 0.15);
  --cs-shadow-lg: 0 8px 30px rgba(0, 0, 0, 0.2);
  --cs-shadow-gold: 0 0 20px rgba(255, 223, 0, 0.15);
  --cs-shadow-teal: 0 0 20px rgba(16, 132, 116, 0.15);

  --cs-ease-out: cubic-bezier(0.16, 1, 0.3, 1);
  --cs-ease-in-out: cubic-bezier(0.65, 0, 0.35, 1);
  --cs-duration-fast: 200ms;
  --cs-duration-base: 400ms;
  --cs-duration-slow: 600ms;
  --cs-duration-draw: 1200ms;

  --cs-z-base: 1;
  --cs-z-above: 10;
  --cs-z-sticky: 100;
  --cs-z-overlay: 200;
  --cs-z-modal: 300;

  --cs-content-max: 1200px;
  --cs-content-narrow: 640px;
  --cs-mobile-dock-clearance: 95px;
}

/* --------------------------------------------------------------------------
   Base Reset
   -------------------------------------------------------------------------- */
.cs-timeline {
  font-family: var(--cs-font-family);
  line-height: 1.6;
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

.cs-timeline *,
.cs-timeline *::before,
.cs-timeline *::after {
  box-sizing: inherit;
}

.cs-timeline__container {
  width: 100%;
  max-width: var(--cs-content-max);
  margin-inline: auto;
  padding-inline: var(--cs-space-md);
}

/* --------------------------------------------------------------------------
   Section Header (shared)
   -------------------------------------------------------------------------- */
.cs-timeline__header {
  text-align: center;
  margin-block-end: var(--ct-header-gap, 32px);
}

.cs-timeline__kicker {
  display: inline-block;
  font-size: var(--cs-font-size-xs);
  font-weight: 600;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  margin-block-end: var(--cs-space-sm);
}

.cs-timeline__title {
  font-size: var(--cs-font-size-2xl);
  font-weight: 500;
  letter-spacing: -0.03em;
  line-height: 1.12;
  margin: 0 0 var(--cs-space-md);
}

.cs-timeline__subtitle {
  font-size: var(--cs-font-size-md);
  line-height: 1.5;
  max-width: 540px;
  margin-inline: auto;
}

/* --------------------------------------------------------------------------
   Calming Reveal
   -------------------------------------------------------------------------- */
.cs-transform__reveal {
  opacity: 0;
  transition: opacity 800ms var(--cs-ease-out);
}

.cs-transform__reveal--visible {
  opacity: 1;
}

/* --------------------------------------------------------------------------
   Responsive Utilities
   -------------------------------------------------------------------------- */
@media screen and (max-width: 749px) {
  .cs-timeline--hide-mobile { display: none !important; }
  .cs-timeline { padding-block-end: var(--cs-mobile-dock-clearance); }
}

@media screen and (min-width: 750px) {
  .cs-timeline--hide-desktop { display: none !important; }
}

.cs-timeline__sr-only {
  position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
  overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border-width: 0;
}

/* ============================================================================
   CS Transform — Hybrid Stepper + Carousel
   ============================================================================ */

.cs-transform {
  --ct-deep-teal: #00352F;
  --ct-soft-teal: #108474;
  --ct-warm-gold: #C4973B;
  --ct-text-primary: #333333;
  --ct-text-secondary: #7B7B7B;
  --ct-card-bg: #ffffff;
  --ct-science-bg: #f0f9f7;
  --ct-pill-bg: rgba(16, 132, 116, 0.08);
  --ct-pill-border: rgba(16, 132, 116, 0.2);
  --ct-btn-bg: #333333;
  --ct-btn-text: #FAFAFA;
}

/* --------------------------------------------------------------------------
   Section Root
   -------------------------------------------------------------------------- */
.cs-transform {
  background: #ffffff;
  color: var(--ct-text-primary);
  padding-top: var(--ct-padding-top, 40px);
  padding-bottom: var(--ct-padding-bottom, 40px);
  overflow: hidden;
  position: relative;
}

.cs-transform__kicker { color: var(--ct-deep-teal); }
.cs-transform__title { color: var(--ct-text-primary); }
.cs-transform__subtitle { color: var(--ct-text-secondary); }

/* ============================================================================
   Stepper Bar
   ============================================================================ */
.cs-transform__stepper {
  position: relative;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  max-width: 600px;
  margin: 0 auto var(--ct-stepper-gap, 32px);
  padding-inline: var(--cs-space-md);
}

.cs-transform__stepper-rail {
  position: absolute;
  top: 16px;
  left: calc(var(--cs-space-md) + 16px);
  right: calc(var(--cs-space-md) + 16px);
  height: 3px;
  background: rgba(0, 53, 47, 0.12);
  border-radius: 2px;
  z-index: 0;
}

.cs-transform__stepper-fill {
  position: absolute;
  top: 0;
  left: 0;
  height: 100%;
  width: 0%;
  background: var(--ct-warm-gold);
  border-radius: 2px;
  transition: width var(--cs-duration-base) var(--cs-ease-out);
}

.cs-transform__step {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 0;
  -webkit-tap-highlight-color: transparent;
}

.cs-transform__step-node {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 32px;
  height: 32px;
  border-radius: var(--cs-radius-full);
  border: 2.5px solid rgba(0, 53, 47, 0.2);
  background: var(--ct-card-bg);
  font-family: var(--cs-font-family);
  font-size: 13px;
  font-weight: 700;
  color: var(--ct-text-secondary);
  transition:
    border-color var(--cs-duration-fast) var(--cs-ease-out),
    background var(--cs-duration-fast) var(--cs-ease-out),
    color var(--cs-duration-fast) var(--cs-ease-out),
    transform var(--cs-duration-fast) var(--cs-ease-out),
    box-shadow var(--cs-duration-fast) var(--cs-ease-out);
}

.cs-transform__step-label {
  font-family: var(--cs-font-family);
  font-size: 11px;
  font-weight: 600;
  color: var(--ct-text-secondary);
  letter-spacing: 0.03em;
  white-space: nowrap;
  transition: color var(--cs-duration-fast) var(--cs-ease-out);
}

/* Active step */
.cs-transform__step--active .cs-transform__step-node {
  border-color: var(--ct-warm-gold);
  background: var(--ct-warm-gold);
  color: #ffffff;
  transform: scale(1.1);
  box-shadow: 0 2px 8px rgba(196, 151, 59, 0.3);
}

.cs-transform__step--active .cs-transform__step-label {
  color: var(--ct-deep-teal);
  font-weight: 700;
}

/* Completed step */
.cs-transform__step--completed .cs-transform__step-node {
  border-color: var(--ct-soft-teal);
  background: var(--ct-soft-teal);
  color: #ffffff;
}

.cs-transform__step--completed .cs-transform__step-label {
  color: var(--ct-soft-teal);
}

/* Hover (non-active, non-completed) */
.cs-transform__step:hover:not(.cs-transform__step--active):not(.cs-transform__step--completed) .cs-transform__step-node {
  border-color: var(--ct-deep-teal);
  color: var(--ct-deep-teal);
}

.cs-transform__step:focus-visible .cs-transform__step-node {
  outline: 2px solid var(--ct-deep-teal);
  outline-offset: 2px;
}

/* --------------------------------------------------------------------------
   Carousel Wrapper
   -------------------------------------------------------------------------- */
.cs-transform__carousel {
  position: relative;
  max-width: 900px;
  margin-inline: auto;
}

/* --------------------------------------------------------------------------
   Scroll-Snap Track
   -------------------------------------------------------------------------- */
.cs-transform__track {
  display: flex;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
  scroll-behavior: smooth;
  gap: 0;
}

/* Hide scrollbar */
.cs-transform__track::-webkit-scrollbar {
  display: none;
}

.cs-transform__track {
  scrollbar-width: none;
  -ms-overflow-style: none;
}

/* --------------------------------------------------------------------------
   Slide
   -------------------------------------------------------------------------- */
.cs-transform__slide {
  flex: 0 0 100%;
  scroll-snap-align: center;
  min-width: 0;
}

.cs-transform__slide-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  max-width: 640px;
  margin-inline: auto;
  padding: var(--cs-space-lg) var(--cs-space-md);
}

/* --------------------------------------------------------------------------
   Time Badge
   -------------------------------------------------------------------------- */
.cs-transform__time-badge {
  display: inline-flex;
  align-items: center;
  font-size: var(--cs-font-size-xs);
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--ct-deep-teal);
  background: var(--ct-card-bg);
  border: 1px solid rgba(0, 0, 0, 0.08);
  border-left: 3px solid var(--ct-warm-gold);
  border-radius: var(--cs-radius-full);
  padding: 0.4em 1.2em 0.4em 1em;
  margin-block-end: var(--cs-space-lg);
  box-shadow: var(--cs-shadow-sm);
}

/* --------------------------------------------------------------------------
   Illustration Frame
   -------------------------------------------------------------------------- */
.cs-transform__illust-frame {
  width: 200px;
  height: 200px;
  border-radius: var(--cs-radius-full);
  background: rgba(0, 53, 47, 0.02);
  border: 1px solid rgba(0, 53, 47, 0.05);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-block-end: var(--cs-space-lg);
  animation: ct-float 5s ease-in-out infinite;
}

.cs-transform__illust-svg {
  width: 88%;
  height: 88%;
}

@keyframes ct-float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-6px); }
}

@media screen and (min-width: 750px) {
  .cs-transform__illust-frame {
    width: 260px;
    height: 260px;
  }
}

/* --------------------------------------------------------------------------
   Slide Headline
   -------------------------------------------------------------------------- */
.cs-transform__slide-headline {
  font-size: var(--cs-font-size-xl);
  font-weight: 700;
  color: var(--ct-text-primary);
  margin: 0 0 var(--cs-space-md);
  line-height: 1.2;
  letter-spacing: -0.02em;
}

/* --------------------------------------------------------------------------
   Benefit Bullets
   -------------------------------------------------------------------------- */
.cs-transform__benefits {
  list-style: none;
  padding: 0;
  margin: 0 0 var(--cs-space-md);
  text-align: left;
  width: 100%;
  max-width: 520px;
}

.cs-transform__benefit {
  position: relative;
  padding-left: 1.25em;
  margin-block-end: var(--cs-space-sm);
  font-size: var(--cs-font-size-sm);
  color: var(--ct-text-secondary);
  line-height: 1.55;
}

.cs-transform__benefit::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0.55em;
  width: 6px;
  height: 6px;
  border-radius: var(--cs-radius-full);
  background: var(--ct-soft-teal);
  opacity: 0.6;
}

.cs-transform__benefit-text {
  display: inline;
}

/* --------------------------------------------------------------------------
   Ingredient Pills
   -------------------------------------------------------------------------- */
.cs-transform__pills {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: var(--cs-space-xs);
  margin-block-end: var(--cs-space-md);
}

.cs-transform__pill {
  display: inline-flex;
  align-items: center;
  font-size: 11px;
  font-weight: 700;
  padding: 0.3em 0.8em;
  border-radius: var(--cs-radius-full);
  background: var(--ct-pill-bg);
  color: var(--ct-soft-teal);
  border: 1px solid var(--ct-pill-border);
  white-space: nowrap;
  letter-spacing: 0.02em;
  text-transform: uppercase;
}

.cs-transform__pill--inline {
  margin-left: 0.4em;
  font-size: 10px;
  padding: 0.2em 0.6em;
  vertical-align: middle;
}

/* --------------------------------------------------------------------------
   Storytelling Paragraph
   -------------------------------------------------------------------------- */
.cs-transform__story {
  font-size: var(--cs-font-size-sm);
  color: var(--ct-text-secondary);
  line-height: 1.65;
  margin: 0 0 var(--cs-space-md);
  max-width: 520px;
}

/* --------------------------------------------------------------------------
   Science References (3 per slide — bullet list)
   -------------------------------------------------------------------------- */
.cs-transform__science-list {
  display: flex;
  align-items: flex-start;
  gap: var(--cs-space-sm);
  background: var(--ct-science-bg);
  border-radius: var(--cs-radius-md);
  border-left: 3px solid var(--ct-soft-teal);
  padding: var(--cs-space-md);
  margin-block-end: var(--cs-space-lg);
  text-align: left;
  max-width: 520px;
  width: 100%;
}

.cs-transform__science-list-icon {
  flex-shrink: 0;
  color: var(--ct-soft-teal);
  margin-top: 2px;
}

.cs-transform__science-refs {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: var(--cs-space-sm);
}

.cs-transform__science-ref-item {
  padding-bottom: var(--cs-space-xs);
  border-bottom: 1px solid rgba(16, 132, 116, 0.1);
}

.cs-transform__science-ref-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.cs-transform__science-text {
  font-size: var(--cs-font-size-xs);
  font-style: italic;
  color: var(--ct-text-secondary);
  line-height: 1.5;
  margin: 0;
}

.cs-transform__science-ref {
  display: block;
  font-size: 10px;
  color: var(--ct-soft-teal);
  margin-block-start: 4px;
  font-style: normal;
  opacity: 0.8;
  font-weight: 600;
}

/* --------------------------------------------------------------------------
   CTA Button
   -------------------------------------------------------------------------- */
.cs-transform__cta-wrap {
  width: 100%;
  display: flex;
  justify-content: center;
}

.cs-transform__cta {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5em;
  font-family: var(--cs-font-family);
  font-size: var(--cs-font-size-sm);
  font-weight: 600;
  letter-spacing: 0.04em;
  text-decoration: none;
  padding: 0.875em 2em;
  border-radius: 3.75rem;
  border: none;
  cursor: pointer;
  min-height: 44px;
  min-width: 44px;
  background: var(--ct-btn-bg);
  color: var(--ct-btn-text);
  border: 2px solid var(--ct-btn-bg);
  transition:
    background var(--cs-duration-fast) var(--cs-ease-out),
    transform var(--cs-duration-fast) var(--cs-ease-out),
    box-shadow var(--cs-duration-fast) var(--cs-ease-out);
}

.cs-transform__cta:hover {
  background: transparent;
  color: var(--ct-btn-bg);
  transform: translateY(-1px);
  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
}

.cs-transform__cta:active {
  transform: translateY(0);
}

.cs-transform__cta[disabled] {
  opacity: 0.6;
  cursor: not-allowed;
}


/* --------------------------------------------------------------------------
   Mobile Overrides (< 750px)
   -------------------------------------------------------------------------- */
@media screen and (max-width: 749px) {
  .cs-transform__slide-inner {
    padding-inline: var(--cs-space-sm);
  }

  .cs-transform__slide-headline {
    font-size: var(--cs-font-size-lg);
  }

  .cs-transform__illust-frame {
    width: 180px;
    height: 180px;
  }

  .cs-transform__story {
    font-size: var(--cs-font-size-xs);
  }

  .cs-transform__science-list {
    padding: var(--cs-space-sm);
  }

  .cs-transform__science-text {
    font-size: 11px;
  }

  /* Stepper: smaller on mobile */
  .cs-transform__stepper {
    padding-inline: var(--cs-space-xs);
    max-width: 100%;
  }

  .cs-transform__step-node {
    width: 28px;
    height: 28px;
    font-size: 11px;
  }

  .cs-transform__step-label {
    font-size: 9px;
  }

  .cs-transform__stepper-rail {
    top: 14px;
