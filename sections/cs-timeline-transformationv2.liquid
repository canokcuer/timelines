{% comment %}
  TheChill Dönüşüm Yolculuğu — Hybrid Stepper + Carousel v2.
  Self-contained: all styles, scripts, and SVG illustrations inlined.
  4 science-backed milestones with clickable stepper + swipeable carousel.
  Each slide: 3 benefit bullets, 3 scientific references, CTA.
{% endcomment %}

<cs-transform-timeline>
<section
  id="cs-transform-{{ section.id }}"
  class="cs-timeline cs-transform"
  aria-label="{{ section.settings.kicker | default: 'Dönüşüm Yolculuğu' }}"
  data-cs-transform
  style="--ct-padding-top: {{ section.settings.padding_top }}px; --ct-padding-bottom: {{ section.settings.padding_bottom }}px; --ct-header-gap: {{ section.settings.header_gap }}px; --ct-stepper-gap: {{ section.settings.stepper_gap }}px;"
>
  <div class="cs-timeline__container">

    {%- comment -%} ── Section Header ──────────────────────────────── {%- endcomment -%}
    <header class="cs-timeline__header cs-transform__header cs-transform__reveal">
      {%- if section.settings.kicker != blank -%}
        <span class="cs-timeline__kicker cs-transform__kicker">
          {{ section.settings.kicker }}
        </span>
      {%- endif -%}

      <h2 class="cs-timeline__title cs-transform__title">
        {{ section.settings.title }}
      </h2>

      {%- if section.settings.subtitle != blank -%}
        <p class="cs-timeline__subtitle cs-transform__subtitle">
          {{ section.settings.subtitle }}
        </p>
      {%- endif -%}
    </header>

    {%- comment -%} ── Stepper Bar ─────────────────────────────────── {%- endcomment -%}
    <div class="cs-transform__stepper cs-transform__reveal" role="tablist" aria-label="Dönüşüm adımları">
      <div class="cs-transform__stepper-rail">
        <div class="cs-transform__stepper-fill" data-cs-stepper-fill></div>
      </div>
      {%- for block in section.blocks -%}
        <button
          type="button"
          class="cs-transform__step{% if forloop.first %} cs-transform__step--active{% endif %}"
          role="tab"
          aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
          aria-label="Adım {{ forloop.index }}: {{ block.settings.time_label }}"
          data-cs-step="{{ forloop.index0 }}"
          tabindex="{% if forloop.first %}0{% else %}-1{% endif %}"
        >
          <span class="cs-transform__step-node">{{ forloop.index }}</span>
          <span class="cs-transform__step-label">{{ block.settings.time_label }}</span>
        </button>
      {%- endfor -%}
    </div>

    {%- comment -%} ── Carousel ────────────────────────────────────── {%- endcomment -%}
    <div
      class="cs-transform__carousel cs-transform__reveal"
      role="region"
      aria-roledescription="carousel"
      aria-label="Dönüşüm adımları"
    >
      {%- comment -%} ── Slide Track ─────────────────────────────── {%- endcomment -%}
      <div class="cs-transform__track" data-cs-track>
        {%- for block in section.blocks -%}
          <div
            class="cs-transform__slide"
            role="group"
            aria-roledescription="slide"
            aria-label="{{ block.settings.time_label }} — {{ forloop.index }} / {{ forloop.length }}"
            data-cs-slide="{{ forloop.index0 }}"
            {{ block.shopify_attributes }}
          >
            <div class="cs-transform__slide-inner">

              {%- comment -%} Time Badge {%- endcomment -%}
              <div class="cs-transform__time-badge">
                {{ block.settings.time_label }}
              </div>

              {%- comment -%} SVG Illustration {%- endcomment -%}
              <div class="cs-transform__illust-frame">
                {%- case block.settings.illustration -%}

                  {%- when 'molecule' -%}
